{
  "wireMagic": "pb3",
  "pens": [ {
  
  } ],
  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 80,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "Today is for any young Indian boy or girl,\nunder the age of 25,"
    } ]
  }, {
    "tStartMs": 4360,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "who wants to start\na consumer electronic brand."
    } ]
  }, {
    "tStartMs": 27920,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Start? Okay, ready?"
    } ]
  }, {
    "tStartMs": 31480,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "All right."
    } ]
  }, {
    "tStartMs": 41400,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "Hi, guys, thank you for coming home\nand doing this."
    } ]
  }, {
    "tStartMs": 46480,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "I think Carl had to travel\nfrom further, further away."
    } ]
  }, {
    "tStartMs": 50240,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "-Mm-hmm.\n-Amit and Rahul live closer in Delhi."
    } ]
  }, {
    "tStartMs": 54560,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "So maybe we start\nby speaking about ourselves,"
    } ]
  }, {
    "tStartMs": 59320,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "giving my audience an intro of who we are,"
    } ]
  }, {
    "tStartMs": 64440,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "how we got to be where we are."
    } ]
  }, {
    "tStartMs": 67680,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "Rahul is already a friend of mine,\nso I know a lot about him."
    } ]
  }, {
    "tStartMs": 71200,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "But maybe we start with Carl."
    } ]
  }, {
    "tStartMs": 74000,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Sure. I'm happy to be here."
    } ]
  }, {
    "tStartMs": 76280,
    "dDurationMs": 4880,
    "segs": [ {
      "utf8": "It took a while for us to schedule it\nback and forth, but we're finally here."
    } ]
  }, {
    "tStartMs": 81920,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "So I'm Carl."
    } ]
  }, {
    "tStartMs": 83080,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "I'm one of the co-founders of a company\ncalled Nothing."
    } ]
  }, {
    "tStartMs": 86960,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "But ever since I can remember,\nI was always a tech fan."
    } ]
  }, {
    "tStartMs": 90720,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "I grew up in Stockholm, in Sweden."
    } ]
  }, {
    "tStartMs": 92440,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "I remember, my parents got me\nthe first iPod."
    } ]
  }, {
    "tStartMs": 96600,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "And I was only like 12 at the time."
    } ]
  }, {
    "tStartMs": 98960,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "And the first-generation iPod\nwas very complicated,"
    } ]
  }, {
    "tStartMs": 102000,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "because, I don't know\nif you guys remember,"
    } ]
  }, {
    "tStartMs": 103920,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "-it had the FireWire connection.\n-[Rahul] Right."
    } ]
  }, {
    "tStartMs": 106520,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "I had a PC.\nIt didn't have the FireWire connection."
    } ]
  }, {
    "tStartMs": 109920,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "So I had to buy...\nFirst, I got the iPod, I didn't know."
    } ]
  }, {
    "tStartMs": 113080,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "-I couldn't connect it to the PC.\n-Right."
    } ]
  }, {
    "tStartMs": 116040,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "Then I had to buy a PCI card for FireWire,"
    } ]
  }, {
    "tStartMs": 118800,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "install that, to even be able\nto connect the iPod."
    } ]
  }, {
    "tStartMs": 122880,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "And back then, there was no iTunes,"
    } ]
  }, {
    "tStartMs": 124200,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "so it was RealPlayer to manage the music."
    } ]
  }, {
    "tStartMs": 128240,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "Well, anyway, that product\ngot me really hooked on technology."
    } ]
  }, {
    "tStartMs": 131680,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "The scroll wheel was really cool,\nand managing the music library,"
    } ]
  }, {
    "tStartMs": 136320,
    "dDurationMs": 5760,
    "segs": [ {
      "utf8": "fixing all the ID3 tags for each song,\ngetting the album arts perfect."
    } ]
  }, {
    "tStartMs": 142880,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "And a couple of years later,\nI was probably..."
    } ]
  }, {
    "tStartMs": 145920,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "So I think I was the first to get the iPod\nin my entire school."
    } ]
  }, {
    "tStartMs": 150280,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "So I was a cool kid among the nerds\nin the beginning."
    } ]
  }, {
    "tStartMs": 153720,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Where was the school, Carl?"
    } ]
  }, {
    "tStartMs": 155520,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "That was in Stockholm."
    } ]
  }, {
    "tStartMs": 157800,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "What year are we talking about?"
    } ]
  }, {
    "tStartMs": 159520,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "iPod. When was the iPod?"
    } ]
  }, {
    "tStartMs": 161480,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "2001?"
    } ]
  }, {
    "tStartMs": 162960,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Yeah. You're 36 today, right?"
    } ]
  }, {
    "tStartMs": 164640,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Yeah, I'm 35... turning 36."
    } ]
  }, {
    "tStartMs": 168080,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "So when I was 12, I got the iPod."
    } ]
  }, {
    "tStartMs": 169720,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Really excited about that product."
    } ]
  }, {
    "tStartMs": 171920,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "Then I got the first iPhone\nthrough a friend in the US,"
    } ]
  }, {
    "tStartMs": 176280,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "because the iPhone\nwas only exclusive with AT\u0026T."
    } ]
  }, {
    "tStartMs": 181040,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "So I had a friend buy it for me,"
    } ]
  }, {
    "tStartMs": 182360,
    "dDurationMs": 5320,
    "segs": [ {
      "utf8": "and then we had to pay\na $450 cancellation fee on the contract,"
    } ]
  }, {
    "tStartMs": 187760,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "and then got it shipped,\nand then jailbroke it,"
    } ]
  }, {
    "tStartMs": 190240,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "and installed my own SIM card."
    } ]
  }, {
    "tStartMs": 191560,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "So I was the first among all my friends\nto get the iPhone."
    } ]
  }, {
    "tStartMs": 194480,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "But I think those two products\nwere super formative for me."
    } ]
  }, {
    "tStartMs": 197840,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "I guess the third thing\nthat happened was..."
    } ]
  }, {
    "tStartMs": 201240,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Then I got the iPad."
    } ]
  }, {
    "tStartMs": 202640,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "I forgot which year,\nbut the first year the iPad came out."
    } ]
  }, {
    "tStartMs": 205880,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "And I don't know if you guys remember,\nit used to have a skeuomorphic UI."
    } ]
  }, {
    "tStartMs": 209880,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "So, basically, the UI tried to mimic\nhow things look like in real life."
    } ]
  }, {
    "tStartMs": 214080,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "And when you swipe from the bottom,\nthere was a control panel."
    } ]
  }, {
    "tStartMs": 218760,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "And it was like metallic."
    } ]
  }, {
    "tStartMs": 220120,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "So you had like a volume knob\nthat was brushed metal."
    } ]
  }, {
    "tStartMs": 223360,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "But when you tilted the iPad,"
    } ]
  }, {
    "tStartMs": 225440,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "the light source of the graphic\nalso changed."
    } ]
  }, {
    "tStartMs": 229600,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "So, I'm like, \"Oh, my God,"
    } ]
  }, {
    "tStartMs": 231200,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "like, if Apple thinks about\nevery little detail like this..."
    } ]
  }, {
    "tStartMs": 236440,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "I can trust them on like...\nThey've figured everything out.\""
    } ]
  }, {
    "tStartMs": 239520,
    "dDurationMs": 5360,
    "segs": [ {
      "utf8": "So those three moments made me a big fan\nof this industry and of Apple."
    } ]
  }, {
    "tStartMs": 244960,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Do you still feel that way about Apple?"
    } ]
  }, {
    "tStartMs": 247440,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "No, it's a very different company now."
    } ]
  }, {
    "tStartMs": 249640,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "When did it change?"
    } ]
  }, {
    "tStartMs": 251320,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "I think the change has been gradual."
    } ]
  }, {
    "tStartMs": 253320,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "I think the two CEOs have had\na very different approach"
    } ]
  }, {
    "tStartMs": 257800,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "to running the company."
    } ]
  }, {
    "tStartMs": 260840,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "I mean, the stock price doesn't lie."
    } ]
  }, {
    "tStartMs": 262640,
    "dDurationMs": 5360,
    "segs": [ {
      "utf8": "I think Tim Cook has done a great job\non the shareholder value creation side."
    } ]
  }, {
    "tStartMs": 268080,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "But when it just comes to inspiring\na young guy or a young person"
    } ]
  }, {
    "tStartMs": 272200,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "to take a career in tech, I think\nthe old Apple was way better at that."
    } ]
  }, {
    "tStartMs": 278520,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "So really inspired by those products."
    } ]
  }, {
    "tStartMs": 280720,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "And then, I was chronically online\nas a kid."
    } ]
  }, {
    "tStartMs": 283520,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "My parents were busy."
    } ]
  }, {
    "tStartMs": 284960,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "They were always at work,\nbut I got a laptop computer,"
    } ]
  }, {
    "tStartMs": 288440,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "and I got fibre Internet\nat a very young age"
    } ]
  }, {
    "tStartMs": 290960,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "because the infrastructure\nwas pretty well developed in Sweden."
    } ]
  }, {
    "tStartMs": 295520,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "-At 12, you had...\n-Fibre."
    } ]
  }, {
    "tStartMs": 297920,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "-And phone, access to phone.\n-I had a Nokia 3210."
    } ]
  }, {
    "tStartMs": 302320,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "-At 12 years old.\n-Yeah."
    } ]
  }, {
    "tStartMs": 304880,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "So then fast forward to later,\nso I had the Internet."
    } ]
  }, {
    "tStartMs": 307840,
    "dDurationMs": 4920,
    "segs": [ {
      "utf8": "Started making friends online\n'cause I felt like the friends around me,"
    } ]
  }, {
    "tStartMs": 312840,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "they only saw a very small part\nof the world."
    } ]
  }, {
    "tStartMs": 315040,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "Whereas online,\nyou can connect with anybody."
    } ]
  }, {
    "tStartMs": 318640,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "So I made a very good friend."
    } ]
  }, {
    "tStartMs": 320840,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "We were chatting on MSN Messenger\nevery single day"
    } ]
  }, {
    "tStartMs": 323720,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "about how to make money online."
    } ]
  }, {
    "tStartMs": 326280,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "We were both writing blogs\nand making websites and all that stuff."
    } ]
  }, {
    "tStartMs": 330840,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "And then, he then became\nthe youngest founder"
    } ]
  }, {
    "tStartMs": 334080,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "to get into Y Combinator."
    } ]
  }, {
    "tStartMs": 336000,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And he's, like, two years younger than me."
    } ]
  }, {
    "tStartMs": 338000,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "-Wow.\n-I was very jealous when he got in."
    } ]
  }, {
    "tStartMs": 340720,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "He was probably 17 or something."
    } ]
  }, {
    "tStartMs": 343440,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "And so that was also my plan."
    } ]
  }, {
    "tStartMs": 345160,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So after uni,\nI'm going to apply for Y Combinator."
    } ]
  }, {
    "tStartMs": 348000,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "So it was a different time,\nwhen consumer Internet"
    } ]
  }, {
    "tStartMs": 350080,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "was still very, like, booming\nwith Facebook and all that."
    } ]
  }, {
    "tStartMs": 353520,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "What's really working for Y Combinator?"
    } ]
  }, {
    "tStartMs": 356400,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "We're trying to start something like that\ncalled WTFund,"
    } ]
  }, {
    "tStartMs": 359320,
    "dDurationMs": 5520,
    "segs": [ {
      "utf8": "which is a non-dilutive grant programme\nwhere we don't take equities."
    } ]
  }, {
    "tStartMs": 364920,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "It's not too much like Y Combinator,\nbut a different version of it."
    } ]
  }, {
    "tStartMs": 370200,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Why have they been so successful?"
    } ]
  }, {
    "tStartMs": 372960,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "I don't know. I haven't thought about it."
    } ]
  }, {
    "tStartMs": 374240,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "When I was young,\nI just wanted to go there,"
    } ]
  }, {
    "tStartMs": 376560,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "because I thought that was the place\nyou had to go"
    } ]
  }, {
    "tStartMs": 379480,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "if you wanted to become\na Silicon Valley founder."
    } ]
  }, {
    "tStartMs": 385160,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "They made a lot of... They've been\na kingmaker in the industry, I think."
    } ]
  }, {
    "tStartMs": 388920,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "I'm sure they have some\nunique way of figuring out"
    } ]
  }, {
    "tStartMs": 392360,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "who's a good fit in terms of founders."
    } ]
  }, {
    "tStartMs": 395000,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "And then they have their brand."
    } ]
  }, {
    "tStartMs": 396880,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "And then they prepare\nthe founders for, like..."
    } ]
  }, {
    "tStartMs": 400280,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "the subsequent funding rounds\nin a pretty smart way."
    } ]
  }, {
    "tStartMs": 403560,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Like, even when I'm raising money,"
    } ]
  }, {
    "tStartMs": 405800,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "sometimes, I reference\nthe Y Combinator docs,"
    } ]
  }, {
    "tStartMs": 409440,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "like, the guides for how to raise money."
    } ]
  }, {
    "tStartMs": 412080,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Do you think it's network\nor access to capital?"
    } ]
  }, {
    "tStartMs": 415160,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "The capital is very little, actually."
    } ]
  }, {
    "tStartMs": 417320,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "-Half a million.\n-Yeah. It was even less before."
    } ]
  }, {
    "tStartMs": 420240,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "And they take a lot of stake\nfor that money."
    } ]
  }, {
    "tStartMs": 423960,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "But I think it's a branding thing."
    } ]
  }, {
    "tStartMs": 425320,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "Like, once you have that brand\non your resume,"
    } ]
  }, {
    "tStartMs": 428680,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "your next round will be a lot easier."
    } ]
  }, {
    "tStartMs": 430360,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "And your next, next round\nwill be a lot easier."
    } ]
  }, {
    "tStartMs": 432760,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "And they do have good content to teach."
    } ]
  }, {
    "tStartMs": 434920,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Maybe that's their user acquisition.\nRight?"
    } ]
  }, {
    "tStartMs": 437760,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "Having good content to teach young people\nwhy you should start a company,"
    } ]
  }, {
    "tStartMs": 442280,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "how you should start a company."
    } ]
  }, {
    "tStartMs": 443600,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "And then once they're ready,\nthey inbound to YC."
    } ]
  }, {
    "tStartMs": 447760,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Okay. And then?"
    } ]
  }, {
    "tStartMs": 449360,
    "dDurationMs": 5440,
    "segs": [ {
      "utf8": "So I was planning to go to YC,\nand then I was playing a lot of games."
    } ]
  }, {
    "tStartMs": 455440,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "A lot of League of Legends at that time."
    } ]
  }, {
    "tStartMs": 458240,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "-It wasn't very...\n-Games as in, like, video games?"
    } ]
  }, {
    "tStartMs": 460840,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "-Yeah, like online computer games.\n-Online games."
    } ]
  }, {
    "tStartMs": 465040,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "So I was a bit lazy,\nso I didn't write my application."
    } ]
  }, {
    "tStartMs": 467880,
    "dDurationMs": 5320,
    "segs": [ {
      "utf8": "But then I got a phone call from the CEO\nof Meizu back then."
    } ]
  }, {
    "tStartMs": 473840,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "He's like, \"Hey,\nwe want to become more international."
    } ]
  }, {
    "tStartMs": 477720,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Do you want to help?\""
    } ]
  }, {
    "tStartMs": 479280,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "So I had like two options."
    } ]
  }, {
    "tStartMs": 480400,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Either I have to write\nmy application for YC,"
    } ]
  }, {
    "tStartMs": 482840,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "or I can go to China to join Meizu."
    } ]
  }, {
    "tStartMs": 485480,
    "dDurationMs": 6400,
    "segs": [ {
      "utf8": "I took the path of least resistance\nand didn't finish my university."
    } ]
  }, {
    "tStartMs": 491960,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "I moved to Hong Kong in 2011."
    } ]
  }, {
    "tStartMs": 495960,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "-For Meizu?\n-For Meizu."
    } ]
  }, {
    "tStartMs": 497360,
    "dDurationMs": 6160,
    "segs": [ {
      "utf8": "Just for the...\nMeizu was the Apple of China at that time."
    } ]
  }, {
    "tStartMs": 503600,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "They were the first one\nto come up with a phone. Yeah."
    } ]
  }, {
    "tStartMs": 506200,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "-The first Chinese smartphone.\n-Yes, it was Meizu."
    } ]
  }, {
    "tStartMs": 509480,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "They made really great MP3 players before.\nThat's when I got to know the company."
    } ]
  }, {
    "tStartMs": 517560,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "And then, yeah, to be a part\nof the beginning of something interesting,"
    } ]
  }, {
    "tStartMs": 520760,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "that's why I moved."
    } ]
  }, {
    "tStartMs": 522640,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And also out of laziness,"
    } ]
  }, {
    "tStartMs": 524400,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "to not have to write the thesis\nfor university"
    } ]
  }, {
    "tStartMs": 526840,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "and the application for YC."
    } ]
  }, {
    "tStartMs": 529040,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "And the reason why he reached out to me\nwas because,"
    } ]
  }, {
    "tStartMs": 532000,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "after I discovered their products in 2006,"
    } ]
  }, {
    "tStartMs": 535800,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "I made an online fan community\nabout that company."
    } ]
  }, {
    "tStartMs": 538960,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "And it got quite big."
    } ]
  }, {
    "tStartMs": 540600,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "We got to like 70,000 users, members."
    } ]
  }, {
    "tStartMs": 544040,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "We were updating, like, people"
    } ]
  }, {
    "tStartMs": 545600,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "on the new firmware updates\nand customisation, and all that stuff."
    } ]
  }, {
    "tStartMs": 550280,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "And then I think he saw something in that\nand decided to call."
    } ]
  }, {
    "tStartMs": 554200,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "So the founder of Meizu\ncalled you himself?"
    } ]
  }, {
    "tStartMs": 556480,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "-The CEO.\n-Yeah?"
    } ]
  }, {
    "tStartMs": 558200,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "-The professional CEO.\n-Wow."
    } ]
  }, {
    "tStartMs": 561080,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Okay. And you were in Nokia\nfor three months?"
    } ]
  }, {
    "tStartMs": 563320,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "Yeah, that was before that.\nJust for like a summer internship."
    } ]
  }, {
    "tStartMs": 566560,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Right. And after Meizu?"
    } ]
  }, {
    "tStartMs": 569600,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "So I didn't stay that long."
    } ]
  }, {
    "tStartMs": 572200,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "I think I stayed, like, a year."
    } ]
  }, {
    "tStartMs": 574800,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "I left because I quickly realised\nthat it was a family business."
    } ]
  }, {
    "tStartMs": 578560,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "So the key positions\nwere all family members."
    } ]
  }, {
    "tStartMs": 580800,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "And it's hard to build a very big company\nlike that, I think."
    } ]
  }, {
    "tStartMs": 585640,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "Was the professional CEO a family member?"
    } ]
  }, {
    "tStartMs": 588520,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "He wasn't."
    } ]
  }, {
    "tStartMs": 589920,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "But imagine how hard it was for him\nto do his work."
    } ]
  }, {
    "tStartMs": 593800,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "But head of finance,\nhead of international."
    } ]
  }, {
    "tStartMs": 597520,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "It's probably not gonna work."
    } ]
  }, {
    "tStartMs": 598600,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "So I started applying for jobs."
    } ]
  }, {
    "tStartMs": 601360,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "I applied for Xiaomi."
    } ]
  }, {
    "tStartMs": 603120,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "I applied for OPPO."
    } ]
  }, {
    "tStartMs": 606760,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "I applied for another company\nthat's no longer here, called Smartisan."
    } ]
  }, {
    "tStartMs": 611240,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yeah, yeah."
    } ]
  }, {
    "tStartMs": 613680,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Smartisan had that... They had that..."
    } ]
  }, {
    "tStartMs": 615240,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "This is a Bangalore-based startup, right?"
    } ]
  }, {
    "tStartMs": 617200,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "No, no, no. This is based out of Beijing."
    } ]
  }, {
    "tStartMs": 621320,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Yeah, back in the day."
    } ]
  }, {
    "tStartMs": 623840,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "With their Hammer UI and all that."
    } ]
  }, {
    "tStartMs": 625640,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "-Is it?\n-Mm-hmm."
    } ]
  }, {
    "tStartMs": 626840,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 627920,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "-Yeah, they did some good design.\n-[Rahul] Yeah."
    } ]
  }, {
    "tStartMs": 630160,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "The Smartisan guy never responded to me."
    } ]
  }, {
    "tStartMs": 633120,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "I interviewed at Xiaomi and OPPO."
    } ]
  }, {
    "tStartMs": 635760,
    "dDurationMs": 5560,
    "segs": [ {
      "utf8": "And to be honest, I think back then,\nXiaomi was a rocket ship."
    } ]
  }, {
    "tStartMs": 641400,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Like, venture-backed."
    } ]
  }, {
    "tStartMs": 642760,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "I think Sequoia and a bunch of\nreally well-known VCs were backing them."
    } ]
  }, {
    "tStartMs": 648040,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "-DST and all of them. Yeah.\n-DST."
    } ]
  }, {
    "tStartMs": 650000,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "So I was actually quite intimidated\nby the people I met there."
    } ]
  }, {
    "tStartMs": 654320,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "Like, everybody that interviewed with me\nat Xiaomi felt very aggressive,"
    } ]
  }, {
    "tStartMs": 658440,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "like, results-oriented, very smart."
    } ]
  }, {
    "tStartMs": 661480,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Whereas when I interviewed with OPPO,"
    } ]
  }, {
    "tStartMs": 663440,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "I felt more like a traditional\nmanufacturing culture."
    } ]
  }, {
    "tStartMs": 668000,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "So selfishly,\nI thought that if I joined this"
    } ]
  }, {
    "tStartMs": 671200,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "less aggressive culture, I can shine more."
    } ]
  }, {
    "tStartMs": 673840,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Did you get a job at Xiaomi as well?"
    } ]
  }, {
    "tStartMs": 676200,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "I dropped out of the interview process"
    } ]
  }, {
    "tStartMs": 678440,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "after we made an agreement\nwith OPPO at that time."
    } ]
  }, {
    "tStartMs": 682240,
    "dDurationMs": 4760,
    "segs": [ {
      "utf8": "Yeah, so then OPPO also saw\nthe rise of Xiaomi."
    } ]
  }, {
    "tStartMs": 687640,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "Because Xiaomi was selling phones online,"
    } ]
  }, {
    "tStartMs": 689280,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "they were the first\nto do that in the world."
    } ]
  }, {
    "tStartMs": 691160,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "And they could undercut other people"
    } ]
  }, {
    "tStartMs": 693640,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "because the distribution cost\nwas a lot lower."
    } ]
  }, {
    "tStartMs": 696160,
    "dDurationMs": 6400,
    "segs": [ {
      "utf8": "So OPPO was also trying to find a strategy\nto hedge against the rise of Xiaomi."
    } ]
  }, {
    "tStartMs": 703520,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "So they created a new brand\ncalled OnePlus."
    } ]
  }, {
    "tStartMs": 706640,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "It was supposed to be online,"
    } ]
  }, {
    "tStartMs": 708640,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "by leveraging the supply chain\nthat OPPO had built."
    } ]
  }, {
    "tStartMs": 711240,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "Because Xiaomi was\nstill building their supply chain,"
    } ]
  }, {
    "tStartMs": 713080,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "they didn't have those advantages."
    } ]
  }, {
    "tStartMs": 714320,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Is OnePlus still a part of OPPO?"
    } ]
  }, {
    "tStartMs": 716400,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Yeah, yeah, yeah."
    } ]
  }, {
    "tStartMs": 718960,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "So then, I had just joined."
    } ]
  }, {
    "tStartMs": 722240,
    "dDurationMs": 5520,
    "segs": [ {
      "utf8": "And I was like, \"Hey, I can't just join\nand then you start a new company."
    } ]
  }, {
    "tStartMs": 727840,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Like, I want to be a part\nof the new company.\""
    } ]
  }, {
    "tStartMs": 730200,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "But then I was told that the new company\nis not for international,"
    } ]
  }, {
    "tStartMs": 733320,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "it's just for China."
    } ]
  }, {
    "tStartMs": 735880,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "To fight Xiaomi in China."
    } ]
  }, {
    "tStartMs": 737840,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "But I kind of made the case\nthat it doesn't hurt, right?"
    } ]
  }, {
    "tStartMs": 740960,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "Like, if I can run international,\nit's all free money."
    } ]
  }, {
    "tStartMs": 745320,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "Like, you guys can still focus on China,"
    } ]
  }, {
    "tStartMs": 748320,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "and everything else is just extra\non top of that."
    } ]
  }, {
    "tStartMs": 750720,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "So that's how I, in the beginning,\ngot the opportunity."
    } ]
  }, {
    "tStartMs": 754600,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "I was only 24 to run international."
    } ]
  }, {
    "tStartMs": 758880,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Were you more a marketing person\nat this point"
    } ]
  }, {
    "tStartMs": 761400,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "or were you more\nthe technical person at this point?"
    } ]
  }, {
    "tStartMs": 763760,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "I was more marketing, I think."
    } ]
  }, {
    "tStartMs": 766520,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "I was kind of like a..."
    } ]
  }, {
    "tStartMs": 768320,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "'Cause ever since I was 12\nwhen I got that computer,"
    } ]
  }, {
    "tStartMs": 770280,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "I started making websites."
    } ]
  }, {
    "tStartMs": 771600,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "And then I built traffic,\nsold advertising."
    } ]
  }, {
    "tStartMs": 774080,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "So like just..."
    } ]
  }, {
    "tStartMs": 775840,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "I had a deep desire to make money\nwhen I was young."
    } ]
  }, {
    "tStartMs": 778160,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "So more like business/marketing,\njust trying to make it work, hustling."
    } ]
  }, {
    "tStartMs": 783880,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "So that's kind of what we did."
    } ]
  }, {
    "tStartMs": 785880,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "After one year,\nafter launching the product at OnePlus,"
    } ]
  }, {
    "tStartMs": 790560,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "China did $100 million in revenue."
    } ]
  }, {
    "tStartMs": 792480,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "International did $200 million."
    } ]
  }, {
    "tStartMs": 794560,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "China lost money,\ninternational made money."
    } ]
  }, {
    "tStartMs": 796920,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "And then we decided to pivot\nthe entire company"
    } ]
  }, {
    "tStartMs": 798880,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "to be more focused on international."
    } ]
  }, {
    "tStartMs": 801400,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "'Cause the competition in China\nwas too high."
    } ]
  }, {
    "tStartMs": 803880,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "-Yeah.\n-So that was the OnePlus journey."
    } ]
  }, {
    "tStartMs": 807480,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "Spent seven years at OnePlus."
    } ]
  }, {
    "tStartMs": 812560,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Very grateful because I was just a kid."
    } ]
  }, {
    "tStartMs": 814360,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "Like, being able to participate\nin such a high CapEx industry"
    } ]
  }, {
    "tStartMs": 819240,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "without needing to use my own money."
    } ]
  }, {
    "tStartMs": 822120,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "I didn't have money."
    } ]
  }, {
    "tStartMs": 824240,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "So, very grateful\nfor all those opportunities."
    } ]
  }, {
    "tStartMs": 826280,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Allowing me to fail\nwith a lot of crazy ideas"
    } ]
  }, {
    "tStartMs": 828440,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "and learning from those."
    } ]
  }, {
    "tStartMs": 830800,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Ultimately, it's kind\nof like a CPG strategy"
    } ]
  }, {
    "tStartMs": 833640,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "where we buy components\nfrom different suppliers,"
    } ]
  }, {
    "tStartMs": 836840,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "we package the components,"
    } ]
  }, {
    "tStartMs": 838760,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "and we have a unique position\nin the market,"
    } ]
  }, {
    "tStartMs": 841240,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "design, brand, and sell the product."
    } ]
  }, {
    "tStartMs": 845040,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "I had done that for seven years."
    } ]
  }, {
    "tStartMs": 846360,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "I didn't feel like\nthat's what I wanted to do my entire life."
    } ]
  }, {
    "tStartMs": 851560,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "I want to not only implement\nother people's technology,"
    } ]
  }, {
    "tStartMs": 855720,
    "dDurationMs": 6160,
    "segs": [ {
      "utf8": "I also want the opportunity to eventually\nimpact how people use technology."
    } ]
  }, {
    "tStartMs": 861960,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "So I knew I had to go independent."
    } ]
  }, {
    "tStartMs": 866040,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "So I left in 2020, in September."
    } ]
  }, {
    "tStartMs": 869440,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "And on my birthday,\nthat was like a birthday gift for myself."
    } ]
  }, {
    "tStartMs": 874280,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "And started this new company\ncalled Nothing."
    } ]
  }, {
    "tStartMs": 878320,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "It's been four and a half years."
    } ]
  }, {
    "tStartMs": 880320,
    "dDurationMs": 5240,
    "segs": [ {
      "utf8": "We underestimated the difficulty\nin building this, but we're still around."
    } ]
  }, {
    "tStartMs": 885640,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "So, very grateful to still have\nopportunities to build a company."
    } ]
  }, {
    "tStartMs": 891760,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "But it was a bit tougher than we expected."
    } ]
  }, {
    "tStartMs": 895280,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Are you branding your phone\nby keeping it there?"
    } ]
  }, {
    "tStartMs": 897720,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "Yeah, it's free exposure. [chuckles]"
    } ]
  }, {
    "tStartMs": 901560,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "It has a very distinctive back, right?"
    } ]
  }, {
    "tStartMs": 903600,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Yeah, so that's our entire thing."
    } ]
  }, {
    "tStartMs": 905840,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "We..."
    } ]
  }, {
    "tStartMs": 907280,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "It's a very mature industry,"
    } ]
  }, {
    "tStartMs": 910120,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "and it's very hard to compete\nbecause everybody is at very high scale."
    } ]
  }, {
    "tStartMs": 914480,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "So they have a lot of advantages."
    } ]
  }, {
    "tStartMs": 917560,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "We're not reinventing the category."
    } ]
  }, {
    "tStartMs": 919640,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "It was invented a long time ago\nby somebody else."
    } ]
  }, {
    "tStartMs": 922680,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "So, for us, it's all about carving out\na small position in the market first."
    } ]
  }, {
    "tStartMs": 927640,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "We don't have to have everybody love us."
    } ]
  }, {
    "tStartMs": 930480,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "It's okay if 90% of people don't care\nabout us or hate us"
    } ]
  }, {
    "tStartMs": 934480,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "as long as we get a niche group\nof consumers who really love us."
    } ]
  }, {
    "tStartMs": 940000,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "That works in our industry\nbecause it's so big."
    } ]
  }, {
    "tStartMs": 943000,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Maybe it doesn't work\nfor smaller categories."
    } ]
  }, {
    "tStartMs": 945600,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "So, for us, we chose to differentiate\nthrough design"
    } ]
  }, {
    "tStartMs": 949120,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "because it was the fastest way\nto differentiate."
    } ]
  }, {
    "tStartMs": 952000,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "If we picked technology,\nit would take years to play out."
    } ]
  }, {
    "tStartMs": 955960,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "It's a lot of investment, a lot of years."
    } ]
  }, {
    "tStartMs": 959640,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "We also didn't want to reinvent\nthe product category."
    } ]
  }, {
    "tStartMs": 962360,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "Like, if we have crazy ideas\non a new gadget,"
    } ]
  }, {
    "tStartMs": 966560,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "we might spend years\non trying to build it."
    } ]
  }, {
    "tStartMs": 968920,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "And then if we launch it,\nyou only have one chance."
    } ]
  }, {
    "tStartMs": 971760,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "If people don't like it, you're screwed."
    } ]
  }, {
    "tStartMs": 973880,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "Yeah, so we start with hardware design,\nthen we move to software design."
    } ]
  }, {
    "tStartMs": 978040,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "Now we're investing more and more\ninto the OS itself, into AI."
    } ]
  }, {
    "tStartMs": 982800,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "So I think, for us, it's about building\ndifferentiation and modes over time."
    } ]
  }, {
    "tStartMs": 987320,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "But in a gradual way."
    } ]
  }, {
    "tStartMs": 988640,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "Don't move too fast because then\nyou might, kind of, fall off the horse."
    } ]
  }, {
    "tStartMs": 992360,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "So, for a company\nheadquartered in Sweden..."
    } ]
  }, {
    "tStartMs": 996640,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "-UK.\n-UK."
    } ]
  }, {
    "tStartMs": 999320,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "The trade war will affect you how?"
    } ]
  }, {
    "tStartMs": 1001240,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Tariffs?"
    } ]
  }, {
    "tStartMs": 1002480,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "So, now, the most direct way is..."
    } ]
  }, {
    "tStartMs": 1006760,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "Trump had new tariffs\nfor manufacturing from China."
    } ]
  }, {
    "tStartMs": 1010320,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "So we manufacture the earbuds in China."
    } ]
  }, {
    "tStartMs": 1013520,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "And that's like a 20% hit on our..."
    } ]
  }, {
    "tStartMs": 1017880,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "-[Amit] Import.\n-...business plans for the US market."
    } ]
  }, {
    "tStartMs": 1020880,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "So now we need to look\nat alternative sources of manufacturing"
    } ]
  }, {
    "tStartMs": 1024360,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "like India, like Vietnam,"
    } ]
  }, {
    "tStartMs": 1025840,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "where it makes the most sense."
    } ]
  }, {
    "tStartMs": 1028280,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "It's the first time where, you know,\nevery night, 10pm, I go on CNN.com."
    } ]
  }, {
    "tStartMs": 1033080,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "See. He must have woken up."
    } ]
  }, {
    "tStartMs": 1035440,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "What is the new news?"
    } ]
  }, {
    "tStartMs": 1036760,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "And then go to sleep."
    } ]
  }, {
    "tStartMs": 1038280,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "But it won't affect you as much\nif you're getting stuff from China"
    } ]
  }, {
    "tStartMs": 1041400,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "and selling in India, right?"
    } ]
  }, {
    "tStartMs": 1043280,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "No, it's not about that getting from..."
    } ]
  }, {
    "tStartMs": 1045640,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "See, because the supply chain right now\nis there in China."
    } ]
  }, {
    "tStartMs": 1048600,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "And then all the manufacturing now\nis coming to India."
    } ]
  }, {
    "tStartMs": 1052480,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "But it's not about China,\nit's about India also."
    } ]
  }, {
    "tStartMs": 1055880,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "Because, you know, reciprocal tariffs\nand all those sort of things."
    } ]
  }, {
    "tStartMs": 1059280,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "But I would assume it would hurt you most\nif you're selling something in the US."
    } ]
  }, {
    "tStartMs": 1063960,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "Certainly, yes."
    } ]
  }, {
    "tStartMs": 1065600,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "But now we're talking about\nthe whole industry, you know, per se."
    } ]
  }, {
    "tStartMs": 1068200,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "So, you know,\nif you see the reciprocal tariff,"
    } ]
  }, {
    "tStartMs": 1071600,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "even on mobile phones."
    } ]
  }, {
    "tStartMs": 1073800,
    "dDurationMs": 4880,
    "segs": [ {
      "utf8": "It's, you know, it's 16.5%."
    } ]
  }, {
    "tStartMs": 1079640,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Right?"
    } ]
  }, {
    "tStartMs": 1080720,
    "dDurationMs": 4480,
    "segs": [ {
      "utf8": "So if anything coming into India,\nthere is a duty of 16.5%."
    } ]
  }, {
    "tStartMs": 1085280,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "Going to US as of now is 0%."
    } ]
  }, {
    "tStartMs": 1088200,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So reciprocal means..."
    } ]
  }, {
    "tStartMs": 1090120,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "At some level, doesn't it sound fair?"
    } ]
  }, {
    "tStartMs": 1092760,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "Like, I'm just...\nI have no affinity to America."
    } ]
  }, {
    "tStartMs": 1097080,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "And I'm the biggest proponent\nof India built for India,"
    } ]
  }, {
    "tStartMs": 1100640,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "supporting Indian product."
    } ]
  }, {
    "tStartMs": 1103120,
    "dDurationMs": 5120,
    "segs": [ {
      "utf8": "But, if tomorrow\nI was selling to country X, Y, Z."
    } ]
  }, {
    "tStartMs": 1108320,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "And I was selling them something\nand they were charging me 30% duty on it,"
    } ]
  }, {
    "tStartMs": 1113960,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "if I was buying something from them,"
    } ]
  }, {
    "tStartMs": 1117880,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "I would assume the same duty should apply."
    } ]
  }, {
    "tStartMs": 1120200,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Yeah, I think so."
    } ]
  }, {
    "tStartMs": 1121960,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Like, inherently, it's logical, no?"
    } ]
  }, {
    "tStartMs": 1123920,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "-Yeah, but I have a different view.\n-Yeah."
    } ]
  }, {
    "tStartMs": 1125840,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "See, it's not binary.\nIt's not, you know-- It depends:"
    } ]
  }, {
    "tStartMs": 1129480,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "How do you want to bring up your country?\nWhat are your policies, for example?"
    } ]
  }, {
    "tStartMs": 1133360,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "We've been discussing about China a lot."
    } ]
  }, {
    "tStartMs": 1136320,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "In China, way back, they decided"
    } ]
  }, {
    "tStartMs": 1138440,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "that they are not going to allow\nthe foreign companies."
    } ]
  }, {
    "tStartMs": 1140480,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Foreign companies can only come with JVs"
    } ]
  }, {
    "tStartMs": 1142400,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "because they want to build\ntheir champions."
    } ]
  }, {
    "tStartMs": 1146560,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "But then, how can they do that,"
    } ]
  }, {
    "tStartMs": 1149840,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "+but sell to other countries\nat the scale that they are selling"
    } ]
  }, {
    "tStartMs": 1153920,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "and creating these deficits?"
    } ]
  }, {
    "tStartMs": 1155360,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "No, but they created that scale, right?"
    } ]
  }, {
    "tStartMs": 1157840,
    "dDurationMs": 5400,
    "segs": [ {
      "utf8": "So, see, if you see examples\nhow great countries are built."
    } ]
  }, {
    "tStartMs": 1164240,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "It's all about the companies\nthat, you know..."
    } ]
  }, {
    "tStartMs": 1168520,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "If you have great companies,\nthe country will prosper."
    } ]
  }, {
    "tStartMs": 1171560,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "And the United States\nis the biggest example."
    } ]
  }, {
    "tStartMs": 1175440,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "Same thing, you know,\nChina worked on that way back."
    } ]
  }, {
    "tStartMs": 1178720,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "And so, if Mercedes-Benz\nhave to, you know..."
    } ]
  }, {
    "tStartMs": 1184480,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "they want to sell and they say,\n\"Do a joint venture with our company.\""
    } ]
  }, {
    "tStartMs": 1188080,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "Everyone, Hyundai, or...\nall of them in the automobile."
    } ]
  }, {
    "tStartMs": 1192040,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "Softwares... Never allowed Google,\nMicrosoft, you know, all those players."
    } ]
  }, {
    "tStartMs": 1196560,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "They build their own companies,\nand they..."
    } ]
  }, {
    "tStartMs": 1199280,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "We all know about that."
    } ]
  }, {
    "tStartMs": 1202400,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "So, if it was like what we are discussing"
    } ]
  }, {
    "tStartMs": 1204920,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "that yes, sitting across the table,\nokay, if you do this, I do this."
    } ]
  }, {
    "tStartMs": 1207800,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Then all these things-- Then Google\nwould have been there probably..."
    } ]
  }, {
    "tStartMs": 1210640,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Or Amazon would have been there."
    } ]
  }, {
    "tStartMs": 1212200,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "I don't think so whether\nthey will be having an Alibaba or not"
    } ]
  }, {
    "tStartMs": 1214680,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "or whether there was this Baidu,"
    } ]
  }, {
    "tStartMs": 1216800,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "you know, all those players\nwould have been existing or not."
    } ]
  }, {
    "tStartMs": 1219480,
    "dDurationMs": 6520,
    "segs": [ {
      "utf8": "But I'm making the presumption\nthat classical economic theory suggests"
    } ]
  }, {
    "tStartMs": 1226080,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "that free markets are the fastest way"
    } ]
  }, {
    "tStartMs": 1230720,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "to improve quality and get competitive."
    } ]
  }, {
    "tStartMs": 1233320,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "Like, I do see your point."
    } ]
  }, {
    "tStartMs": 1234960,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "I remember reading somewhere in history"
    } ]
  }, {
    "tStartMs": 1238200,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "that back in the day\nwhen UK was not doing well,"
    } ]
  }, {
    "tStartMs": 1241200,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "they shut off from the world,"
    } ]
  }, {
    "tStartMs": 1243320,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "isolated their domestic industry\npre-industrial revolution"
    } ]
  }, {
    "tStartMs": 1247320,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "and they didn't allow foreign products\nfor a while"
    } ]
  }, {
    "tStartMs": 1250120,
    "dDurationMs": 5400,
    "segs": [ {
      "utf8": "to help their internal industry to grow\nto a point where it can be competitive."
    } ]
  }, {
    "tStartMs": 1255600,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "So maybe there's a point to that."
    } ]
  }, {
    "tStartMs": 1257880,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "But when I look at it very simplistically,"
    } ]
  }, {
    "tStartMs": 1260480,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "if Nikhil is selling something\nand Rahul is selling something,"
    } ]
  }, {
    "tStartMs": 1265800,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "if each time Rahul is selling something,"
    } ]
  }, {
    "tStartMs": 1268600,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "there is a certain additional tax"
    } ]
  }, {
    "tStartMs": 1270680,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "outside of the cost of growth produced\nin Rahul's margin,"
    } ]
  }, {
    "tStartMs": 1274480,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "the same should apply to Nikhil as well."
    } ]
  }, {
    "tStartMs": 1276200,
    "dDurationMs": 4520,
    "segs": [ {
      "utf8": "Certainly. So as I said, likewise,\nit sounds very, it's simple, it's logical."
    } ]
  }, {
    "tStartMs": 1280800,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "But, you know,\nwhen you're building your countries,"
    } ]
  }, {
    "tStartMs": 1284480,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "you know, the whole narrative\nchanges in that."
    } ]
  }, {
    "tStartMs": 1286320,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "And that's how all these FTA treaties\nare being worked out."
    } ]
  }, {
    "tStartMs": 1289720,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "-[Nikhil] Yeah.\n-Yeah."
    } ]
  }, {
    "tStartMs": 1290840,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "They've supported the ecosystem also\nin a big way,"
    } ]
  }, {
    "tStartMs": 1293680,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "if you look at all Chinese companies."
    } ]
  }, {
    "tStartMs": 1295640,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "I mean, all, like-- You're talking about\nInternet companies,"
    } ]
  }, {
    "tStartMs": 1298840,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "they never allowed US companies\nto come in."
    } ]
  }, {
    "tStartMs": 1301680,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "In fact, there is no Uber also there."
    } ]
  }, {
    "tStartMs": 1303880,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "Amazon also had to sell out\ntheir business there."
    } ]
  }, {
    "tStartMs": 1306480,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "I mean, somehow\nthey're protected for the Indian--"
    } ]
  }, {
    "tStartMs": 1308720,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "their Chinese companies to grow, actually."
    } ]
  }, {
    "tStartMs": 1311040,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "That's how, I mean,\nthat's how their whole strategy,"
    } ]
  }, {
    "tStartMs": 1313440,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "you know, has been worked out."
    } ]
  }, {
    "tStartMs": 1314920,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "So, today, we talk\nabout semiconductors here."
    } ]
  }, {
    "tStartMs": 1317160,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "They started working\non semiconductors 20 years back."
    } ]
  }, {
    "tStartMs": 1319240,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "-[Carl] Yeah.\n-And now the results are coming."
    } ]
  }, {
    "tStartMs": 1321520,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "They're like 3,200 companies\nworking on semiconductors."
    } ]
  }, {
    "tStartMs": 1325560,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "Most patents are being filed there. So..."
    } ]
  }, {
    "tStartMs": 1329840,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "Carl, can I ask you another question?"
    } ]
  }, {
    "tStartMs": 1331960,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Mm-hmm."
    } ]
  }, {
    "tStartMs": 1333880,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "For a kid who moved from China to the US"
    } ]
  }, {
    "tStartMs": 1337360,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "with two PhD parents,"
    } ]
  }, {
    "tStartMs": 1340320,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "and a deep desire to make money\nwhile young,"
    } ]
  }, {
    "tStartMs": 1343000,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "where does that come from?"
    } ]
  }, {
    "tStartMs": 1344920,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "I'm sure there's some childhood trauma,"
    } ]
  }, {
    "tStartMs": 1347560,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "but I've never explored that path\nto understand more."
    } ]
  }, {
    "tStartMs": 1350000,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "What do you suspect it could be?"
    } ]
  }, {
    "tStartMs": 1352520,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "I think just being... not fitting in,"
    } ]
  }, {
    "tStartMs": 1355600,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "the feeling of not fitting in,\nyou know, like..."
    } ]
  }, {
    "tStartMs": 1357800,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "But you're a young, good-looking guy.\nWhy not fitting in?"
    } ]
  }, {
    "tStartMs": 1360200,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "'Cause I grew up in white societies\nas a minority."
    } ]
  }, {
    "tStartMs": 1364480,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Racist? Back then?"
    } ]
  }, {
    "tStartMs": 1366240,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "I think it's not, like, explicitly racist,"
    } ]
  }, {
    "tStartMs": 1370920,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "but it's like, you're just\nnot the same, right?"
    } ]
  }, {
    "tStartMs": 1374360,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Like, I could tell."
    } ]
  }, {
    "tStartMs": 1376560,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "I think there's something to do with that."
    } ]
  }, {
    "tStartMs": 1378680,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "US more so or Sweden?"
    } ]
  }, {
    "tStartMs": 1381720,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "-I think both.\n-Is that all?"
    } ]
  }, {
    "tStartMs": 1385520,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Childhood?"
    } ]
  }, {
    "tStartMs": 1386600,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "I think childhood trauma\nis a big part of it,"
    } ]
  }, {
    "tStartMs": 1388800,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "but I haven't gone to a therapist\nto unpack all of that."
    } ]
  }, {
    "tStartMs": 1393480,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "There's also, I think, a fear of death."
    } ]
  }, {
    "tStartMs": 1397520,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "You know, I remember\nwhen I was very young,"
    } ]
  }, {
    "tStartMs": 1401080,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "I was very angry at my parents\nfor giving birth to me."
    } ]
  }, {
    "tStartMs": 1405480,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Because now I have to die,\nand that's terrible."
    } ]
  }, {
    "tStartMs": 1407960,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "\"Why did you do this?\""
    } ]
  }, {
    "tStartMs": 1409320,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "-This is at what age?\n-Eight, I think."
    } ]
  }, {
    "tStartMs": 1411880,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "So there's like this fear."
    } ]
  }, {
    "tStartMs": 1414040,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "And my best answer is, like,\nthis is going to be a journey."
    } ]
  }, {
    "tStartMs": 1419160,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Life is a journey."
    } ]
  }, {
    "tStartMs": 1420920,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "I got the conclusion\nfrom the movie Life of Pi."
    } ]
  }, {
    "tStartMs": 1423680,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "[Rahul] Mm-hmm."
    } ]
  }, {
    "tStartMs": 1424960,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "The kid is on a boat,\nmeets a lot of animals,"
    } ]
  }, {
    "tStartMs": 1427880,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "but actually it didn't happen."
    } ]
  }, {
    "tStartMs": 1430160,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "Just made it up\nto make the journey more pleasant."
    } ]
  }, {
    "tStartMs": 1435560,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "So it's all about the journey,\nand I think by doing something ambitious,"
    } ]
  }, {
    "tStartMs": 1439080,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "doing something different,\nthe journey will be a lot more fun."
    } ]
  }, {
    "tStartMs": 1442080,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So that's also a driver, I think."
    } ]
  }, {
    "tStartMs": 1444440,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Do you feel like nothing has meaning?"
    } ]
  }, {
    "tStartMs": 1446320,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "Are you nihilistic,\nstoic in your thinking?"
    } ]
  }, {
    "tStartMs": 1449200,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "I think the journey has meaning,"
    } ]
  }, {
    "tStartMs": 1451200,
    "dDurationMs": 4840,
    "segs": [ {
      "utf8": "but I don't think\nthere's much beyond death."
    } ]
  }, {
    "tStartMs": 1456120,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Well, thank you."
    } ]
  }, {
    "tStartMs": 1458240,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Rahul, would you like to go next?"
    } ]
  }, {
    "tStartMs": 1462080,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Tell us about your life."
    } ]
  }, {
    "tStartMs": 1463520,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "Start from the beginning, from Delhi."
    } ]
  }, {
    "tStartMs": 1466240,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "-You know...\n-I know, but they don't know."
    } ]
  }, {
    "tStartMs": 1472520,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "So, yeah, I grew up in Delhi."
    } ]
  }, {
    "tStartMs": 1477600,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Born in a middle class family,"
    } ]
  }, {
    "tStartMs": 1479200,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "father was a school teacher,"
    } ]
  }, {
    "tStartMs": 1481880,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "mother was a housewife."
    } ]
  }, {
    "tStartMs": 1484360,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Youngest kid in the family."
    } ]
  }, {
    "tStartMs": 1488600,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "Growing up, just wanted to do something."
    } ]
  }, {
    "tStartMs": 1493360,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Nobody was doing business in my family."
    } ]
  }, {
    "tStartMs": 1494760,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "Because, you know, all..."
    } ]
  }, {
    "tStartMs": 1496400,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "But I don't know how I picked up that,"
    } ]
  }, {
    "tStartMs": 1498680,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "but that I will always do something\nof my own."
    } ]
  }, {
    "tStartMs": 1501480,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "This was probably when I was..."
    } ]
  }, {
    "tStartMs": 1505920,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "maybe, if I remember,\naround 10 years or 12 years,"
    } ]
  }, {
    "tStartMs": 1510240,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "I just wanted to do something of my own."
    } ]
  }, {
    "tStartMs": 1513080,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "And I was pretty clear\nthat I will not work for anybody else."
    } ]
  }, {
    "tStartMs": 1516720,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Despite knowing that there is no capital."
    } ]
  }, {
    "tStartMs": 1518640,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Why?"
    } ]
  }, {
    "tStartMs": 1520120,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "No... A school teacher,\nhow much capital will you have?"
    } ]
  }, {
    "tStartMs": 1523600,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "No, why will you not work for anyone else?"
    } ]
  }, {
    "tStartMs": 1527200,
    "dDurationMs": 5520,
    "segs": [ {
      "utf8": "Because I just thought that\nI want to do something different in life,"
    } ]
  }, {
    "tStartMs": 1532800,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "in terms of something meaningful."
    } ]
  }, {
    "tStartMs": 1536000,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "I am not saying impact,"
    } ]
  }, {
    "tStartMs": 1537280,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "because, at that time,\nit was not about impact,"
    } ]
  }, {
    "tStartMs": 1539520,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "it was about survival."
    } ]
  }, {
    "tStartMs": 1542720,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "You said this to me personally\nat different points."
    } ]
  }, {
    "tStartMs": 1546600,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "Even when I sat with you"
    } ]
  }, {
    "tStartMs": 1548920,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "and had the fund raise,\ndilution conversation."
    } ]
  }, {
    "tStartMs": 1553320,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "You always said, we won't raise X,"
    } ]
  }, {
    "tStartMs": 1558680,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "because control will go away."
    } ]
  }, {
    "tStartMs": 1561320,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Or we will have somebody else\nwe are answerable to."
    } ]
  }, {
    "tStartMs": 1564400,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "Why did you never want to work\nfor anyone else?"
    } ]
  }, {
    "tStartMs": 1568080,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "And why do you never\nwant to give up control"
    } ]
  }, {
    "tStartMs": 1571000,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "or your position in that ecosystem?"
    } ]
  }, {
    "tStartMs": 1572960,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "Yeah, so I think we will break up\nin these two parts."
    } ]
  }, {
    "tStartMs": 1577080,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "First, not work for anyone,"
    } ]
  }, {
    "tStartMs": 1578680,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "because I wanted, as I said,\nto do something different,"
    } ]
  }, {
    "tStartMs": 1582600,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "something big, something meaningful."
    } ]
  }, {
    "tStartMs": 1587120,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "And I..."
    } ]
  }, {
    "tStartMs": 1589200,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "-Jai, get me some coffee, please.\n-Yes, sir."
    } ]
  }, {
    "tStartMs": 1591240,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "I remember this conversation\nwith my friends at that time,"
    } ]
  }, {
    "tStartMs": 1593640,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "and we used to go and play in parks,\nthat I will do something of my own."
    } ]
  }, {
    "tStartMs": 1601480,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "And they would also ask the same question."
    } ]
  }, {
    "tStartMs": 1603440,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "But I think there was a deep desire\nin terms of wanted to..."
    } ]
  }, {
    "tStartMs": 1610920,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "wanted to be known for something."
    } ]
  }, {
    "tStartMs": 1614280,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Why?"
    } ]
  }, {
    "tStartMs": 1617360,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "This is the problem with him."
    } ]
  }, {
    "tStartMs": 1621600,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "No, but..."
    } ]
  }, {
    "tStartMs": 1622840,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "So why?"
    } ]
  }, {
    "tStartMs": 1624200,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Maybe because when I was growing up,"
    } ]
  }, {
    "tStartMs": 1628280,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "I saw, you know..."
    } ]
  }, {
    "tStartMs": 1633320,
    "dDurationMs": 6760,
    "segs": [ {
      "utf8": "how people were and how things were\ngoing on in terms of whatever access."
    } ]
  }, {
    "tStartMs": 1640160,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "So because we were having\nvery limited access to things."
    } ]
  }, {
    "tStartMs": 1643520,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "So you are 50 now."
    } ]
  }, {
    "tStartMs": 1645680,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "Your formative years were '90s?"
    } ]
  }, {
    "tStartMs": 1650680,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "-When India was opening up?\n-Yeah."
    } ]
  }, {
    "tStartMs": 1653120,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "Yeah. You know, end of, let's say...\nyou can say..."
    } ]
  }, {
    "tStartMs": 1657160,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "When I started working, it was 2000, yeah."
    } ]
  }, {
    "tStartMs": 1660120,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "Right. What did you see then\nwhich made you want to do these things?"
    } ]
  }, {
    "tStartMs": 1663960,
    "dDurationMs": 5240,
    "segs": [ {
      "utf8": "So first, you know, I just told my dad...\nhe said, \"What do you want to do?\""
    } ]
  }, {
    "tStartMs": 1669280,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "I said, \"I just want to do\nsomething of my own.\""
    } ]
  }, {
    "tStartMs": 1670880,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "-He said, \"What?\"\n-I said, \"I have no idea."
    } ]
  }, {
    "tStartMs": 1673760,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "But buy me a computer.\""
    } ]
  }, {
    "tStartMs": 1675560,
    "dDurationMs": 5080,
    "segs": [ {
      "utf8": "Because all my friends, whether they were\ndoing civil or mechanical or electronics,"
    } ]
  }, {
    "tStartMs": 1680720,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "everybody was going in software."
    } ]
  }, {
    "tStartMs": 1681840,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "So I said I want to do\nsomething in software."
    } ]
  }, {
    "tStartMs": 1683600,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "[Nikhil] Mm-hmm."
    } ]
  }, {
    "tStartMs": 1685320,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "And bought that computer."
    } ]
  }, {
    "tStartMs": 1690160,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And I clearly remember\nwhen I bought that computer,"
    } ]
  }, {
    "tStartMs": 1692160,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I had no idea about computers\nat that time."
    } ]
  }, {
    "tStartMs": 1693920,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Windows came,\nand Windows was there at that time."
    } ]
  }, {
    "tStartMs": 1697040,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "So I went to the guy\nwho was selling the computer."
    } ]
  }, {
    "tStartMs": 1699800,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "He said, \"What computer do you want?\""
    } ]
  }, {
    "tStartMs": 1701600,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "I said, \"It should have lot of icons\non the screen.\""
    } ]
  }, {
    "tStartMs": 1706720,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "It used to have shortcuts, actually."
    } ]
  }, {
    "tStartMs": 1708680,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "I never knew about that."
    } ]
  }, {
    "tStartMs": 1709760,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "I said, \"It should have lot of icons\non the screen.\""
    } ]
  }, {
    "tStartMs": 1714000,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "And that's how..."
    } ]
  }, {
    "tStartMs": 1715920,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "So he laughed at me."
    } ]
  }, {
    "tStartMs": 1718560,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "\"He has no idea.\""
    } ]
  }, {
    "tStartMs": 1720800,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "He gave me."
    } ]
  }, {
    "tStartMs": 1722120,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "And then I bought a book."
    } ]
  }, {
    "tStartMs": 1727320,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "\"Learn VB in 21 days.\""
    } ]
  }, {
    "tStartMs": 1729480,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "-Visual Basic.\n-Visual Basic, yeah."
    } ]
  }, {
    "tStartMs": 1732280,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "I wrote a program in three days."
    } ]
  }, {
    "tStartMs": 1734640,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Hello world, this, that.\nI thought, \"Okay, I know programming now.\""
    } ]
  }, {
    "tStartMs": 1737960,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "My friend came, he saw the book.\nHe said, \"You've done this?\""
    } ]
  }, {
    "tStartMs": 1740720,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I said, \"Yeah, I made a program.\"\nHe said, \"Can I take this?\""
    } ]
  }, {
    "tStartMs": 1742480,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "I said, \"Yeah, take it.\""
    } ]
  }, {
    "tStartMs": 1744080,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "So he took that book away."
    } ]
  }, {
    "tStartMs": 1745560,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "That guy later became my partner.\nSo the story..."
    } ]
  }, {
    "tStartMs": 1748840,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "And he is a core techie guy."
    } ]
  }, {
    "tStartMs": 1750680,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Coding only."
    } ]
  }, {
    "tStartMs": 1752520,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "So I tell him\nyou become a coder because of me."
    } ]
  }, {
    "tStartMs": 1755640,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "So, by virtue of buying that computer,\nthat decision,"
    } ]
  }, {
    "tStartMs": 1758920,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "we started working on..."
    } ]
  }, {
    "tStartMs": 1760680,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "So I started looking for opportunities\nin software."
    } ]
  }, {
    "tStartMs": 1762800,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "That, what can I do in software."
    } ]
  }, {
    "tStartMs": 1765200,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "2000 was like the software bust time, no?"
    } ]
  }, {
    "tStartMs": 1768160,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Yeah, the dot-com."
    } ]
  }, {
    "tStartMs": 1769400,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "So, this is like '99 or so."
    } ]
  }, {
    "tStartMs": 1771600,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "You started Micromax in 2000."
    } ]
  }, {
    "tStartMs": 1773560,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "No, actually 1998."
    } ]
  }, {
    "tStartMs": 1776360,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "1998, with the three friends."
    } ]
  }, {
    "tStartMs": 1779200,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "-Four friends.\n-[Nikhil] Four friends."
    } ]
  }, {
    "tStartMs": 1781120,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Started with three, fourth came\nfrom US and then joined here."
    } ]
  }, {
    "tStartMs": 1784720,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "Then started, you know,\nworking on software,"
    } ]
  }, {
    "tStartMs": 1786360,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "just worked on a lot of SAP."
    } ]
  }, {
    "tStartMs": 1788400,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "That went down."
    } ]
  }, {
    "tStartMs": 1790920,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Then started working on e-commerce,"
    } ]
  }, {
    "tStartMs": 1793480,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "that Y2K problems and all that.\nSo, at that time, I was in US."
    } ]
  }, {
    "tStartMs": 1797440,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "So I was the BD guy,\ndoing marketing and sales,"
    } ]
  }, {
    "tStartMs": 1800640,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "and rest of the other guys were\ndoing the coding and everything."
    } ]
  }, {
    "tStartMs": 1803360,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "So, at that time,\nwe wrote a lot of B2B engines"
    } ]
  }, {
    "tStartMs": 1806280,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "for e-commerce and doing all that."
    } ]
  }, {
    "tStartMs": 1813200,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "So, you know, that was the time\nwhen Sun Microsystems was there,"
    } ]
  }, {
    "tStartMs": 1816040,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "and it was like we had the dot in dot-com."
    } ]
  }, {
    "tStartMs": 1820400,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "And then that market went down,\nand then we realised"
    } ]
  }, {
    "tStartMs": 1823840,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "that it is a very fast-moving market,"
    } ]
  }, {
    "tStartMs": 1825280,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "and you have to, you know,\nconstantly change yourself"
    } ]
  }, {
    "tStartMs": 1827360,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "very quickly to be relevant."
    } ]
  }, {
    "tStartMs": 1829960,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "We moved on to embedded technology,"
    } ]
  }, {
    "tStartMs": 1831520,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "started working\nwith University of Irvine, California."
    } ]
  }, {
    "tStartMs": 1834360,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "They had an R\u0026D centre on embedded."
    } ]
  }, {
    "tStartMs": 1836800,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "We started working together."
    } ]
  }, {
    "tStartMs": 1839240,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "And, at that time, Nokia, in India,"
    } ]
  }, {
    "tStartMs": 1841680,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "was looking\nfor a machine-to-machine partner, M2M."
    } ]
  }, {
    "tStartMs": 1846360,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "HCL was their partner\nfor their mobile phones,"
    } ]
  }, {
    "tStartMs": 1850040,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "and they were looking for someone\nfor a machine-to-machine."
    } ]
  }, {
    "tStartMs": 1852240,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "And we got introduced."
    } ]
  }, {
    "tStartMs": 1855360,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And they said,\n\"Would you like to do something?\""
    } ]
  }, {
    "tStartMs": 1857360,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "You know, we used to write device drivers,"
    } ]
  }, {
    "tStartMs": 1861320,
    "dDurationMs": 6000,
    "segs": [ {
      "utf8": "doing, you know, work on\na lot of different architectures."
    } ]
  }, {
    "tStartMs": 1867400,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "ARM, PowerPC and all that."
    } ]
  }, {
    "tStartMs": 1869360,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Said okay, started doing that."
    } ]
  }, {
    "tStartMs": 1873480,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "And then, one fine day,"
    } ]
  }, {
    "tStartMs": 1878040,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "I was just sitting with one of the guys\nfrom Nokia, Finland."
    } ]
  }, {
    "tStartMs": 1881640,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "And he showed me a product."
    } ]
  }, {
    "tStartMs": 1884440,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "I said, \"What is this?\""
    } ]
  }, {
    "tStartMs": 1885520,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "He said, \"This is one of the products\nwherein if you put a SIM card in this,"
    } ]
  }, {
    "tStartMs": 1888800,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "you can connect a telephone\nalong with this,"
    } ]
  }, {
    "tStartMs": 1893080,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "and it will replace the landline.\""
    } ]
  }, {
    "tStartMs": 1895240,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "So I said, \"Good.\nSo why did you make this product?\""
    } ]
  }, {
    "tStartMs": 1898800,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "He said, \"In Finland, you know,"
    } ]
  }, {
    "tStartMs": 1900000,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "because there are a lot of snow\nand everything,"
    } ]
  }, {
    "tStartMs": 1902160,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "you can't lay the copper wire...\nthe telephone."
    } ]
  }, {
    "tStartMs": 1905800,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "So you can put a SIM card in this\nand connect a phone"
    } ]
  }, {
    "tStartMs": 1908200,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "and then you have a landline,"
    } ]
  }, {
    "tStartMs": 1909320,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "because this phone is going to be fixed,\nnobody's going to take it.\""
    } ]
  }, {
    "tStartMs": 1913320,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "He said, \"Can you do something with this?\""
    } ]
  }, {
    "tStartMs": 1917360,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "I said, \"India, how much would this..."
    } ]
  }, {
    "tStartMs": 1919400,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "we don't have market\nfor something like this.\""
    } ]
  }, {
    "tStartMs": 1924200,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "So I took that product from him.\nI said, \"Okay, let me just play.\""
    } ]
  }, {
    "tStartMs": 1930320,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "And we found an opportunity and I went\nback to him the next day and said,"
    } ]
  }, {
    "tStartMs": 1934440,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "we would like to power\nthe payphone machines."
    } ]
  }, {
    "tStartMs": 1937840,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Yes."
    } ]
  }, {
    "tStartMs": 1939360,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "So we went to Airtel and all those guys..."
    } ]
  }, {
    "tStartMs": 1945640,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "and all the GSM players,"
    } ]
  }, {
    "tStartMs": 1947720,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "said, we can power payphones\nwith one SIM card."
    } ]
  }, {
    "tStartMs": 1951800,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "At that time, payphone in India\nwas only MTNL and BSNL,"
    } ]
  }, {
    "tStartMs": 1954280,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "government companies laying down the wire."
    } ]
  }, {
    "tStartMs": 1957080,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "You mean the STD centre?"
    } ]
  }, {
    "tStartMs": 1958960,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "STD centre, STD meets."
    } ]
  }, {
    "tStartMs": 1962680,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "So they said, \"Okay, how can you do that?\""
    } ]
  }, {
    "tStartMs": 1964560,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "We said, \"This is, you know,\nwith that phone,\""
    } ]
  }, {
    "tStartMs": 1966200,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "because we were writing device drivers\nand everything,"
    } ]
  }, {
    "tStartMs": 1968120,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "we took that machine,\nchange the code and everything,"
    } ]
  }, {
    "tStartMs": 1971960,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "put our software, attach the landline,"
    } ]
  }, {
    "tStartMs": 1974720,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "and say, you put a SIM card,\nand you can work."
    } ]
  }, {
    "tStartMs": 1978800,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "They said, good."
    } ]
  }, {
    "tStartMs": 1980600,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "And then it was also a solution,\ngood solution for corporates,"
    } ]
  }, {
    "tStartMs": 1983400,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "because corporates, if they want to have\na connection straight away,"
    } ]
  }, {
    "tStartMs": 1986080,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "you can just, you know, integrate it\nwith the EPABX systems and all."
    } ]
  }, {
    "tStartMs": 1990080,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So it worked for them."
    } ]
  }, {
    "tStartMs": 1993080,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "And from a small Delhi-based company,"
    } ]
  }, {
    "tStartMs": 1997040,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "we started growing to all the states\nand started supporting all the carriers."
    } ]
  }, {
    "tStartMs": 2000840,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "Airtel, that time, it was Hutch\nand Idea and all."
    } ]
  }, {
    "tStartMs": 2005640,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "We started supplying to them."
    } ]
  }, {
    "tStartMs": 2007680,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "The business was started doing\nreasonably okay."
    } ]
  }, {
    "tStartMs": 2010160,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "From three, four crore rupees annually,"
    } ]
  }, {
    "tStartMs": 2014600,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "we started doing around 100 crore rupees."
    } ]
  }, {
    "tStartMs": 2017760,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "-And, you know, very quickly we scaled up.\n-What year was this?"
    } ]
  }, {
    "tStartMs": 2022480,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "This, I think 2003."
    } ]
  }, {
    "tStartMs": 2024800,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Hundred crore then\nis like thousand crore now."
    } ]
  }, {
    "tStartMs": 2027880,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "More."
    } ]
  }, {
    "tStartMs": 2030040,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "A lot more."
    } ]
  }, {
    "tStartMs": 2031480,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "So we were happy."
    } ]
  }, {
    "tStartMs": 2032560,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "We thought that okay, we have arrived,\nsomething is happening."
    } ]
  }, {
    "tStartMs": 2035080,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "So that business was doing well."
    } ]
  }, {
    "tStartMs": 2036720,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So one day I got a call\nfrom this Finnish guy."
    } ]
  }, {
    "tStartMs": 2040120,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "I remember his name, Henry."
    } ]
  }, {
    "tStartMs": 2042120,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "So Henry said, \"Rahul, can we meet?\"\nI said, \"Absolutely.\""
    } ]
  }, {
    "tStartMs": 2046040,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Said, \"Why?\""
    } ]
  }, {
    "tStartMs": 2047120,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "He said, \"I have good news\nand bad news for you.\""
    } ]
  }, {
    "tStartMs": 2050000,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "I said, \"Tell me what?\"\nHe said, \"No, come over to my home.\""
    } ]
  }, {
    "tStartMs": 2053720,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Went to his home."
    } ]
  }, {
    "tStartMs": 2056240,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "He said, \"What do you like to listen?\"\nI said, \"Tell me the bad news first.\""
    } ]
  }, {
    "tStartMs": 2059600,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "He said, \"Bad news is that"
    } ]
  }, {
    "tStartMs": 2061560,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "Nokia, we have sold\nthe whole machine-to-machine business.\""
    } ]
  }, {
    "tStartMs": 2064880,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "What year was this?"
    } ]
  }, {
    "tStartMs": 2066640,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "It's 2003."
    } ]
  }, {
    "tStartMs": 2068400,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "2003, 2004."
    } ]
  }, {
    "tStartMs": 2069840,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "Back then they were killing it, right?\nNokia was the market leader?"
    } ]
  }, {
    "tStartMs": 2073800,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Number 1 to number 10 was Nokia."
    } ]
  }, {
    "tStartMs": 2075480,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "Then started 11, 12, 13. Yeah."
    } ]
  }, {
    "tStartMs": 2078280,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "So I said, \"What is the good news?\""
    } ]
  }, {
    "tStartMs": 2080880,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "He said, \"Good news is that"
    } ]
  }, {
    "tStartMs": 2082080,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "as Nokia, now we are coming\ninto car accessories business."
    } ]
  }, {
    "tStartMs": 2085000,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "We want you to distribute\nour car accessories.\""
    } ]
  }, {
    "tStartMs": 2090160,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "So those car accessories, you know,\nthey had speakers."
    } ]
  }, {
    "tStartMs": 2092200,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "You could put in those,\nthat lighter socket."
    } ]
  }, {
    "tStartMs": 2097080,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "-[Nikhil] Mm-hmm.\n-Oh."
    } ]
  }, {
    "tStartMs": 2098360,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "And connect the wire with your Nokia phone\nand then while you are driving,"
    } ]
  }, {
    "tStartMs": 2102120,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "the speaker, you know, you can talk."
    } ]
  }, {
    "tStartMs": 2104960,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "A pretty interesting solution."
    } ]
  }, {
    "tStartMs": 2106240,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "They had a speaker\nyou can put in your seat"
    } ]
  }, {
    "tStartMs": 2109200,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "and the mic and, you know,\nthe speakers will come like this."
    } ]
  }, {
    "tStartMs": 2113960,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "So all those sort of..."
    } ]
  }, {
    "tStartMs": 2116240,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "So I said, \"No, we are not interested\nin the accessories business.\""
    } ]
  }, {
    "tStartMs": 2120200,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "So the technology was there with us\ncompletely because we developed..."
    } ]
  }, {
    "tStartMs": 2125000,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "So we made our own box,\nour fixed wireless terminal."
    } ]
  }, {
    "tStartMs": 2127760,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "Stamped Micromax on top of it\nand went back to Airtel."
    } ]
  }, {
    "tStartMs": 2131280,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "We said, \"Nokia is no more,\nthis is Micromax."
    } ]
  }, {
    "tStartMs": 2134640,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Would you like to use it?\""
    } ]
  }, {
    "tStartMs": 2136840,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Same terminal."
    } ]
  }, {
    "tStartMs": 2138960,
    "dDurationMs": 5160,
    "segs": [ {
      "utf8": "All of those guys, Airtel and Vodafone,\nthey used to know me from Nokia."
    } ]
  }, {
    "tStartMs": 2144200,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "In their phone also, my phone number\nwas saved as \"Rahul Nokia\"."
    } ]
  }, {
    "tStartMs": 2149000,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "So they said, \"Okay.\""
    } ]
  }, {
    "tStartMs": 2154240,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "Up north there is a shrine, Vaishno Devi,\nthey said, \"You install it there.\""
    } ]
  }, {
    "tStartMs": 2158080,
    "dDurationMs": 5440,
    "segs": [ {
      "utf8": "Because it works 24 hours, the pay phone,\nyou know, it works 24 hours."
    } ]
  }, {
    "tStartMs": 2163600,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "-In \"Vaishnav\" Devi?\n-Vaishno Devi."
    } ]
  }, {
    "tStartMs": 2165920,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "Yeah? I have been there,\nthat walk where you are climbing the hill"
    } ]
  }, {
    "tStartMs": 2169960,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "and there are STD booths\non that path, right?"
    } ]
  }, {
    "tStartMs": 2171840,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Yes, yes."
    } ]
  }, {
    "tStartMs": 2174400,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "So we installed our machines there."
    } ]
  }, {
    "tStartMs": 2177080,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "First machines in Vaishno Devi?"
    } ]
  }, {
    "tStartMs": 2178720,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "-Yes.\n-How come?"
    } ]
  }, {
    "tStartMs": 2180600,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Because that's what Airtel said,\nthat, you know, if you install--"
    } ]
  }, {
    "tStartMs": 2182680,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "Because the traffic is so high,\nthat if it works there,"
    } ]
  }, {
    "tStartMs": 2186360,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "if it can take the load,\nthen it will work anywhere."
    } ]
  }, {
    "tStartMs": 2189480,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "We said, \"Okay.\"\nWe installed it there, 20 days."
    } ]
  }, {
    "tStartMs": 2192160,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "The revenue from..."
    } ]
  }, {
    "tStartMs": 2193240,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "Because see, for the operators,\nit was a killer product"
    } ]
  }, {
    "tStartMs": 2196400,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "because their ARPU from one SIM card,"
    } ]
  }, {
    "tStartMs": 2198640,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "multiple people are using one SIM card,\nthe ARPU is massive."
    } ]
  }, {
    "tStartMs": 2201960,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Thousands of rupees from one SIM card."
    } ]
  }, {
    "tStartMs": 2204040,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "With an individual, it's..."
    } ]
  }, {
    "tStartMs": 2205920,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Versus what did they have before that?"
    } ]
  }, {
    "tStartMs": 2207600,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "Nothing."
    } ]
  }, {
    "tStartMs": 2209240,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "There were STD booths before that, right?"
    } ]
  }, {
    "tStartMs": 2210840,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "MTNL... powered by MTNL and BSNL."
    } ]
  }, {
    "tStartMs": 2213040,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Hmm."
    } ]
  }, {
    "tStartMs": 2214160,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "To run an..."
    } ]
  }, {
    "tStartMs": 2215440,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "You know, to install an STD booth\nwhere there was no MTNL, BSNL line,"
    } ]
  }, {
    "tStartMs": 2218200,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "where there was only..."
    } ]
  }, {
    "tStartMs": 2219280,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "if there was a GSM signal coming in,\nyou can power that."
    } ]
  }, {
    "tStartMs": 2223720,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "And so then they gave us a contract."
    } ]
  }, {
    "tStartMs": 2226640,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "This is pre\n\"people having cell phones\", right?"
    } ]
  }, {
    "tStartMs": 2228640,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Significantly pre."
    } ]
  }, {
    "tStartMs": 2229840,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "No, cell phones were there at that time."
    } ]
  }, {
    "tStartMs": 2231600,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "In 2005-06, they were pretty much there."
    } ]
  }, {
    "tStartMs": 2234520,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Yeah, the cell phones were there."
    } ]
  }, {
    "tStartMs": 2235720,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "No smartphones,\nall the feature phones were there."
    } ]
  }, {
    "tStartMs": 2237880,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "So, you are saying the difference was\nit got cheaper?"
    } ]
  }, {
    "tStartMs": 2240080,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "Yeah, it was difficult to get."
    } ]
  }, {
    "tStartMs": 2242400,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "So, you have to apply to MTNL,\nget a license and then, you know, install."
    } ]
  }, {
    "tStartMs": 2246640,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "-Painful that time.\n-[Rahul] Right."
    } ]
  }, {
    "tStartMs": 2248520,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "The government."
    } ]
  }, {
    "tStartMs": 2249680,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "The government thing and then,\nyou know, they will come,"
    } ]
  }, {
    "tStartMs": 2252640,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "and if there was no line..."
    } ]
  }, {
    "tStartMs": 2254520,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Imagine if there is no...\nIf it is a village."
    } ]
  }, {
    "tStartMs": 2257800,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "See, they have to lay down the whole line.\nIt was a costly affair and time-taking."
    } ]
  }, {
    "tStartMs": 2261520,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "And for us, if there is a signal coming,"
    } ]
  }, {
    "tStartMs": 2263320,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "we will say, about five minutes,\nwe will install it."
    } ]
  }, {
    "tStartMs": 2265853,
    "dDurationMs": 4760,
    "segs": [ {
      "utf8": "So, that business started doing quite well\nand then we became a de facto number one"
    } ]
  }, {
    "tStartMs": 2270693,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "on GSM fixed wireless terminal phones\nin India."
    } ]
  }, {
    "tStartMs": 2273693,
    "dDurationMs": 5400,
    "segs": [ {
      "utf8": "And started operating offices pan-India,\nbecame a pan-India player,"
    } ]
  }, {
    "tStartMs": 2279173,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "service network and everything.\nSo, we learnt a lot there."
    } ]
  }, {
    "tStartMs": 2282533,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "Applying, you know, sale tax numbers\nand everything,"
    } ]
  }, {
    "tStartMs": 2285653,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "you know, like the whole...\nhow the business works."
    } ]
  }, {
    "tStartMs": 2288653,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "This is till 2006."
    } ]
  }, {
    "tStartMs": 2290933,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "2000, yeah. 2006-07."
    } ]
  }, {
    "tStartMs": 2294053,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Mm."
    } ]
  }, {
    "tStartMs": 2295573,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "One fine day, I got a call\nfrom a senior guy from Airtel."
    } ]
  }, {
    "tStartMs": 2297653,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "He said, \"Oh, there is a problem\nin a machine."
    } ]
  }, {
    "tStartMs": 2299133,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Can you go and check it?\""
    } ]
  }, {
    "tStartMs": 2300533,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "That, by that time, you know,\nour business grew"
    } ]
  }, {
    "tStartMs": 2302453,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "to like 400 crores per annum."
    } ]
  }, {
    "tStartMs": 2305013,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "So, we were doing, like..."
    } ]
  }, {
    "tStartMs": 2308853,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "Did you have liquidity?\nDid you take out money from the business?"
    } ]
  }, {
    "tStartMs": 2311653,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "No, we were just keeping the money."
    } ]
  }, {
    "tStartMs": 2313373,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "But I still... I just remember\nthat time BMW came to India."
    } ]
  }, {
    "tStartMs": 2316053,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "I bought a BMW 3 Series\nand thought, \"Yes, this is it.\""
    } ]
  }, {
    "tStartMs": 2319893,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "In 2006."
    } ]
  }, {
    "tStartMs": 2321013,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "So, that time, then my...\nThat was the first time"
    } ]
  }, {
    "tStartMs": 2323893,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "when my parents realised\nthat our son is doing something."
    } ]
  }, {
    "tStartMs": 2326293,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "Because otherwise, they used to ask me,\n\"Son, what are you doing?\""
    } ]
  }, {
    "tStartMs": 2329173,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "I said, \"Fixed wireless terminals\nand all that...\""
    } ]
  }, {
    "tStartMs": 2332053,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Yeah, so coming back to the story,\nso that guy called me."
    } ]
  }, {
    "tStartMs": 2334893,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "So, I said, he said,\n\"It's in Bengal somewhere,"
    } ]
  }, {
    "tStartMs": 2338173,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "why don't you go and check?\""
    } ]
  }, {
    "tStartMs": 2339933,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "I said, \"I'll send some engineer.\""
    } ]
  }, {
    "tStartMs": 2341493,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "He said,\n\"No, it's a senior-level escalation,"
    } ]
  }, {
    "tStartMs": 2342933,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "can you go yourself?\" I said, \"Okay.\""
    } ]
  }, {
    "tStartMs": 2345733,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Took a plane, landed in Kolkata,\ntook a cab,"
    } ]
  }, {
    "tStartMs": 2348253,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "five hours drive near Bangladesh border."
    } ]
  }, {
    "tStartMs": 2351653,
    "dDurationMs": 4520,
    "segs": [ {
      "utf8": "Saw, this all, Krishnanagar,\nNadia and all..."
    } ]
  }, {
    "tStartMs": 2356973,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "Just saw the problem, fixed it\nand then in the evening coming back..."
    } ]
  }, {
    "tStartMs": 2360613,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "to catch a flight\nin late night in Kolkata."
    } ]
  }, {
    "tStartMs": 2363093,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "In mid, I saw, it's a village\nwhere there was no electricity."
    } ]
  }, {
    "tStartMs": 2366573,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "But there was an Airtel ISD PCO booth."
    } ]
  }, {
    "tStartMs": 2371293,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "So, I asked my cab driver, I said,\n\"Bhaiya, can you stop the car?\""
    } ]
  }, {
    "tStartMs": 2375453,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "I went inside the booth."
    } ]
  }, {
    "tStartMs": 2378213,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "And, because I knew\nthat if it is an Airtel,"
    } ]
  }, {
    "tStartMs": 2379853,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "must be using our equipment."
    } ]
  }, {
    "tStartMs": 2381453,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "So, I said, \"There is no electricity\nin the village,"
    } ]
  }, {
    "tStartMs": 2385013,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "how are you running this booth?\""
    } ]
  }, {
    "tStartMs": 2388413,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "He showed me a big truck battery there."
    } ]
  }, {
    "tStartMs": 2390373,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "He said, \"Sir, you draw power from here.\""
    } ]
  }, {
    "tStartMs": 2394253,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "I said, \"Fine.\""
    } ]
  }, {
    "tStartMs": 2396733,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "We were not making phones those days,\nI was having a Nokia phone."
    } ]
  }, {
    "tStartMs": 2400613,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "There was no signal in my phone."
    } ]
  }, {
    "tStartMs": 2401893,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "I said, \"There is no signal in my phone,\nhow are you drawing the signals?\""
    } ]
  }, {
    "tStartMs": 2405213,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "He showed me a big 20 dB gain antenna,\nmounted on a pole on his terrace."
    } ]
  }, {
    "tStartMs": 2410893,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Typical Indian jugaad."
    } ]
  }, {
    "tStartMs": 2413373,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "He said,\n\"Sir, the signal comes from here.\""
    } ]
  }, {
    "tStartMs": 2416453,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "I got more intrigued. I said, \"Fine,"
    } ]
  }, {
    "tStartMs": 2418133,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "there is no electricity,\nhow do you charge the battery?\""
    } ]
  }, {
    "tStartMs": 2421013,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "He said, \"Eleven kilometres away\nthere is a village,"
    } ]
  }, {
    "tStartMs": 2424053,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "there is electricity."
    } ]
  }, {
    "tStartMs": 2426453,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "In the night, when I shut down\nmy shutter, I go there,"
    } ]
  }, {
    "tStartMs": 2428973,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "charge in the night\nand then come back in the morning.\""
    } ]
  }, {
    "tStartMs": 2431613,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "I said, \"How much money do you make?\""
    } ]
  }, {
    "tStartMs": 2433613,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "He said, \"Around, let's say,\n4,000 rupees a month.\""
    } ]
  }, {
    "tStartMs": 2436453,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Now, 4,000 rupees a month in a village,"
    } ]
  }, {
    "tStartMs": 2438413,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "there is no electricity,\nno entertainment, no TV, is big."
    } ]
  }, {
    "tStartMs": 2442053,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "Then I was travelling\nin the interiors of Bihar,"
    } ]
  }, {
    "tStartMs": 2445733,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "and I saw people charging,"
    } ]
  }, {
    "tStartMs": 2448093,
    "dDurationMs": 4520,
    "segs": [ {
      "utf8": "you know, asking 25 rupees or 40 rupees\nto charge your phone."
    } ]
  }, {
    "tStartMs": 2452693,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Because at those days there were\ndifferent pins for different phones."
    } ]
  }, {
    "tStartMs": 2455173,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I remember, yeah."
    } ]
  }, {
    "tStartMs": 2456933,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "Different for Motorola\nand different for Nokia,"
    } ]
  }, {
    "tStartMs": 2460093,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "those round pins and all..."
    } ]
  }, {
    "tStartMs": 2461813,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "before everything standardised."
    } ]
  }, {
    "tStartMs": 2463853,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "I said, \"Why is this?\""
    } ]
  }, {
    "tStartMs": 2465333,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "He said, \"Because there is no electricity\nat home, people come, pay and charge.\""
    } ]
  }, {
    "tStartMs": 2468893,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "It's very expensive, right?"
    } ]
  }, {
    "tStartMs": 2470933,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "-For a charge.\n-Yeah. At that time it is very much."
    } ]
  }, {
    "tStartMs": 2473893,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "But see, those days\nmobile phones were not common like this"
    } ]
  }, {
    "tStartMs": 2476693,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "because the call was not free."
    } ]
  }, {
    "tStartMs": 2480053,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Today, probably you are paying for data."
    } ]
  }, {
    "tStartMs": 2482053,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "You know, that time the call\nwas expensive."
    } ]
  }, {
    "tStartMs": 2484973,
    "dDurationMs": 5080,
    "segs": [ {
      "utf8": "I went back, sat with our guys,\nworked a lot on the GSM technology."
    } ]
  }, {
    "tStartMs": 2490133,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "I said, \"Guys,\nwhy don't you make a mobile phone?\""
    } ]
  }, {
    "tStartMs": 2491853,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "What year was this?"
    } ]
  }, {
    "tStartMs": 2493093,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "This is 2007."
    } ]
  }, {
    "tStartMs": 2496253,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "So, the first reaction from everyone\ninternally was, \"Are you crazy?"
    } ]
  }, {
    "tStartMs": 2499933,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "Who is going to fight these Nokias\nand Samsungs and Motorolas in the world?\""
    } ]
  }, {
    "tStartMs": 2507453,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And they said,\n\"Why do you want to do that?"
    } ]
  }, {
    "tStartMs": 2509213,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "I mean, we are doing so well.\nYou are driving a BMW 3 Series,"
    } ]
  }, {
    "tStartMs": 2513013,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "so why do you want\nto disturb the apple cart?"
    } ]
  }, {
    "tStartMs": 2515573,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Why?"
    } ]
  }, {
    "tStartMs": 2517973,
    "dDurationMs": 5600,
    "segs": [ {
      "utf8": "I said, \"No, I think, you know, the food\nis being cooked in different countries."
    } ]
  }, {
    "tStartMs": 2523653,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "We need a flavour in India."
    } ]
  }, {
    "tStartMs": 2525453,
    "dDurationMs": 6480,
    "segs": [ {
      "utf8": "You know, it's somewhere in Finland\nor in Korea, but we need Indian flavours.\""
    } ]
  }, {
    "tStartMs": 2533213,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Anyway, so fought a lot internally."
    } ]
  }, {
    "tStartMs": 2536093,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "And then they said..."
    } ]
  }, {
    "tStartMs": 2537533,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Fought with your co-founders,\nyour partners."
    } ]
  }, {
    "tStartMs": 2538973,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Yes, yes, yes."
    } ]
  }, {
    "tStartMs": 2541053,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "They said, \"Okay, 10,000 phones you make."
    } ]
  }, {
    "tStartMs": 2543533,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "If it works, it's fine,\notherwise our business is doing well.\""
    } ]
  }, {
    "tStartMs": 2546013,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "So, this is like casino money\nthey gave me."
    } ]
  }, {
    "tStartMs": 2548093,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "They said, \"You go and play, if it works,\nit's okay. Otherwise you pay.\""
    } ]
  }, {
    "tStartMs": 2550373,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "How much money was there?"
    } ]
  }, {
    "tStartMs": 2552133,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "10,000 phones,\neven if a phone was 2,000 rupees,"
    } ]
  }, {
    "tStartMs": 2556493,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "you multiply, it was what?"
    } ]
  }, {
    "tStartMs": 2558653,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "-Twenty crores?\n-Yeah, all that, yeah."
    } ]
  }, {
    "tStartMs": 2563013,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "I said, okay."
    } ]
  }, {
    "tStartMs": 2564973,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "So, we sat with the team and said,"
    } ]
  }, {
    "tStartMs": 2566493,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "\"Guys, let's make a phone\nwith long battery life,"
    } ]
  }, {
    "tStartMs": 2568853,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "one month of battery backup,\nbecause of all these experiences.\""
    } ]
  }, {
    "tStartMs": 2572653,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "And..."
    } ]
  }, {
    "tStartMs": 2574813,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "And that's how\nthe first Micromax phone came."
    } ]
  }, {
    "tStartMs": 2578013,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "And the tagline for the phone\nwas \"Mobile ka Baap.\""
    } ]
  }, {
    "tStartMs": 2580733,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Because the standby time was 30 days."
    } ]
  }, {
    "tStartMs": 2584093,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Since we worked a lot."
    } ]
  }, {
    "tStartMs": 2585693,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "Now, herein, my philosophy is that\nwhatever you are doing in life,"
    } ]
  }, {
    "tStartMs": 2590093,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "nothing goes waste."
    } ]
  }, {
    "tStartMs": 2591373,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "Whatever we were, you know, I'm just,\nyou know, scrambling my whole story here."
    } ]
  }, {
    "tStartMs": 2595413,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "But in between,\nwe worked a lot on SIM card,"
    } ]
  }, {
    "tStartMs": 2597293,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "with Schlumberger and all those guys\nfor one, two years."
    } ]
  }, {
    "tStartMs": 2599253,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "Nothing came out of it."
    } ]
  }, {
    "tStartMs": 2600893,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Nothing came out of all those things."
    } ]
  }, {
    "tStartMs": 2602773,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "But all those things we implemented\nwhen we were making phones."
    } ]
  }, {
    "tStartMs": 2606573,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "So, normal phones take\nseven to eight milliamperes,"
    } ]
  }, {
    "tStartMs": 2610373,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "you know, per second as power."
    } ]
  }, {
    "tStartMs": 2612693,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "We worked on embedded,"
    } ]
  }, {
    "tStartMs": 2614413,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "we made it two to three milliamperes\nper second."
    } ]
  }, {
    "tStartMs": 2616533,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "And that's how we created\nthe same form factor."
    } ]
  }, {
    "tStartMs": 2620253,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "At that time,\nthe battery was 700, 600 mAh."
    } ]
  }, {
    "tStartMs": 2624573,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "We put some 1,800 mAh,\n2,000 mAh that time."
    } ]
  }, {
    "tStartMs": 2628493,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "Same form factor."
    } ]
  }, {
    "tStartMs": 2629773,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "Made a phone\nand then went to the distributors."
    } ]
  }, {
    "tStartMs": 2633093,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Now, the real problem started from there."
    } ]
  }, {
    "tStartMs": 2636173,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "Because all the distributors were like,\nall big distributors."
    } ]
  }, {
    "tStartMs": 2639133,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "Like, even the Delhi distributor of Nokia\nwas bigger than us."
    } ]
  }, {
    "tStartMs": 2644413,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "We were doing pan-India business,\nfixed wireless and all, but..."
    } ]
  }, {
    "tStartMs": 2647333,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "Because Nokia was so successful."
    } ]
  }, {
    "tStartMs": 2649373,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "So, we said, \"Now we make mobile phones,\nwhy don't you distribute?\""
    } ]
  }, {
    "tStartMs": 2653493,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "And globally, it was only, you know,"
    } ]
  }, {
    "tStartMs": 2654933,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "all those four, five\ninternational brand names."
    } ]
  }, {
    "tStartMs": 2658373,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "There was no local brand doing anything\nin the world at that time."
    } ]
  }, {
    "tStartMs": 2663173,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "Even if it was there, they were not like\nvery, very successful brands."
    } ]
  }, {
    "tStartMs": 2667013,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "So, they just offered us a cup of coffee\nand said, \"Good friends, but sorry.\""
    } ]
  }, {
    "tStartMs": 2672013,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "We were not able to find a distributor\nafter making the phone."
    } ]
  }, {
    "tStartMs": 2675333,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "In 2000?"
    } ]
  }, {
    "tStartMs": 2677693,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "'07, '08 now. This is '08."
    } ]
  }, {
    "tStartMs": 2682173,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "And so, we went back to..."
    } ]
  }, {
    "tStartMs": 2684693,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "After a lot of...\nthere is no distributor, how do we..."
    } ]
  }, {
    "tStartMs": 2688013,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "So, we went back to our fixed wireless."
    } ]
  }, {
    "tStartMs": 2689813,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "-Did you already make the inventory?\n-Huh?"
    } ]
  }, {
    "tStartMs": 2691533,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "-Did you already make the inventory?\n-Yeah, already it was with us."
    } ]
  }, {
    "tStartMs": 2695733,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "And we went back to our distributors\nof fixed wireless terminals,"
    } ]
  }, {
    "tStartMs": 2699893,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "payphone guys, who were selling payphones."
    } ]
  }, {
    "tStartMs": 2703293,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "We said, \"Now, we have this.\nWould you like to sell this?\""
    } ]
  }, {
    "tStartMs": 2706173,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "He said, \"Sir, give it to us, keep it,\nif it sells, we will see.\""
    } ]
  }, {
    "tStartMs": 2709013,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Because they were not\nthe mobile phone guys."
    } ]
  }, {
    "tStartMs": 2712333,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "We gave the phones to them."
    } ]
  }, {
    "tStartMs": 2716013,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Ten days, the phones were sold out."
    } ]
  }, {
    "tStartMs": 2719653,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "Why? Because of the differentiation.\nThere was nothing like that in the market."
    } ]
  }, {
    "tStartMs": 2722613,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "-Battery was the differentiation.\n-Yes."
    } ]
  }, {
    "tStartMs": 2725333,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Which you learnt from travelling\nto remote places."
    } ]
  }, {
    "tStartMs": 2727493,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Yes."
    } ]
  }, {
    "tStartMs": 2729173,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "And the form factor was nice,\nit was not bulky,"
    } ]
  }, {
    "tStartMs": 2732973,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "so we didn't try to change much\non the form factor and all."
    } ]
  }, {
    "tStartMs": 2738533,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "The repeat order started coming in.\nThat's the same--"
    } ]
  }, {
    "tStartMs": 2741973,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "And then everything went crazy.\nThings blew up, right?"
    } ]
  }, {
    "tStartMs": 2744533,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "-Things blew up.\n-I remember seeing Micromax everywhere."
    } ]
  }, {
    "tStartMs": 2747133,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Yeah, then things became crazy."
    } ]
  }, {
    "tStartMs": 2749133,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "And you started marketing like mad\nat this point, right?"
    } ]
  }, {
    "tStartMs": 2752013,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "No, so then we sat and said,\n\"Okay, what is it that we want to do?"
    } ]
  }, {
    "tStartMs": 2756373,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "And how do we want to do it?\""
    } ]
  }, {
    "tStartMs": 2758373,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Because there could be\na lot of distractions."
    } ]
  }, {
    "tStartMs": 2762053,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "So, and we were still learning\nat that stage,"
    } ]
  }, {
    "tStartMs": 2765213,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "it's not that we perfected,\nwe were still learning."
    } ]
  }, {
    "tStartMs": 2768813,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "So, one day I saw my cook\nusing three SIM cards."
    } ]
  }, {
    "tStartMs": 2772613,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "This is the time\nwhen all the new operators got license,"
    } ]
  }, {
    "tStartMs": 2776133,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "and everybody was selling\nnew schemes every day."
    } ]
  }, {
    "tStartMs": 2778133,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Uninor and all the new guys came in."
    } ]
  }, {
    "tStartMs": 2781293,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "So, I said,\n\"Why are you using three SIM cards?\""
    } ]
  }, {
    "tStartMs": 2782973,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "He said, \"Sir, one for local calling.\""
    } ]
  }, {
    "tStartMs": 2785293,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "I said, \"Fine. Second SIM card?\""
    } ]
  }, {
    "tStartMs": 2787213,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "He said, \"To call my native village.\""
    } ]
  }, {
    "tStartMs": 2789613,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "I said, \"Third SIM card?\""
    } ]
  }, {
    "tStartMs": 2791733,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "He said, \"Incoming is free,\nso I am not throwing it away.\""
    } ]
  }, {
    "tStartMs": 2795973,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "I went back to our guys and said,"
    } ]
  }, {
    "tStartMs": 2797453,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "\"Guys, why don't we make a phone\nwith a dual SIM card?\""
    } ]
  }, {
    "tStartMs": 2801213,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "They said, \"No, two phones\nonly rich people can afford.\""
    } ]
  }, {
    "tStartMs": 2804573,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "I said, \"That's not the consumer truth."
    } ]
  }, {
    "tStartMs": 2806293,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "These are the guys\nwho are using two phones."
    } ]
  }, {
    "tStartMs": 2809453,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "So, can we make\nin a single phone, you know,"
    } ]
  }, {
    "tStartMs": 2811853,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "simultaneously talking on the GSM signal?\""
    } ]
  }, {
    "tStartMs": 2815453,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "So, with one single baseband,\nwe created the dual SIM phone that time."
    } ]
  }, {
    "tStartMs": 2819853,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "And I still remember,\nI showcased it at one distributor meet,"
    } ]
  }, {
    "tStartMs": 2824533,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "and everybody stood\nand clapped, and they said, \"Sir...\""
    } ]
  }, {
    "tStartMs": 2828213,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "That was the time when we realised"
    } ]
  }, {
    "tStartMs": 2830093,
    "dDurationMs": 4480,
    "segs": [ {
      "utf8": "that we have to find the gaps\nin the market."
    } ]
  }, {
    "tStartMs": 2834653,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "It's very interesting.\nYou are finding your gaps"
    } ]
  }, {
    "tStartMs": 2836653,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "from your driver, your maid,\nfrom going to villages."
    } ]
  }, {
    "tStartMs": 2840053,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "Everyday life."
    } ]
  }, {
    "tStartMs": 2841373,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "It's like you are learning that,"
    } ]
  }, {
    "tStartMs": 2843373,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "you are just observing\nand then, you know, finding those gaps."
    } ]
  }, {
    "tStartMs": 2846333,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Do you see any gaps today?"
    } ]
  }, {
    "tStartMs": 2848413,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Multiple."
    } ]
  }, {
    "tStartMs": 2849493,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Name one, top of the list."
    } ]
  }, {
    "tStartMs": 2854093,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "I can go on and on,"
    } ]
  }, {
    "tStartMs": 2855733,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "but these are all different,\ndifferent ideas."
    } ]
  }, {
    "tStartMs": 2858773,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "I went crazy, I will tell you, you know,\nin that in terms of finding gaps."
    } ]
  }, {
    "tStartMs": 2861253,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "So, we said, okay, we want to make a..."
    } ]
  }, {
    "tStartMs": 2862733,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "So, that's how we made first phone\nfor girls with Swarovski."
    } ]
  }, {
    "tStartMs": 2866053,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "At that time,\nthe phones for girls in India"
    } ]
  }, {
    "tStartMs": 2868173,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "was only by Dolce \u0026 Gabbana, by Motorola."
    } ]
  }, {
    "tStartMs": 2870533,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "Now, how many people can afford\na Dolce \u0026 Gabbana in this country?"
    } ]
  }, {
    "tStartMs": 2874413,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "So, we made a phone,\nyou know, with Swarovski."
    } ]
  }, {
    "tStartMs": 2877773,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "Now, again, these very interesting\nconsumer stories here."
    } ]
  }, {
    "tStartMs": 2880373,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "We launched that phone\nbecause our team insisted,"
    } ]
  }, {
    "tStartMs": 2883293,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "\"No, this is Swarovski,\nit has to be expensive.\""
    } ]
  }, {
    "tStartMs": 2886493,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "And after a lot of, you know..."
    } ]
  }, {
    "tStartMs": 2890053,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "I said, \"No, just make it in the reach of,"
    } ]
  }, {
    "tStartMs": 2894413,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "let's say, common people.\""
    } ]
  }, {
    "tStartMs": 2895733,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "We priced at 5,000 rupees at that time."
    } ]
  }, {
    "tStartMs": 2898333,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Is that the way in India?"
    } ]
  }, {
    "tStartMs": 2899813,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "I remember watching an interview of yours\nwhen I was researching for today."
    } ]
  }, {
    "tStartMs": 2905293,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "When you were talking\nabout the form factor on your phone,"
    } ]
  }, {
    "tStartMs": 2907933,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "you said-- What was his name?"
    } ]
  }, {
    "tStartMs": 2910613,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "-Jesper?\n-[Carl] Yeah."
    } ]
  }, {
    "tStartMs": 2912493,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "He said that whenever\nyou look a product..."
    } ]
  }, {
    "tStartMs": 2915013,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "at a product for two seconds\nand look away and you have to draw it,"
    } ]
  }, {
    "tStartMs": 2919333,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "you should have\nthat one distinctive design element."
    } ]
  }, {
    "tStartMs": 2923293,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "That's a very different school of thought"
    } ]
  }, {
    "tStartMs": 2926133,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "from the more utilitarian school\nof thought here, right?"
    } ]
  }, {
    "tStartMs": 2929973,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "Is this what works for India\nand that works for the affluent?"
    } ]
  }, {
    "tStartMs": 2935053,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "No, see, this is a time\nwhen there were only feature phones,"
    } ]
  }, {
    "tStartMs": 2937413,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "-there were no smartphones.\n-[Nikhil] Right."
    } ]
  }, {
    "tStartMs": 2938893,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "So, how do you differentiate\nfeature phones?"
    } ]
  }, {
    "tStartMs": 2940413,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Right."
    } ]
  }, {
    "tStartMs": 2941533,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "I think we're at a stage in the industry\nwhere it's hyper-competitive."
    } ]
  }, {
    "tStartMs": 2944733,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "-Yes.\n-Every user need has been fully explored."
    } ]
  }, {
    "tStartMs": 2948293,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "Now, it is all evolved, like in laptops,\nit's already at the ceiling."
    } ]
  }, {
    "tStartMs": 2952453,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "-How will you... You can't reinvent.\n-Right."
    } ]
  }, {
    "tStartMs": 2956013,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "This was a time\nwhen everything was evolving."
    } ]
  }, {
    "tStartMs": 2957973,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "[Nikhil] Right."
    } ]
  }, {
    "tStartMs": 2959093,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "We're at a different maturity stage\nof the industry, I think."
    } ]
  }, {
    "tStartMs": 2961493,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "-[Rahul] Yes, yes.\n-Right. Right."
    } ]
  }, {
    "tStartMs": 2963293,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "The phone was also a dream\nwhen you came in."
    } ]
  }, {
    "tStartMs": 2966813,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Nobody had phones that time."
    } ]
  }, {
    "tStartMs": 2968013,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "2008, by then, a lot of people had phones."
    } ]
  }, {
    "tStartMs": 2971893,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Yeah, but the penetration was not high"
    } ]
  }, {
    "tStartMs": 2973373,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "because the GSM rates\nand everything was quite expensive."
    } ]
  }, {
    "tStartMs": 2976773,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "How big did it get in terms of numbers?"
    } ]
  }, {
    "tStartMs": 2979413,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "From selling 10,000 phones a month,"
    } ]
  }, {
    "tStartMs": 2983493,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "we were selling three million phones\na month."
    } ]
  }, {
    "tStartMs": 2987293,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "How big was the overall market\nat that time?"
    } ]
  }, {
    "tStartMs": 2990013,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Total market less than 100 million\nin India."
    } ]
  }, {
    "tStartMs": 2992893,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Put together, less than that."
    } ]
  }, {
    "tStartMs": 2994653,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "So, you were selling\n3% of the total market a month."
    } ]
  }, {
    "tStartMs": 2998853,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "-No, no, no.\n-[Amit] 20%?"
    } ]
  }, {
    "tStartMs": 3000533,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "[Rahul] No, no, no."
    } ]
  }, {
    "tStartMs": 3002013,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "-[Carl] A third?\n-No, no, no."
    } ]
  }, {
    "tStartMs": 3004533,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "When we were doing three million,"
    } ]
  }, {
    "tStartMs": 3006933,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "at that time, our market share\nwas around 25%, plus, plus."
    } ]
  }, {
    "tStartMs": 3011653,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "That's crazy."
    } ]
  }, {
    "tStartMs": 3013013,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "You were sponsoring cricket,"
    } ]
  }, {
    "tStartMs": 3015013,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "you were sponsoring everything\nback then, right?"
    } ]
  }, {
    "tStartMs": 3017253,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "Yes, so our big bet\nwas on cricket and music."
    } ]
  }, {
    "tStartMs": 3021173,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Because that's what the youth was into."
    } ]
  }, {
    "tStartMs": 3022693,
    "dDurationMs": 4480,
    "segs": [ {
      "utf8": "And you said, a blanket on whatever is..."
    } ]
  }, {
    "tStartMs": 3027253,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Yeah. And that worked also."
    } ]
  }, {
    "tStartMs": 3029693,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "-And this stayed for a while?\n-Yeah."
    } ]
  }, {
    "tStartMs": 3032493,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "For a couple of years?"
    } ]
  }, {
    "tStartMs": 3034373,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "-Yeah.\n-This crazy growth trajectory?"
    } ]
  }, {
    "tStartMs": 3036453,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Yes."
    } ]
  }, {
    "tStartMs": 3037693,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "Interestingly, we come back\nto our tariff questions,"
    } ]
  }, {
    "tStartMs": 3041253,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "the tariff conversation\nwe were having earlier,"
    } ]
  }, {
    "tStartMs": 3043493,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "because that kind of\nwas the problem, right?"
    } ]
  }, {
    "tStartMs": 3046853,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "The Chinese competition\nwhich came into India post."
    } ]
  }, {
    "tStartMs": 3049693,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "Yes, so that was a time..."
    } ]
  }, {
    "tStartMs": 3052933,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "And again, I will answer a couple\nof other questions"
    } ]
  }, {
    "tStartMs": 3054893,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "which you were asking about\nwhy you wanted to and all."
    } ]
  }, {
    "tStartMs": 3057693,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "So there were a lot of learnings also\nin between."
    } ]
  }, {
    "tStartMs": 3059733,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "So for example, when Meizu\nwas raising the round with Alibaba,"
    } ]
  }, {
    "tStartMs": 3064173,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "we were deep down\nwith Alibaba at that time."
    } ]
  }, {
    "tStartMs": 3066573,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Yeah. Raising the round and..."
    } ]
  }, {
    "tStartMs": 3068333,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "-So our paths have been intertwined.\n-Yes, and a pretty big one."
    } ]
  }, {
    "tStartMs": 3072133,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "At that time, we were raising, what,"
    } ]
  }, {
    "tStartMs": 3074253,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "around 800 million dollars\naround at that time."
    } ]
  }, {
    "tStartMs": 3076333,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "This is in 2000..."
    } ]
  }, {
    "tStartMs": 3077493,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "'14 and secondary, most of it."
    } ]
  }, {
    "tStartMs": 3080933,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "-Wow!\n-[laughter]"
    } ]
  }, {
    "tStartMs": 3084173,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "So it was because the business\nwas throwing so much of cash."
    } ]
  }, {
    "tStartMs": 3088133,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "-Right.\n-Yeah, so we said we don't need money,"
    } ]
  }, {
    "tStartMs": 3090373,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "but, you know, at that time,\neverybody wanted to connect."
    } ]
  }, {
    "tStartMs": 3093053,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "-You know, I remember...\n-You could buy a few more BMWs."
    } ]
  }, {
    "tStartMs": 3097093,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Few more than few more."
    } ]
  }, {
    "tStartMs": 3098253,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "[laughter]"
    } ]
  }, {
    "tStartMs": 3100133,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "So this was going well.\nAnd then we realised that..."
    } ]
  }, {
    "tStartMs": 3103853,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "So we didn't take that money."
    } ]
  }, {
    "tStartMs": 3105133,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "We said, \"Okay, no,\nwe are doing quite well.\""
    } ]
  }, {
    "tStartMs": 3106653,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "We said, \"We already have so much of...\""
    } ]
  }, {
    "tStartMs": 3109973,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Bad decision in hindsight?"
    } ]
  }, {
    "tStartMs": 3111653,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "So we thought that, you know,"
    } ]
  }, {
    "tStartMs": 3113773,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "if we have taken care of the Finnish\nand the Koreans at that time--"
    } ]
  }, {
    "tStartMs": 3118893,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Later on, because that time we never knew,"
    } ]
  }, {
    "tStartMs": 3120653,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "but in 2016-17, you know,\nthat was the time"
    } ]
  }, {
    "tStartMs": 3125133,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "when the, you know, the Chinese brands\nstarted coming in."
    } ]
  }, {
    "tStartMs": 3129213,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "So we thought, you know,\nwe have taken care of them."
    } ]
  }, {
    "tStartMs": 3131613,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "So we can, you know,\nwe'll take care of this also."
    } ]
  }, {
    "tStartMs": 3134413,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "It's okay. We'll go head on."
    } ]
  }, {
    "tStartMs": 3137853,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "But, you know, that was\na very, very different game."
    } ]
  }, {
    "tStartMs": 3142093,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "Because, you know, when the Chinese came,\nthey came up with so much of gunpowder."
    } ]
  }, {
    "tStartMs": 3146853,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "And you never know that\nwhere the gunpowder is coming from."
    } ]
  }, {
    "tStartMs": 3149533,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And whether there is an end to it or not."
    } ]
  }, {
    "tStartMs": 3152653,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "Do you think the government\nsubsidised them to come in that manner?"
    } ]
  }, {
    "tStartMs": 3155813,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "-Their government?\n-[Rahul] So... Yes."
    } ]
  }, {
    "tStartMs": 3157493,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "So there, as I said,\nyou never know, because, you know,"
    } ]
  }, {
    "tStartMs": 3159453,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "there were so many schemes\nwhich were running there."
    } ]
  }, {
    "tStartMs": 3162053,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "And not only the central level scheme,\nbut also the state level scheme."
    } ]
  }, {
    "tStartMs": 3164773,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "The companies were funded\nby the states also."
    } ]
  }, {
    "tStartMs": 3167893,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "So..."
    } ]
  }, {
    "tStartMs": 3169773,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "So we said, okay, we'll see."
    } ]
  }, {
    "tStartMs": 3171933,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "And then we started fighting."
    } ]
  }, {
    "tStartMs": 3173493,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "It was a price, you know,\nprice battle started going on."
    } ]
  }, {
    "tStartMs": 3177573,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "You know, when the Xiaomis of the world\nstarted coming in and then the..."
    } ]
  }, {
    "tStartMs": 3180573,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "So before that, we were fighting,\nlet's say, with the Samsungs"
    } ]
  }, {
    "tStartMs": 3183613,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "and the Motos\nor the Sony Ericssons of the world."
    } ]
  }, {
    "tStartMs": 3189093,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Doing pretty well."
    } ]
  }, {
    "tStartMs": 3190853,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "And then you start...\nsuddenly you start having a competition"
    } ]
  }, {
    "tStartMs": 3193493,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "wherein if you are selling, let's say,\nat 100 rupees,"
    } ]
  }, {
    "tStartMs": 3197773,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "somebody comes and says,\nhey, I'm 90 rupees."
    } ]
  }, {
    "tStartMs": 3201333,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "[Nikhil] And if you say 80,\nthey'll say 70."
    } ]
  }, {
    "tStartMs": 3203093,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "[Rahul] They'll say 70.\nSo that's how it's a race to the bottom."
    } ]
  }, {
    "tStartMs": 3205493,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "And then suddenly\nthey were burning a lot of money."
    } ]
  }, {
    "tStartMs": 3209533,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "-But can I ask a structural question?\n-Yes. Yes."
    } ]
  }, {
    "tStartMs": 3212733,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "While it seems like a race to the bottom,"
    } ]
  }, {
    "tStartMs": 3216173,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "because of the scale of manufacturing\nthey have,"
    } ]
  }, {
    "tStartMs": 3219893,
    "dDurationMs": 5240,
    "segs": [ {
      "utf8": "is the cost of production in China\ninherently so much lower"
    } ]
  }, {
    "tStartMs": 3225213,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "that at 80 rupees you can't make money,\nbut at 70 rupees they can?"
    } ]
  }, {
    "tStartMs": 3229213,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "So that's, yeah, that's true,\nbecause it's the whole supply chain"
    } ]
  }, {
    "tStartMs": 3233573,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "which is, you know,\nwhich is established there."
    } ]
  }, {
    "tStartMs": 3236333,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "So probably what we were discussing."
    } ]
  }, {
    "tStartMs": 3238293,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "That if their BOM is 100, your BOM is 120."
    } ]
  }, {
    "tStartMs": 3243173,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "But you would also be importing\nthat time or manufacturing?"
    } ]
  }, {
    "tStartMs": 3246813,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "No. So, see, we established\nour first plant in India in 2010."
    } ]
  }, {
    "tStartMs": 3251213,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "-So you started early.\n-Way before Make In India started."
    } ]
  }, {
    "tStartMs": 3254453,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "So, but the components\nwas coming from there, right?"
    } ]
  }, {
    "tStartMs": 3258053,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "And at that time, all these brands\nwhat we see right now,"
    } ]
  }, {
    "tStartMs": 3261493,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "they were not there."
    } ]
  }, {
    "tStartMs": 3262733,
    "dDurationMs": 4880,
    "segs": [ {
      "utf8": "So they started coming in, for example,\nall the brands were there in DVD players"
    } ]
  }, {
    "tStartMs": 3267693,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "or MP3 players, and then they started\ncoming on that."
    } ]
  }, {
    "tStartMs": 3271933,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "And then the price war started."
    } ]
  }, {
    "tStartMs": 3273773,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "And so, and we also went into it."
    } ]
  }, {
    "tStartMs": 3279293,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "But somehow with the whole supply chain\nand everything, then you slowly,"
    } ]
  }, {
    "tStartMs": 3282813,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "you know, access to all these things\nstarted getting restricted."
    } ]
  }, {
    "tStartMs": 3286933,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "So, for example,\nwhy Micromax became successful?"
    } ]
  }, {
    "tStartMs": 3289453,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "Because in this...\nin the industry where we are in,"
    } ]
  }, {
    "tStartMs": 3292373,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "you are already, you know,\nyou're looking for a differentiation."
    } ]
  }, {
    "tStartMs": 3294293,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "For example, if I was designing a phone,\nmy question to myself was:"
    } ]
  }, {
    "tStartMs": 3296973,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Why will I buy,\nor somebody will buy this phone?"
    } ]
  }, {
    "tStartMs": 3299133,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "What is different in this one? Why?"
    } ]
  }, {
    "tStartMs": 3301333,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Why..."
    } ]
  }, {
    "tStartMs": 3302693,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Why somebody will not buy another phone?"
    } ]
  }, {
    "tStartMs": 3304493,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "So, you know, that's how\nthe differentiators were coming in."
    } ]
  }, {
    "tStartMs": 3308093,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "And differentiator\nwas not only on the feature,"
    } ]
  }, {
    "tStartMs": 3310213,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "but also on who's going to come up\nwith the latest chipset first."
    } ]
  }, {
    "tStartMs": 3313733,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Who's going to come up with--\nIf there is a 50 megapixel camera,"
    } ]
  }, {
    "tStartMs": 3315733,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "who's the first guy coming up\nwith a 50 megapixel camera?"
    } ]
  }, {
    "tStartMs": 3318853,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "If there was a fast charging coming,"
    } ]
  }, {
    "tStartMs": 3320773,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "who's the first guy\nto come up with fast charging?"
    } ]
  }, {
    "tStartMs": 3322453,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "And the distributors used to look at,\nyou know, look at us that,"
    } ]
  }, {
    "tStartMs": 3325453,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "okay, they will come up\nwith something new every quarter and..."
    } ]
  }, {
    "tStartMs": 3329933,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "So when that access\nstarted getting stopped?"
    } ]
  }, {
    "tStartMs": 3332013,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Government stopped the access?"
    } ]
  }, {
    "tStartMs": 3333813,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "No, no, it's not the government, you know,\nbecause the scale shifted somewhere else."
    } ]
  }, {
    "tStartMs": 3338133,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Right."
    } ]
  }, {
    "tStartMs": 3339213,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "And they preferred supplying\nto their own companies than to you?"
    } ]
  }, {
    "tStartMs": 3342973,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "Right. And so the numbers and everything,"
    } ]
  }, {
    "tStartMs": 3348253,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "because their numbers\nstarted growing up in..."
    } ]
  }, {
    "tStartMs": 3350053,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Because China itself\nbecame a very big market"
    } ]
  }, {
    "tStartMs": 3352013,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "and the scale was, you know, became big."
    } ]
  }, {
    "tStartMs": 3353973,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Because, you know,\nthere are a lot of theories about..."
    } ]
  }, {
    "tStartMs": 3356173,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "about Micromax in the market."
    } ]
  }, {
    "tStartMs": 3357813,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "This happened, that happened.\nEverybody can come up with their own."
    } ]
  }, {
    "tStartMs": 3360773,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Yeah. What is the theory...\nthe most popular one?"
    } ]
  }, {
    "tStartMs": 3362933,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "No, I keep on hearing different one."
    } ]
  }, {
    "tStartMs": 3364493,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "Oh, they went, you know,\ninto luxury segment"
    } ]
  }, {
    "tStartMs": 3367853,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "or there was no R\u0026D. You know, all this."
    } ]
  }, {
    "tStartMs": 3371573,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "But I don't know\nhow many people know, we..."
    } ]
  }, {
    "tStartMs": 3373293,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "When Nokia got sold, we had the..."
    } ]
  }, {
    "tStartMs": 3375653,
    "dDurationMs": 4480,
    "segs": [ {
      "utf8": "You know, we took all the top Nokia,\nthey had the gold, you know, division."
    } ]
  }, {
    "tStartMs": 3380213,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "We got all gold guys from Nokia\nand doing the R\u0026D at that time."
    } ]
  }, {
    "tStartMs": 3383213,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "But whatever this was happening,\nall this, you know, coming from China,"
    } ]
  }, {
    "tStartMs": 3387333,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "it was a global phenomenon."
    } ]
  }, {
    "tStartMs": 3388613,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "So it was not only that we were affected."
    } ]
  }, {
    "tStartMs": 3390733,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "All the other, let's say,\nthere were other brands"
    } ]
  }, {
    "tStartMs": 3392733,
    "dDurationMs": 4920,
    "segs": [ {
      "utf8": "in Turkey or in Malaysia,"
    } ]
  }, {
    "tStartMs": 3397733,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "other places,\nyou know, everybody got affected."
    } ]
  }, {
    "tStartMs": 3400813,
    "dDurationMs": 6600,
    "segs": [ {
      "utf8": "And I think in 2019 odd or so,\nwe realised that, you know,"
    } ]
  }, {
    "tStartMs": 3407493,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "you can burn money,\nbut you know, you can burn money"
    } ]
  }, {
    "tStartMs": 3410013,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "till the point you know\nthat I'm going to win the game."
    } ]
  }, {
    "tStartMs": 3412293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Right."
    } ]
  }, {
    "tStartMs": 3413373,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "But if the other person is having\nan unlimited supplies,"
    } ]
  }, {
    "tStartMs": 3417493,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "like a bottomless pit."
    } ]
  }, {
    "tStartMs": 3419173,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "A bit like today, no?\nAll the loss-making startups in India,"
    } ]
  }, {
    "tStartMs": 3423533,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "all competing downwards."
    } ]
  }, {
    "tStartMs": 3425453,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 3427333,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "And see, and we build Micromax,\nlet's say, from day one, making money"
    } ]
  }, {
    "tStartMs": 3431853,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "and doing that, you know,\nnever raised any capital."
    } ]
  }, {
    "tStartMs": 3435893,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "Slowly, slowly, you know, build it\nand whatever, you know, we raised."
    } ]
  }, {
    "tStartMs": 3439493,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "Said no to $800 million in 2014."
    } ]
  }, {
    "tStartMs": 3442813,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "-So if you ask me in hindsight that.\n-You should have taken it."
    } ]
  }, {
    "tStartMs": 3446573,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Yeah, because see, that time we never knew\nthat you had to create a war chest."
    } ]
  }, {
    "tStartMs": 3449413,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "[Nikhil] Yeah."
    } ]
  }, {
    "tStartMs": 3451413,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "You create a war chest\nand say, \"Okay, now let's, you know--\""
    } ]
  }, {
    "tStartMs": 3454013,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Biggest bull run in Indian equity markets.\nImagine you put that in equity."
    } ]
  }, {
    "tStartMs": 3458013,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "2014 to today."
    } ]
  }, {
    "tStartMs": 3459573,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Yeah. So, you know, with $800 million,"
    } ]
  }, {
    "tStartMs": 3461253,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "you sit on the casino table\nand say, okay, now play."
    } ]
  }, {
    "tStartMs": 3463133,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "-Yeah.\n-[Carl] Yeah."
    } ]
  }, {
    "tStartMs": 3465933,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Yeah, so, and then after..."
    } ]
  }, {
    "tStartMs": 3468533,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Yeah, in 2009,\nthen we realised that, you know,"
    } ]
  }, {
    "tStartMs": 3470813,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "either we'll, you know,\nif we keep on burning with this space,"
    } ]
  }, {
    "tStartMs": 3473693,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "we will get finished."
    } ]
  }, {
    "tStartMs": 3475093,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "We'll get completely burned out."
    } ]
  }, {
    "tStartMs": 3476533,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "We will not have any capital left."
    } ]
  }, {
    "tStartMs": 3479253,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "So we said,\n\"Okay, let's stop burning money."
    } ]
  }, {
    "tStartMs": 3481973,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "And wait for your turn."
    } ]
  }, {
    "tStartMs": 3484933,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "And start focusing on manufacturing.\""
    } ]
  }, {
    "tStartMs": 3487693,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "And that's how\nwe started building more factories"
    } ]
  }, {
    "tStartMs": 3491813,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "in 19, 20, 21, and now."
    } ]
  }, {
    "tStartMs": 3497493,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "And that's how we, you know,\npivoted on the manufacturing game."
    } ]
  }, {
    "tStartMs": 3502213,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "And the whole idea is that unless\nand until you have access to supply chain."
    } ]
  }, {
    "tStartMs": 3506613,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "For example, if today I have to make\na triple screen fold..."
    } ]
  }, {
    "tStartMs": 3513573,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "I don't have access to the screen."
    } ]
  }, {
    "tStartMs": 3516013,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "So how do you come up with the latest?"
    } ]
  }, {
    "tStartMs": 3517253,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "-When you say access to supply chain...\n-Yes."
    } ]
  }, {
    "tStartMs": 3519733,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "...you're talking about\nthe company in China that gives--"
    } ]
  }, {
    "tStartMs": 3522453,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "That makes the screen. Okay?"
    } ]
  }, {
    "tStartMs": 3523933,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "That makes the display."
    } ]
  }, {
    "tStartMs": 3525173,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "But the other bigger company there,"
    } ]
  }, {
    "tStartMs": 3527053,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "for example, let's say Huawei,\nhas a triple screen."
    } ]
  }, {
    "tStartMs": 3529013,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Huawei has already blocked that"
    } ]
  }, {
    "tStartMs": 3530093,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "and said, \"Okay, for one year\nyou can't give to anybody else."
    } ]
  }, {
    "tStartMs": 3532613,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "Because I am promising you\nthis much of volume.\""
    } ]
  }, {
    "tStartMs": 3535013,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "So, Nikhil,\nhow it happens is all partners,"
    } ]
  }, {
    "tStartMs": 3538973,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "like supply chain partners,\nscreen, battery, or processor,"
    } ]
  }, {
    "tStartMs": 3542533,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "they work with bigger brands,"
    } ]
  }, {
    "tStartMs": 3544013,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "and everybody has an alpha customer\non their list."
    } ]
  }, {
    "tStartMs": 3546293,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Let's say Huawei would be\nthe alpha customer on the list."
    } ]
  }, {
    "tStartMs": 3549133,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "So every first technology\nwould go to Huawei."
    } ]
  }, {
    "tStartMs": 3552213,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "He will block the capacity,\nand when it is over, it will come to us."
    } ]
  }, {
    "tStartMs": 3555813,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "New technology means all resources\nthey will depute to Huawei."
    } ]
  }, {
    "tStartMs": 3559013,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "And then it will come to the market,"
    } ]
  }, {
    "tStartMs": 3560413,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "and Huawei will take the first leg\nof new product, which is launching,"
    } ]
  }, {
    "tStartMs": 3564253,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "which goes for chipsets,\nscreens, sensor, across."
    } ]
  }, {
    "tStartMs": 3568013,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "But we will never be able to make that\non our own."
    } ]
  }, {
    "tStartMs": 3570733,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "For anybody wanting to start\na consumer electronic company,"
    } ]
  }, {
    "tStartMs": 3575493,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "you can't make that triple-fold screen"
    } ]
  }, {
    "tStartMs": 3577733,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "that this supply chain vendor\nis making for Huawei."
    } ]
  }, {
    "tStartMs": 3581573,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "No, if you are, like, a \"startup\" startup,\nit is too hard to make."
    } ]
  }, {
    "tStartMs": 3585533,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "It requires a lot of money and probably--"
    } ]
  }, {
    "tStartMs": 3587173,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "[Amit] He might be making it."
    } ]
  }, {
    "tStartMs": 3588813,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "-It's at a later stage.\n-He can answer."
    } ]
  }, {
    "tStartMs": 3589973,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "-Yes, later stage.\n-It's at a later stage."
    } ]
  }, {
    "tStartMs": 3591813,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "So if you look at Apple's strategy now,"
    } ]
  }, {
    "tStartMs": 3593933,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "they feel like they're bleeding\ntoo much margin to their suppliers."
    } ]
  }, {
    "tStartMs": 3597013,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "-[Amit] Yeah.\n-So they're doing vertical integration."
    } ]
  }, {
    "tStartMs": 3598853,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "So they are developing\ntheir own technology,"
    } ]
  }, {
    "tStartMs": 3600853,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "their own screen,\ntheir own whatever processor."
    } ]
  }, {
    "tStartMs": 3602773,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "I thought they're outsourcing more\nto Foxconn and--"
    } ]
  }, {
    "tStartMs": 3605693,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "-For manufacturing.\n-It's only for EMS."
    } ]
  }, {
    "tStartMs": 3607573,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "-What is EMS?\n-Assembling."
    } ]
  }, {
    "tStartMs": 3609413,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "-You would attempt better.\n-Just for assembling?"
    } ]
  }, {
    "tStartMs": 3612213,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "-Really?\n-[Rahul] Yes."
    } ]
  }, {
    "tStartMs": 3613453,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "So Apple used to be\na consumer-focused company, right?"
    } ]
  }, {
    "tStartMs": 3616253,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "So in the start, they were very small."
    } ]
  }, {
    "tStartMs": 3618373,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "They were competing against IBM,\nand, like, big PC companies."
    } ]
  }, {
    "tStartMs": 3621893,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "So they targeted a niche consumer,\nthe creative consumer."
    } ]
  }, {
    "tStartMs": 3625613,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "And they positioned the personal computer\nas a bicycle for the mind."
    } ]
  }, {
    "tStartMs": 3628653,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "So if you have an idea,"
    } ]
  }, {
    "tStartMs": 3629733,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "you can use your Apple computer\nto manifest that idea."
    } ]
  }, {
    "tStartMs": 3632973,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "In the '90s,\nthey started acquiring software companies"
    } ]
  }, {
    "tStartMs": 3636133,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "to then create their own suite\nof content creation tools"
    } ]
  }, {
    "tStartMs": 3638693,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "like iMovie, GarageBand."
    } ]
  }, {
    "tStartMs": 3641373,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "It's all to cater to the creative, right?"
    } ]
  }, {
    "tStartMs": 3642973,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Beautiful industrial design,"
    } ]
  }, {
    "tStartMs": 3644493,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "great software that helps you\ntake your ideas into reality."
    } ]
  }, {
    "tStartMs": 3648653,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "After some time,\nthey really captured the creatives."
    } ]
  }, {
    "tStartMs": 3651573,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "-Like, they had a partnership with Adobe.\n-Yeah."
    } ]
  }, {
    "tStartMs": 3654733,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Adobe worked better on Apple computers."
    } ]
  }, {
    "tStartMs": 3657413,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "So once they got the creatives,\nthe brand became really cool."
    } ]
  }, {
    "tStartMs": 3660573,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "So normal people,\nthey also wanted to feel creative."
    } ]
  }, {
    "tStartMs": 3663653,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "So therefore,\n\"I buy Apples 'cause I'm a creative.\""
    } ]
  }, {
    "tStartMs": 3666933,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "But then..."
    } ]
  }, {
    "tStartMs": 3668253,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "So they won the consumer battle."
    } ]
  }, {
    "tStartMs": 3669693,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "And then to keep growing the share price,"
    } ]
  }, {
    "tStartMs": 3672653,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "they needed to take the value\nback from their suppliers"
    } ]
  }, {
    "tStartMs": 3674933,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "'cause they had outsourced\na lot of the components."
    } ]
  }, {
    "tStartMs": 3678013,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "So in the recent ten years,\nit's been a vertical integration strategy."
    } ]
  }, {
    "tStartMs": 3681813,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Now they do their own processors."
    } ]
  }, {
    "tStartMs": 3683173,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "Actually, what we talked about before,\nthey get the TSMC latest..."
    } ]
  }, {
    "tStartMs": 3687573,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "There you need allocation."
    } ]
  }, {
    "tStartMs": 3688893,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Yeah, they get the first batch\nbefore everybody else."
    } ]
  }, {
    "tStartMs": 3691733,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "They get the latest technology from TSMC\nfor Apple silicon."
    } ]
  }, {
    "tStartMs": 3695293,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Now they're doing a mini...\nIs it mini-LED or micro-LED?"
    } ]
  }, {
    "tStartMs": 3698493,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "They have their own display technology."
    } ]
  }, {
    "tStartMs": 3701253,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "It's deployed on the Apple Watch already."
    } ]
  }, {
    "tStartMs": 3702893,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "The mini-LED."
    } ]
  }, {
    "tStartMs": 3704413,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[Carl] Mini-LED."
    } ]
  }, {
    "tStartMs": 3705493,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "So it's very hard\nfor anyone to compete, right?"
    } ]
  }, {
    "tStartMs": 3707653,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "It's a very tough industry."
    } ]
  }, {
    "tStartMs": 3710133,
    "dDurationMs": 6080,
    "segs": [ {
      "utf8": "And everybody who is an incumbent today\nhas been around for 30, 40, 50, 100 years?"
    } ]
  }, {
    "tStartMs": 3717213,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "Apple is, like, 50, I think. 50-ish."
    } ]
  }, {
    "tStartMs": 3720133,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "-Samsung is older.\n-Yeah."
    } ]
  }, {
    "tStartMs": 3722533,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "But Samsung's smartphone business\nshould be similar, maybe 25 years."
    } ]
  }, {
    "tStartMs": 3727453,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "The Chinese brand, maybe 15 years."
    } ]
  }, {
    "tStartMs": 3730053,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "So every ten years, the cards will flip."
    } ]
  }, {
    "tStartMs": 3734733,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "[Rahul] Yeah, so I think\nthis is a very interesting thing..."
    } ]
  }, {
    "tStartMs": 3738493,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "if you're talking about competing,\nor nobody can come up."
    } ]
  }, {
    "tStartMs": 3742493,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "-We came up at that time.\n-[Nikhil] Yeah."
    } ]
  }, {
    "tStartMs": 3744173,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Defying the odds, you know."
    } ]
  }, {
    "tStartMs": 3745413,
    "dDurationMs": 5560,
    "segs": [ {
      "utf8": "Globally there was, you know, no brand,\nlike a local brand who came and became..."
    } ]
  }, {
    "tStartMs": 3751053,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "Like, we were top ten in the world,\nand that's how it was going."
    } ]
  }, {
    "tStartMs": 3755413,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "I still feel that can happen. Right?"
    } ]
  }, {
    "tStartMs": 3759013,
    "dDurationMs": 5880,
    "segs": [ {
      "utf8": "But we never realised that governments\nhave to, you know, play a role in it."
    } ]
  }, {
    "tStartMs": 3764973,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Because at that time we never thought\nabout the governments and the countries."
    } ]
  }, {
    "tStartMs": 3767653,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Now we realise about countries,\ngovernments, and everything."
    } ]
  }, {
    "tStartMs": 3770493,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "-What should the government do?\n-Yeah."
    } ]
  }, {
    "tStartMs": 3772893,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "For example,\nyou take our automobile industry in India."
    } ]
  }, {
    "tStartMs": 3777613,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "I think we have done a great job there."
    } ]
  }, {
    "tStartMs": 3779693,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "All the Hondas and Suzukis came initially,"
    } ]
  }, {
    "tStartMs": 3782893,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "did joint ventures\nwith the Indian companies."
    } ]
  }, {
    "tStartMs": 3786493,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "Created a lot of ecosystem\nof supply chain."
    } ]
  }, {
    "tStartMs": 3789373,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "-You see all the component players.\n-Yeah."
    } ]
  }, {
    "tStartMs": 3792013,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Right?"
    } ]
  }, {
    "tStartMs": 3793093,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "And now if you see\nour automobile industry,"
    } ]
  }, {
    "tStartMs": 3795293,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "we are supplying to the world now."
    } ]
  }, {
    "tStartMs": 3797773,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "We are a very mature industry\nin automobile."
    } ]
  }, {
    "tStartMs": 3799693,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "And if the same thing were true\nfor mobile phones,"
    } ]
  }, {
    "tStartMs": 3801893,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "what happened to Micromax\nwould not have happened."
    } ]
  }, {
    "tStartMs": 3804653,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "Maybe, you know,\nthe world order would have been different"
    } ]
  }, {
    "tStartMs": 3807653,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "in terms of the brands."
    } ]
  }, {
    "tStartMs": 3808893,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "-Right.\n-Yeah."
    } ]
  }, {
    "tStartMs": 3810053,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "So, any industry, you need to see\nthat you want to make local champions."
    } ]
  }, {
    "tStartMs": 3813693,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "So for example,\ntoday in the worldly order,"
    } ]
  }, {
    "tStartMs": 3816533,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "imagine if there are two, three\nlocal champions coming out of India"
    } ]
  }, {
    "tStartMs": 3821733,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "who can make a global impact."
    } ]
  }, {
    "tStartMs": 3823653,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "I think it would be great for the country."
    } ]
  }, {
    "tStartMs": 3825013,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "[Nikhil] But if we..."
    } ]
  }, {
    "tStartMs": 3826333,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "There's a flip side to that argument"
    } ]
  }, {
    "tStartMs": 3827653,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "that if we become protectionist\nof local industry..."
    } ]
  }, {
    "tStartMs": 3831333,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "do we continue to get foreign money\ninto the country?"
    } ]
  }, {
    "tStartMs": 3835933,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "So I'm not saying that you stop."
    } ]
  }, {
    "tStartMs": 3838013,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "I'm saying you allow collaborations."
    } ]
  }, {
    "tStartMs": 3841613,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Collaborations where you need to learn."
    } ]
  }, {
    "tStartMs": 3843933,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "-Collaborations with technology transfer.\n-[Rahul] Absolutely."
    } ]
  }, {
    "tStartMs": 3846053,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "-IP transfer.\n-Yes."
    } ]
  }, {
    "tStartMs": 3847533,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Work on IP transfer, and then you learn."
    } ]
  }, {
    "tStartMs": 3849613,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "So in four, five years, you will learn."
    } ]
  }, {
    "tStartMs": 3852973,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Right? See, I said,\n\"Auto happened, you know, at that time.\""
    } ]
  }, {
    "tStartMs": 3855533,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Now today you have all the local companies\nruling the roost."
    } ]
  }, {
    "tStartMs": 3858853,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "Similarly, you learn here,\nfive years, six years."
    } ]
  }, {
    "tStartMs": 3861493,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "So, a lot of people ask me,\n\"Okay, can you do this?"
    } ]
  }, {
    "tStartMs": 3864053,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Can you make a, you know,\nvery complex phone?\""
    } ]
  }, {
    "tStartMs": 3866413,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "We said,\n\"Yes, we can make a very complex phone."
    } ]
  }, {
    "tStartMs": 3868253,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "But maybe it will take five years,\nsix years in India to do that."
    } ]
  }, {
    "tStartMs": 3871413,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "But with collaboration,\nI can start learning right away."
    } ]
  }, {
    "tStartMs": 3874093,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "And then can do it very, very quickly.\""
    } ]
  }, {
    "tStartMs": 3876053,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "And how much did this three million phones\na number fall to"
    } ]
  }, {
    "tStartMs": 3880253,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "when things went bad at Micromax?"
    } ]
  }, {
    "tStartMs": 3882013,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "No, no, it totally started coming."
    } ]
  }, {
    "tStartMs": 3883213,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Every year it started coming up,\nwe started losing."
    } ]
  }, {
    "tStartMs": 3885373,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "At that time,"
    } ]
  }, {
    "tStartMs": 3886493,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "all the Indian brands were more than 50%\nof the Indian market share."
    } ]
  }, {
    "tStartMs": 3889533,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "-Right. Right.\n-Which completely got decimated."
    } ]
  }, {
    "tStartMs": 3892373,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "What was the low for Micromax\nas a company?"
    } ]
  }, {
    "tStartMs": 3894893,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Which year was the low?"
    } ]
  }, {
    "tStartMs": 3896573,
    "dDurationMs": 6560,
    "segs": [ {
      "utf8": "I think that time in 2019, 2020,\nin terms of the brand--"
    } ]
  }, {
    "tStartMs": 3903213,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "-Just before COVID.\n-Yeah."
    } ]
  }, {
    "tStartMs": 3904813,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "-We said, \"Okay, no more...\"\n-And then COVID could not have been fun."
    } ]
  }, {
    "tStartMs": 3907253,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "[laughter]"
    } ]
  }, {
    "tStartMs": 3909853,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "-Right?\n-Yeah."
    } ]
  }, {
    "tStartMs": 3912533,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "When you go from a peak to a low,\nwhat is the one lesson that we can learn"
    } ]
  }, {
    "tStartMs": 3917653,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "from your experience\nthat you have learnt already?"
    } ]
  }, {
    "tStartMs": 3920213,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Today, our manufacturing is bigger than,\nyou know,"
    } ]
  }, {
    "tStartMs": 3922573,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "the revenue is way more bigger\nthan what we used to do in our brand."
    } ]
  }, {
    "tStartMs": 3925573,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Which probably\nnot most of the people will know."
    } ]
  }, {
    "tStartMs": 3928133,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "But we are doing way more better\nthan what we used to do earlier."
    } ]
  }, {
    "tStartMs": 3931293,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "No, I know the Micromax comebacks."
    } ]
  }, {
    "tStartMs": 3932613,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "No, I know. But I am coming."
    } ]
  }, {
    "tStartMs": 3934413,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "So, in between, you know,\nyou are trying multiple things."
    } ]
  }, {
    "tStartMs": 3938293,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "I think what has worked for us,\nyou know, we later realised that,"
    } ]
  }, {
    "tStartMs": 3941653,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "stick to your core."
    } ]
  }, {
    "tStartMs": 3943173,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "What did you realise is your core?"
    } ]
  }, {
    "tStartMs": 3944933,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "So my core was to remain with tech."
    } ]
  }, {
    "tStartMs": 3947813,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So, for example,\nI'll not start a real estate company."
    } ]
  }, {
    "tStartMs": 3949733,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Real estate is doing good, go there."
    } ]
  }, {
    "tStartMs": 3951453,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Or something else is doing good, go there."
    } ]
  }, {
    "tStartMs": 3953053,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Or something."
    } ]
  }, {
    "tStartMs": 3954293,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So this thing was already there."
    } ]
  }, {
    "tStartMs": 3956653,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "The whole manufacturing,\nthe factories what we created,"
    } ]
  }, {
    "tStartMs": 3958853,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "you know, for Micromax, was already there."
    } ]
  }, {
    "tStartMs": 3960453,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "So why don't we build on that?"
    } ]
  }, {
    "tStartMs": 3966253,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "And start doing for others."
    } ]
  }, {
    "tStartMs": 3968413,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "That helped, and that's how we..."
    } ]
  }, {
    "tStartMs": 3970173,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "So at Micromax time,"
    } ]
  }, {
    "tStartMs": 3971373,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "we were having probably\none or two factories."
    } ]
  }, {
    "tStartMs": 3973573,
    "dDurationMs": 4480,
    "segs": [ {
      "utf8": "Now, we have four large factories,\nfifth coming up, and then--"
    } ]
  }, {
    "tStartMs": 3978133,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "You just acquired a new factory as well."
    } ]
  }, {
    "tStartMs": 3979973,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "And now you are scaling."
    } ]
  }, {
    "tStartMs": 3982973,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "Do you feel like you are stronger\nthe second time around"
    } ]
  }, {
    "tStartMs": 3985613,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "than you were in the beginning?"
    } ]
  }, {
    "tStartMs": 3987933,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Less oblivious, more aware."
    } ]
  }, {
    "tStartMs": 3991693,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Like, I feel like\nonce somebody is scarred,"
    } ]
  }, {
    "tStartMs": 3995013,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "the next time they're a little bit\nmore differentiated in their approach."
    } ]
  }, {
    "tStartMs": 3999493,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "This weekend I was thinking that."
    } ]
  }, {
    "tStartMs": 4001893,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "-Believe me.\n-In Goa?"
    } ]
  }, {
    "tStartMs": 4003413,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Yeah. [chuckles]"
    } ]
  }, {
    "tStartMs": 4005533,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "I was thinking about that."
    } ]
  }, {
    "tStartMs": 4007493,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "About something I used to do earlier."
    } ]
  }, {
    "tStartMs": 4010693,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "And then I again thought,\n\"I am still doing the same thing.\""
    } ]
  }, {
    "tStartMs": 4013973,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Which is?"
    } ]
  }, {
    "tStartMs": 4015133,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "Taking big bets, going risky, and all."
    } ]
  }, {
    "tStartMs": 4018493,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "Like, you know, once you start doing,\nI said, \"Okay, no, no, no more, no more."
    } ]
  }, {
    "tStartMs": 4023493,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Stick, stick to your, you know...\""
    } ]
  }, {
    "tStartMs": 4025693,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "-But--\n-Risk is intoxicating, no?"
    } ]
  }, {
    "tStartMs": 4028413,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "It is."
    } ]
  }, {
    "tStartMs": 4029533,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "While you are taking it?"
    } ]
  }, {
    "tStartMs": 4030813,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 4031933,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "-It gives you a high?\n-Yeah."
    } ]
  }, {
    "tStartMs": 4034613,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "And believe that, \"Okay, no, no, no,"
    } ]
  }, {
    "tStartMs": 4035813,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "this is something I think you can do,\nyou can crack it.\""
    } ]
  }, {
    "tStartMs": 4039093,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "And then you go for it."
    } ]
  }, {
    "tStartMs": 4041293,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "And because it has worked earlier,\nthen you start thinking."
    } ]
  }, {
    "tStartMs": 4043533,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Then you know every time\nit is going to work,"
    } ]
  }, {
    "tStartMs": 4045213,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "which is not the case."
    } ]
  }, {
    "tStartMs": 4048693,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "So, yes, while, you know,\nwe are doing this, I am more aware."
    } ]
  }, {
    "tStartMs": 4052373,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "But the core is that, nah?"
    } ]
  }, {
    "tStartMs": 4054773,
    "dDurationMs": 5160,
    "segs": [ {
      "utf8": "So once your core is that,\nyou will want to take bigger bets,"
    } ]
  }, {
    "tStartMs": 4060013,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "thinking that,\n\"Okay, nothing happened earlier."
    } ]
  }, {
    "tStartMs": 4062773,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "You know, you came out of it, see?\""
    } ]
  }, {
    "tStartMs": 4066413,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "So I think that's the DNA."
    } ]
  }, {
    "tStartMs": 4067853,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "As long as the bets don't go wrong,\nthey always get bigger,"
    } ]
  }, {
    "tStartMs": 4071093,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "-organically.\n-Yeah."
    } ]
  }, {
    "tStartMs": 4072573,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "If you had to bet money\non some entrepreneur today,"
    } ]
  }, {
    "tStartMs": 4077333,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "wouldn't you pick somebody\nwho has screwed up a couple of times"
    } ]
  }, {
    "tStartMs": 4080013,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "versus somebody\nwho is doing it for the first time?"
    } ]
  }, {
    "tStartMs": 4084173,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Screwed up a couple of times,\nbut eventually made it."
    } ]
  }, {
    "tStartMs": 4086453,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "-Yeah, that is important.\n-[Nikhil] Yeah."
    } ]
  }, {
    "tStartMs": 4088493,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 4089893,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "If eventually made it,\nthen, yeah, that's fine."
    } ]
  }, {
    "tStartMs": 4092413,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "I feel like this prophecy is true\nfor all life."
    } ]
  }, {
    "tStartMs": 4096613,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "I like people\nwho are a little bit screwed up"
    } ]
  }, {
    "tStartMs": 4100333,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "in all domains."
    } ]
  }, {
    "tStartMs": 4102133,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "When I meet a man\nand I don't know what his vice is,"
    } ]
  }, {
    "tStartMs": 4105013,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "I assume the worst."
    } ]
  }, {
    "tStartMs": 4106813,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "I'd rather know, \"Okay, this is my friend,\nhe is [bleep] up like this, I am aware."
    } ]
  }, {
    "tStartMs": 4110053,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "I am [bleep] up like that, he is aware.\""
    } ]
  }, {
    "tStartMs": 4111973,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "This friendship is good."
    } ]
  }, {
    "tStartMs": 4114213,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "When somebody comes to me\nand projects the idealistic mask,"
    } ]
  }, {
    "tStartMs": 4118213,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "then I worry."
    } ]
  }, {
    "tStartMs": 4120253,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Because we are all the same\nat the core of it, you know."
    } ]
  }, {
    "tStartMs": 4122533,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "We are all inherently flawed as people."
    } ]
  }, {
    "tStartMs": 4124893,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "-100%.\n-[Nikhil] Yeah."
    } ]
  }, {
    "tStartMs": 4127933,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 4129333,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "But thank you for that."
    } ]
  }, {
    "tStartMs": 4130413,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "[laughter]"
    } ]
  }, {
    "tStartMs": 4132253,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "All right, Mr. Amit, you're next."
    } ]
  }, {
    "tStartMs": 4135613,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "-Tell us.\n-I think--"
    } ]
  }, {
    "tStartMs": 4137373,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "I'm very interested in your story\n'cause both of their stories--"
    } ]
  }, {
    "tStartMs": 4140493,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "-Him, I know firsthand.\n-Yeah."
    } ]
  }, {
    "tStartMs": 4141853,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "And his, I have read a bit."
    } ]
  }, {
    "tStartMs": 4143653,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "But your story is not so much out there."
    } ]
  }, {
    "tStartMs": 4146493,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "So I come from a small town,\nBikaner, Rajasthan."
    } ]
  }, {
    "tStartMs": 4150573,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And typical middle-class family."
    } ]
  }, {
    "tStartMs": 4152333,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Father used to work with bank."
    } ]
  }, {
    "tStartMs": 4154733,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "Which bank?"
    } ]
  }, {
    "tStartMs": 4156013,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "State Bank of Bikaner \u0026 Jaipur,\nif you would have heard of."
    } ]
  }, {
    "tStartMs": 4158453,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "SBBJ."
    } ]
  }, {
    "tStartMs": 4160053,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Later on they got merged with SBI."
    } ]
  }, {
    "tStartMs": 4162453,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "And Grandfather was an advocate."
    } ]
  }, {
    "tStartMs": 4164733,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "So typical middle class."
    } ]
  }, {
    "tStartMs": 4167013,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "And when you're in a small town,"
    } ]
  }, {
    "tStartMs": 4168493,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "the only dream is you become a doctor\nor an engineer."
    } ]
  }, {
    "tStartMs": 4172573,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "But I think I was not geared up for that."
    } ]
  }, {
    "tStartMs": 4175253,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "I was a very mischievous kid."
    } ]
  }, {
    "tStartMs": 4177893,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Academically not very strong."
    } ]
  }, {
    "tStartMs": 4179693,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "I mean, 60, 70% scorer at that time..."
    } ]
  }, {
    "tStartMs": 4182973,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "where people were, I think, 80, 85, or..."
    } ]
  }, {
    "tStartMs": 4186053,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "I was the eldest one in the family."
    } ]
  }, {
    "tStartMs": 4190093,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "No, no. He's fit."
    } ]
  }, {
    "tStartMs": 4191653,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "-[Rahul] Yeah?\n-And he went to NIFT."
    } ]
  }, {
    "tStartMs": 4196573,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "-NIFT ones are the cool ones.\n-Yeah."
    } ]
  }, {
    "tStartMs": 4198893,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "I have some colleagues who are from there."
    } ]
  }, {
    "tStartMs": 4201253,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "Sometimes, over-smart."
    } ]
  }, {
    "tStartMs": 4202573,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Right?"
    } ]
  }, {
    "tStartMs": 4203653,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "[laughter]"
    } ]
  }, {
    "tStartMs": 4205133,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "Fashion college."
    } ]
  }, {
    "tStartMs": 4206413,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Yeah, it's like\nwhere all the cool kids go."
    } ]
  }, {
    "tStartMs": 4208973,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "So anyways--"
    } ]
  }, {
    "tStartMs": 4211013,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "See, his shirt has\na very differentiated colour."
    } ]
  }, {
    "tStartMs": 4215333,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "It's not white, right?"
    } ]
  }, {
    "tStartMs": 4217573,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[chuckles] It's not white."
    } ]
  }, {
    "tStartMs": 4218653,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[Nikhil] What colour is it?"
    } ]
  }, {
    "tStartMs": 4219733,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Somewhere off-white, beige-ish."
    } ]
  }, {
    "tStartMs": 4222253,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "So I went..."
    } ]
  }, {
    "tStartMs": 4225253,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "My parents wanted me to become a doctor."
    } ]
  }, {
    "tStartMs": 4228293,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "And actually,\nI was pushed towards that career"
    } ]
  }, {
    "tStartMs": 4231253,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "because in small towns,\nI think those were the two choice."
    } ]
  }, {
    "tStartMs": 4234453,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "And apparently went to Kota also\nfor PMT preparation."
    } ]
  }, {
    "tStartMs": 4239173,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Medical test at that time\nfor crash course."
    } ]
  }, {
    "tStartMs": 4241533,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "But eventually realised\nthat I think I can't do that."
    } ]
  }, {
    "tStartMs": 4244853,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And fortunately what happened that..."
    } ]
  }, {
    "tStartMs": 4246613,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "My father was very, you know, bold\nthat he wanted to get out of Bikaner"
    } ]
  }, {
    "tStartMs": 4251373,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "and move to a bigger city."
    } ]
  }, {
    "tStartMs": 4252453,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "And he moved to Kanpur, actually."
    } ]
  }, {
    "tStartMs": 4254253,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "He got posted there.\nAnd when he moved there,"
    } ]
  }, {
    "tStartMs": 4256413,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "I realised that it's just not this\nas a career."
    } ]
  }, {
    "tStartMs": 4259173,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "There are people who are securing\n80%, 85% marks"
    } ]
  }, {
    "tStartMs": 4262253,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "and going to Delhi for B.Com."
    } ]
  }, {
    "tStartMs": 4264333,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "So I realised that Mass Com is a course."
    } ]
  }, {
    "tStartMs": 4266973,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "B.Com is a course."
    } ]
  }, {
    "tStartMs": 4268293,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Arts people are doing because of passion."
    } ]
  }, {
    "tStartMs": 4270173,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "And well-familied, good-educated kids."
    } ]
  }, {
    "tStartMs": 4273733,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Then I realised that\nmedical I don't want to do."
    } ]
  }, {
    "tStartMs": 4275813,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "I enjoyed maths, physics,"
    } ]
  }, {
    "tStartMs": 4277413,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "those kind of subjects\nwhere I don't need to mug up."
    } ]
  }, {
    "tStartMs": 4280373,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "And definitely a small-town kid\ngoing to a bigger city,"
    } ]
  }, {
    "tStartMs": 4283333,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "so you get a little bit buoyed away\nby what's happening there."
    } ]
  }, {
    "tStartMs": 4287493,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "I realised that."
    } ]
  }, {
    "tStartMs": 4288733,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Then parents said, \"Do an IIT.\""
    } ]
  }, {
    "tStartMs": 4290493,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Then I realised it's too late for me\nto do an IIT now."
    } ]
  }, {
    "tStartMs": 4292933,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "Otherwise you'll ask me\nto bunk for three years."
    } ]
  }, {
    "tStartMs": 4295533,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "And I think it's '98, '99."
    } ]
  }, {
    "tStartMs": 4298773,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "And eventually, after graduation,\nstarted preparing for competitive exams."
    } ]
  }, {
    "tStartMs": 4303573,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "And formally landed into NIFT."
    } ]
  }, {
    "tStartMs": 4305853,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "So I think NIFT Hyderabad\nwas a real-life learning for me."
    } ]
  }, {
    "tStartMs": 4311893,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "First time hostel. Getting out of home."
    } ]
  }, {
    "tStartMs": 4314973,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "And I was into fashion management,\nnot design."
    } ]
  }, {
    "tStartMs": 4317773,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "But maybe all the peers were design guys."
    } ]
  }, {
    "tStartMs": 4320853,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "And again,\nDad took a loan for me to go to college."
    } ]
  }, {
    "tStartMs": 4324933,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "So I had always limitation\nthat I should not be spending more."
    } ]
  }, {
    "tStartMs": 4328453,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "And then my friends\nhad higher pocket money."
    } ]
  }, {
    "tStartMs": 4330493,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "So I think my entrepreneurship stint\nstarted from there."
    } ]
  }, {
    "tStartMs": 4333533,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Tell me things about yourself\nthat I can't Google."
    } ]
  }, {
    "tStartMs": 4337453,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "Or watch in another interview of yours."
    } ]
  }, {
    "tStartMs": 4339573,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "'Cause that's boring. I don't wanna know."
    } ]
  }, {
    "tStartMs": 4342213,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "I mean... notorious kid, definitely."
    } ]
  }, {
    "tStartMs": 4346133,
    "dDurationMs": 5840,
    "segs": [ {
      "utf8": "And, I mean, I always had hunger\nto do something different."
    } ]
  }, {
    "tStartMs": 4352733,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "And in college, like I said,\nI used to look for alternate sources."
    } ]
  }, {
    "tStartMs": 4356773,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "I was again, let's say there was..."
    } ]
  }, {
    "tStartMs": 4359493,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "high-tech city was all call centres\nif you look into it."
    } ]
  }, {
    "tStartMs": 4361853,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Hyderabad that time."
    } ]
  }, {
    "tStartMs": 4363573,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Convergys and all."
    } ]
  }, {
    "tStartMs": 4365093,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "So I thought of maybe doing a job\nat a call centre."
    } ]
  }, {
    "tStartMs": 4367133,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "Maybe pick some project at Convergys."
    } ]
  }, {
    "tStartMs": 4369453,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Not Convergys, maybe, Infosys was there."
    } ]
  }, {
    "tStartMs": 4371173,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Went to ISP to pitch something."
    } ]
  }, {
    "tStartMs": 4373453,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "And maybe just started picking up\nsome projects at our college only,"
    } ]
  }, {
    "tStartMs": 4376413,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "where, you know,\nthere was a fest happening,"
    } ]
  }, {
    "tStartMs": 4378293,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "\"Could you bundle the T-shirts?\""
    } ]
  }, {
    "tStartMs": 4379493,
    "dDurationMs": 4480,
    "segs": [ {
      "utf8": "So I think my first entrepreneurship time\nhappened from there on."
    } ]
  }, {
    "tStartMs": 4384053,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "I started making\na little bit of pocket money from there."
    } ]
  }, {
    "tStartMs": 4387133,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "But I was always insecure in life\nthat I'll not get the job."
    } ]
  }, {
    "tStartMs": 4390813,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Otherwise I was like..."
    } ]
  }, {
    "tStartMs": 4392053,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "So you've finished college,\nand what did you do first?"
    } ]
  }, {
    "tStartMs": 4394573,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "When did you finish college?"
    } ]
  }, {
    "tStartMs": 4396373,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "So I finished college in 2004."
    } ]
  }, {
    "tStartMs": 4398813,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "And I got placed\nin the manufacturing setup,"
    } ]
  }, {
    "tStartMs": 4402053,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Orient Craft, if you would know."
    } ]
  }, {
    "tStartMs": 4403973,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Based out of Gurgaon."
    } ]
  }, {
    "tStartMs": 4405133,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "So that is one of the largest export house\nout of India."
    } ]
  }, {
    "tStartMs": 4409173,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "I thought I would not get\na better job than this."
    } ]
  }, {
    "tStartMs": 4411973,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "So I stayed there."
    } ]
  }, {
    "tStartMs": 4413413,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "And I worked\nfor three and a half years there."
    } ]
  }, {
    "tStartMs": 4415333,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "It was typically merchandising."
    } ]
  }, {
    "tStartMs": 4417773,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "And two years I did merchandising,\nI found it very boring."
    } ]
  }, {
    "tStartMs": 4421333,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "And I thought of leaving the job\nthat time because..."
    } ]
  }, {
    "tStartMs": 4423813,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "If you would know, merchandising is..."
    } ]
  }, {
    "tStartMs": 4425853,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "buyers say you something\nand then you copy paste."
    } ]
  }, {
    "tStartMs": 4428253,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "I used to work for Ann Taylor, Gap,\nall those brands."
    } ]
  }, {
    "tStartMs": 4430973,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "And then I started giving interviews\nactually everywhere outside."
    } ]
  }, {
    "tStartMs": 4434333,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "I went to Barista.\n\"Can I do job in marketing?\""
    } ]
  }, {
    "tStartMs": 4436933,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Coffee Day was big. There was..."
    } ]
  }, {
    "tStartMs": 4438853,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "I went to Air Deccan for an interview\nto apply for marketing."
    } ]
  }, {
    "tStartMs": 4441613,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "I was fed up of my career that time."
    } ]
  }, {
    "tStartMs": 4444053,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "Ironically, three people\nwho have proficiency in marketing"
    } ]
  }, {
    "tStartMs": 4446933,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "are running consumer electronic companies."
    } ]
  }, {
    "tStartMs": 4450173,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "So maybe that's a prerequisite."
    } ]
  }, {
    "tStartMs": 4451653,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "We could catch\nthe market pulse well, actually."
    } ]
  }, {
    "tStartMs": 4456893,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "And maybe I didn't get a job\nanywhere outside."
    } ]
  }, {
    "tStartMs": 4459093,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "And I started taking on\nall special projects at the company."
    } ]
  }, {
    "tStartMs": 4463293,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "What all the pain problems of the company,\nI could take that."
    } ]
  }, {
    "tStartMs": 4465733,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "-And you worked with your brother?\n-No, no, no."
    } ]
  }, {
    "tStartMs": 4468053,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So my brother is ten years younger to me."
    } ]
  }, {
    "tStartMs": 4470733,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "So he came in maybe... ten years ago."
    } ]
  }, {
    "tStartMs": 4475973,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Twenty-five."
    } ]
  }, {
    "tStartMs": 4477413,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "For 15, 16, he came in."
    } ]
  }, {
    "tStartMs": 4479453,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "-So I was--\n-So he's 28."
    } ]
  }, {
    "tStartMs": 4481613,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "So we are talking about 2005 to 2008."
    } ]
  }, {
    "tStartMs": 4484133,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "He is 28 years old."
    } ]
  }, {
    "tStartMs": 4485453,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "No, he's 35. 34, 35."
    } ]
  }, {
    "tStartMs": 4487253,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "You're 38."
    } ]
  }, {
    "tStartMs": 4488413,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "No, I am 43."
    } ]
  }, {
    "tStartMs": 4489933,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "-You're 43.\n-Yeah, yeah. I'm 43."
    } ]
  }, {
    "tStartMs": 4493613,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "So anyways, I worked there\nfor three and a half years"
    } ]
  }, {
    "tStartMs": 4495813,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "and then started picking up."
    } ]
  }, {
    "tStartMs": 4496893,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "You look very good, yeah, for 43."
    } ]
  }, {
    "tStartMs": 4499413,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[Amit] Trying to."
    } ]
  }, {
    "tStartMs": 4500933,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "Working with young founders,\nyou have to stay true to that."
    } ]
  }, {
    "tStartMs": 4506333,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "Anyways, so I worked\nfor three and a half years."
    } ]
  }, {
    "tStartMs": 4509613,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "They moved me to..."
    } ]
  }, {
    "tStartMs": 4511333,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "I saw a huge gap\nin the international product development."
    } ]
  }, {
    "tStartMs": 4514733,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "I picked up that piece,\nand that's my journey started."
    } ]
  }, {
    "tStartMs": 4518133,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "I moved to Hong Kong for the first time."
    } ]
  }, {
    "tStartMs": 4520253,
    "dDurationMs": 5320,
    "segs": [ {
      "utf8": "And I think it was 2007 era\nwhere I saw global brands were there."
    } ]
  }, {
    "tStartMs": 4525653,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "And whenever I used to travel,\npeople used to ask me,"
    } ]
  }, {
    "tStartMs": 4527493,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "\"Go and buy this thing for me,\nthat thing for me.\""
    } ]
  }, {
    "tStartMs": 4529253,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "I used to import\na lot of BlackBerrys from there."
    } ]
  }, {
    "tStartMs": 4531773,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "I think it was BlackBerry time."
    } ]
  }, {
    "tStartMs": 4533613,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "So I used to buy and trade off\nfor 1,000, 2,000 bucks"
    } ]
  }, {
    "tStartMs": 4536293,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "and sell it in India in my office."
    } ]
  }, {
    "tStartMs": 4538493,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "-It was like jailbreak phones.\n-[Rahul] Yeah."
    } ]
  }, {
    "tStartMs": 4540813,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "So every time I used to go buy ten phones\nand bring it here."
    } ]
  }, {
    "tStartMs": 4543893,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "And eventually I realised\nthat I'm solving a bigger problem,"
    } ]
  }, {
    "tStartMs": 4546973,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "not electronics, but textile."
    } ]
  }, {
    "tStartMs": 4548933,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Let me do it myself."
    } ]
  }, {
    "tStartMs": 4550053,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "And I started my first business in 2007,"
    } ]
  }, {
    "tStartMs": 4553853,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "which was fashion accessory,\ntextile merchandising, basically."
    } ]
  }, {
    "tStartMs": 4557773,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Buying house, quasi concept."
    } ]
  }, {
    "tStartMs": 4559853,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "And I had 60,000 bucks in my pocket."
    } ]
  }, {
    "tStartMs": 4562533,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "And again, how could you do a business\nwith 60,000 bucks?"
    } ]
  }, {
    "tStartMs": 4565093,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "So I started it in '7,\nbased out of Hong Kong."
    } ]
  }, {
    "tStartMs": 4567853,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "And I think that's where my journey\nwith H\u0026M started."
    } ]
  }, {
    "tStartMs": 4572253,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "H\u0026M was my first customer."
    } ]
  }, {
    "tStartMs": 4573933,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "I worked with them very closely\nwith the design team."
    } ]
  }, {
    "tStartMs": 4576933,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "So that's how I realised, man,"
    } ]
  }, {
    "tStartMs": 4579973,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "there are brands\nwhich are built at centre."
    } ]
  }, {
    "tStartMs": 4582693,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "So India was, I think, fashion...\nBig Bazaar time that time."
    } ]
  }, {
    "tStartMs": 4586973,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "It was Micromax and Big Bazaar\nwhich were at the bottom."
    } ]
  }, {
    "tStartMs": 4590053,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "And H\u0026M was right at the centre."
    } ]
  }, {
    "tStartMs": 4592093,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "Not cheap, not luxury,\nbut selling to the... to the world."
    } ]
  }, {
    "tStartMs": 4596893,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Uniqlo, H\u0026M."
    } ]
  }, {
    "tStartMs": 4598053,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "And that's how, I think,\nmy roots got levelled"
    } ]
  }, {
    "tStartMs": 4602133,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "at good-quality product\nat an affordable price."
    } ]
  }, {
    "tStartMs": 4604613,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "Not the cheapest, not the expensive."
    } ]
  }, {
    "tStartMs": 4606653,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "I did that business\nfor seven and a half years,"
    } ]
  }, {
    "tStartMs": 4609413,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "eight years, travelling a lot."
    } ]
  }, {
    "tStartMs": 4611013,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "And then Gaurav, my cousin, actually,"
    } ]
  }, {
    "tStartMs": 4614333,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "he was 21,\nhe became commercial pilot, I think,"
    } ]
  }, {
    "tStartMs": 4617933,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Air Deccan time or Kingfisher\nor Jet Airways, something tanked."
    } ]
  }, {
    "tStartMs": 4621013,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "No job."
    } ]
  }, {
    "tStartMs": 4622253,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And he asked me\nto get an iPhone that time."
    } ]
  }, {
    "tStartMs": 4624013,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "It was just launched."
    } ]
  }, {
    "tStartMs": 4625093,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "And I said, \"Are you mad?\""
    } ]
  }, {
    "tStartMs": 4626453,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "[Nikhil] What year?"
    } ]
  }, {
    "tStartMs": 4627573,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "I think '14."
    } ]
  }, {
    "tStartMs": 4629893,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "-What time iPhone--\n-[Carl] The first one?"
    } ]
  }, {
    "tStartMs": 4631613,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "-Yeah.\n-2007 or '8?"
    } ]
  }, {
    "tStartMs": 4633933,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "-'8.\n-2007, '8."
    } ]
  }, {
    "tStartMs": 4635613,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "So I think he asked me to get\nthe iPhone 3 sometime."
    } ]
  }, {
    "tStartMs": 4638813,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "So I got an iPhone 3 for him,\nand I said, \"Are you mad?\""
    } ]
  }, {
    "tStartMs": 4640773,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "It is 25,000 bucks."
    } ]
  }, {
    "tStartMs": 4642733,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "And I got a jailbreak phone\nfrom Hong Kong for him."
    } ]
  }, {
    "tStartMs": 4646853,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "And I got a phone for him."
    } ]
  }, {
    "tStartMs": 4648893,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "He said,\n\"Then I need to buy a cover for this.\""
    } ]
  }, {
    "tStartMs": 4651413,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "And there were no covers for that phone."
    } ]
  }, {
    "tStartMs": 4653613,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "And that's how our journey started."
    } ]
  }, {
    "tStartMs": 4655133,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "He said, \"Let me get..."
    } ]
  }, {
    "tStartMs": 4657013,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "I have a problem,\ncan you solve it for me?\""
    } ]
  }, {
    "tStartMs": 4660293,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "If I have a problem,\nmy other friend should have a problem."
    } ]
  }, {
    "tStartMs": 4663333,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "So we started mobile accessories\nthat time."
    } ]
  }, {
    "tStartMs": 4665053,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "In which year?"
    } ]
  }, {
    "tStartMs": 4666453,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "I think 2014, '15."
    } ]
  }, {
    "tStartMs": 4668093,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I think Xiaomi came to India that time."
    } ]
  }, {
    "tStartMs": 4670813,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "We launched iPhone covers, we flopped."
    } ]
  }, {
    "tStartMs": 4672933,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "All stocks are at home."
    } ]
  }, {
    "tStartMs": 4674093,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "-Under the name Noise?\n-Yeah, it's under the name Noise."
    } ]
  }, {
    "tStartMs": 4676733,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So the company started in 2014."
    } ]
  }, {
    "tStartMs": 4678653,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "'14, '15, we started doing\nmobile accessories as a side job."
    } ]
  }, {
    "tStartMs": 4682053,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "He was, as a hobby, doing it."
    } ]
  }, {
    "tStartMs": 4683653,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "I was doing my business, what I was doing."
    } ]
  }, {
    "tStartMs": 4686813,
    "dDurationMs": 4920,
    "segs": [ {
      "utf8": "And then, iPhone, we had a huge failure,\nbecause the market would be, what, .5%?"
    } ]
  }, {
    "tStartMs": 4691813,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "We were the only few customers\nbuying iPhone."
    } ]
  }, {
    "tStartMs": 4695653,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "And then we flipped to Xiaomi."
    } ]
  }, {
    "tStartMs": 4698373,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "He was doing a side project,\nand that's how our journey kicked in."
    } ]
  }, {
    "tStartMs": 4701533,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "And then what happened?"
    } ]
  }, {
    "tStartMs": 4704293,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "The business started becoming very big."
    } ]
  }, {
    "tStartMs": 4706533,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "The phone, all Chinese guys came in."
    } ]
  }, {
    "tStartMs": 4708613,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "The business started becoming very big."
    } ]
  }, {
    "tStartMs": 4709853,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "You sold accessories\nfor the Chinese phones?"
    } ]
  }, {
    "tStartMs": 4712453,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Yeah, we sold accessories."
    } ]
  }, {
    "tStartMs": 4713653,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "Because, see, please understand,\nwe couldn't do tech."
    } ]
  }, {
    "tStartMs": 4716413,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "I was coming from a fashion background."
    } ]
  }, {
    "tStartMs": 4717853,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "I just knew designs."
    } ]
  }, {
    "tStartMs": 4719773,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "And mobile cover is just an accessory."
    } ]
  }, {
    "tStartMs": 4722093,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "I mean, it's like a T-shirt."
    } ]
  }, {
    "tStartMs": 4724293,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "It's such a simple product.\nYou get it, you print it."
    } ]
  }, {
    "tStartMs": 4726333,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "We had a small setup also\nmanufacturing in a factory"
    } ]
  }, {
    "tStartMs": 4729573,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "where we used to ship\nthousands of cases every day."
    } ]
  }, {
    "tStartMs": 4732733,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "And then we realised that this market\nis getting super commoditised."
    } ]
  }, {
    "tStartMs": 4736693,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "And then when did Noise blow up?"
    } ]
  }, {
    "tStartMs": 4739213,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "-I think--\n-COVID?"
    } ]
  }, {
    "tStartMs": 4740493,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "No, no, no, not COVID."
    } ]
  }, {
    "tStartMs": 4741573,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "I think we started picking up in '19."
    } ]
  }, {
    "tStartMs": 4743373,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "I'll tell you the trajectory,\nwhat happened in between."
    } ]
  }, {
    "tStartMs": 4746933,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So we were doing cases, which was fine."
    } ]
  }, {
    "tStartMs": 4749653,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "And we realised that the pricings\nare going down."
    } ]
  }, {
    "tStartMs": 4751813,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "I mean, we started selling for 500 bucks,\nand eventually it landed to 150."
    } ]
  }, {
    "tStartMs": 4755893,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "And 150, whatever case you sell,\nyou can't make a big company."
    } ]
  }, {
    "tStartMs": 4759253,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "So we were growing,"
    } ]
  }, {
    "tStartMs": 4760333,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "but we were some 100 crore\nrevenue company."
    } ]
  }, {
    "tStartMs": 4763893,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "Then we thought of starting doing\ndifferent categories."
    } ]
  }, {
    "tStartMs": 4766533,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "We launched, everybody said marketplaces,\nFlipkarts of the universe."
    } ]
  }, {
    "tStartMs": 4770973,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "\"Why don't you do headphones,\nneckbands, or whatever categories?\""
    } ]
  }, {
    "tStartMs": 4774893,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "We did that, we failed."
    } ]
  }, {
    "tStartMs": 4775973,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "There was no differentiation."
    } ]
  }, {
    "tStartMs": 4778013,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "There was no differentiation."
    } ]
  }, {
    "tStartMs": 4779333,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "And then, out of interest,\nwe realised what categories to pick."
    } ]
  }, {
    "tStartMs": 4783053,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "So our thesis was clear,\nwe'll not fight the big boys."
    } ]
  }, {
    "tStartMs": 4785973,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "Like, Sony was selling wired earphones,\nor Philips."
    } ]
  }, {
    "tStartMs": 4789253,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "I said, \"Why would somebody buy us?\""
    } ]
  }, {
    "tStartMs": 4790573,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "Till that time, we were cheaper,\nand you can't be cheaper."
    } ]
  }, {
    "tStartMs": 4792613,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "Till that time, you cut cost."
    } ]
  }, {
    "tStartMs": 4795453,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "And we were searching for smartwatch\nfor ourselves that time in '19 something."
    } ]
  }, {
    "tStartMs": 4799653,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "I don't remember that time."
    } ]
  }, {
    "tStartMs": 4801453,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "And only Fitbit was available\nfor 20,000 grands."
    } ]
  }, {
    "tStartMs": 4803853,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Fitbit Blaze or something."
    } ]
  }, {
    "tStartMs": 4804973,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "We got a refurb watch for 10,000."
    } ]
  }, {
    "tStartMs": 4807333,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "We realised,\n\"Is this a gap in the market?\""
    } ]
  }, {
    "tStartMs": 4810333,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "And that's how we started doing watches."
    } ]
  }, {
    "tStartMs": 4812653,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "The market was two million units\nthat time."
    } ]
  }, {
    "tStartMs": 4816493,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Maybe two million in a year."
    } ]
  }, {
    "tStartMs": 4818573,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Nobody was doing watches."
    } ]
  }, {
    "tStartMs": 4819973,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "We started,\nthen it picked up in three, four years."
    } ]
  }, {
    "tStartMs": 4822813,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "And COVID, it picked up."
    } ]
  }, {
    "tStartMs": 4825173,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "So I think there was a tipping point of--"
    } ]
  }, {
    "tStartMs": 4826773,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "So, watch was the tipping point?"
    } ]
  }, {
    "tStartMs": 4828373,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Watch was the tipping point for us."
    } ]
  }, {
    "tStartMs": 4829973,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "Because you were able\nto buy refurbished for cheaper and--"
    } ]
  }, {
    "tStartMs": 4833213,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "No, no, no.\nWe bought refurbished for ourselves."
    } ]
  }, {
    "tStartMs": 4835693,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "But then we realised\nthat there is a market which exists."
    } ]
  }, {
    "tStartMs": 4838013,
    "dDurationMs": 5440,
    "segs": [ {
      "utf8": "\"Can we do in our brand where we could do\na 5,000, 8,000 rupees watch,"
    } ]
  }, {
    "tStartMs": 4843533,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "which is affordable\nto a mid-level consumer?\""
    } ]
  }, {
    "tStartMs": 4845893,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Good part, Gaurav was 25 that time."
    } ]
  }, {
    "tStartMs": 4848733,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "So he had that young taste."
    } ]
  }, {
    "tStartMs": 4850133,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "He never wanted to buy cheap."
    } ]
  }, {
    "tStartMs": 4851813,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And he never wanted to buy\nthe most expensive one."
    } ]
  }, {
    "tStartMs": 4853813,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "And all India market\nwas Chinese knockoffs."
    } ]
  }, {
    "tStartMs": 4856773,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "So that was the desire to build."
    } ]
  }, {
    "tStartMs": 4858173,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Can we use something for ourselves\nand gift it to friends, family?"
    } ]
  }, {
    "tStartMs": 4861893,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "And today you are more known for earbuds?"
    } ]
  }, {
    "tStartMs": 4864133,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "No, no. We are not known for..."
    } ]
  }, {
    "tStartMs": 4865613,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "We are less known for earbuds."
    } ]
  }, {
    "tStartMs": 4867013,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "We are dominant share for watches."
    } ]
  }, {
    "tStartMs": 4870293,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Watches is more tough category."
    } ]
  }, {
    "tStartMs": 4871893,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "How much is your share now?"
    } ]
  }, {
    "tStartMs": 4873373,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "We would be north of 25%\nfor last three, four years."
    } ]
  }, {
    "tStartMs": 4876733,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "So watches are more complicated."
    } ]
  }, {
    "tStartMs": 4877973,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "How big is the market?"
    } ]
  }, {
    "tStartMs": 4880213,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "-Close to a billion dollar market revenue.\n-Wow."
    } ]
  }, {
    "tStartMs": 4884893,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "So how much are you selling now, Noise,\nin terms of revenues?"
    } ]
  }, {
    "tStartMs": 4888093,
    "dDurationMs": 5560,
    "segs": [ {
      "utf8": "We would be... Watches we would have\nclose to 10, 14% of the revenue share."
    } ]
  }, {
    "tStartMs": 4893733,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "[Nikhil] So about 100, 140 million?"
    } ]
  }, {
    "tStartMs": 4896093,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "[Amit] Close to 100 million of revenue."
    } ]
  }, {
    "tStartMs": 4898333,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "[Nikhil] And the rest of the products\nin Noise?"
    } ]
  }, {
    "tStartMs": 4900773,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Are audio devices."
    } ]
  }, {
    "tStartMs": 4902173,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "So as of now, we were very clear\nthat we have limited capital."
    } ]
  }, {
    "tStartMs": 4905133,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "We bootstrapped the business."
    } ]
  }, {
    "tStartMs": 4907093,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "So we couldn't go very widthwise.\nWe never had the--"
    } ]
  }, {
    "tStartMs": 4909613,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Have you raised money now?"
    } ]
  }, {
    "tStartMs": 4910693,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "Last year,\nwe raised a strategic investment"
    } ]
  }, {
    "tStartMs": 4913453,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "from Bose Corporation."
    } ]
  }, {
    "tStartMs": 4915533,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "And now how big is the business,\nrevenue-wise?"
    } ]
  }, {
    "tStartMs": 4918333,
    "dDurationMs": 5880,
    "segs": [ {
      "utf8": "We would be somewhere sitting...\n150, 200 million, that kind of revenue."
    } ]
  }, {
    "tStartMs": 4924293,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "Hundred in watches\nand fifty to two hundred in others."
    } ]
  }, {
    "tStartMs": 4928173,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "And we were very clear,\nwe'll go deeper in the category"
    } ]
  }, {
    "tStartMs": 4931213,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "because we never had capital\nto experiment multiple ways."
    } ]
  }, {
    "tStartMs": 4934493,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Crazy, huh? Super impressive."
    } ]
  }, {
    "tStartMs": 4937053,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "To have been able to bootstrap\nto that scale, right?"
    } ]
  }, {
    "tStartMs": 4940253,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "I didn't know that.\nI thought you guys had raised the venture."
    } ]
  }, {
    "tStartMs": 4943173,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "No, we didn't.\nI think it became a blessing for us"
    } ]
  }, {
    "tStartMs": 4946813,
    "dDurationMs": 4760,
    "segs": [ {
      "utf8": "because, first, we never had to dress up\nour company for any external benefit."
    } ]
  }, {
    "tStartMs": 4951653,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "Like today,\nsometimes investors says chase GMV,"
    } ]
  }, {
    "tStartMs": 4954653,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "second day they say chase market share,\nand sometimes profit."
    } ]
  }, {
    "tStartMs": 4958493,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "So we were in that luxury\nof taking our decisions,"
    } ]
  }, {
    "tStartMs": 4962173,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "which were right for the business\nin long run."
    } ]
  }, {
    "tStartMs": 4964573,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "So having less set of people,\nhaving less products,"
    } ]
  }, {
    "tStartMs": 4969213,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "go deeper in the categories\nwhere you are in."
    } ]
  }, {
    "tStartMs": 4971813,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "-Nikhil, this is what the difference is.\n-[Nikhil] Yeah."
    } ]
  }, {
    "tStartMs": 4973653,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "These are the real businesses,"
    } ]
  }, {
    "tStartMs": 4975333,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "because, see, if you see all old,\nyou know, businesses,"
    } ]
  }, {
    "tStartMs": 4979133,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "they were all coming\nfrom their own capital"
    } ]
  }, {
    "tStartMs": 4982133,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "or having access only to the banks,\nyou know,"
    } ]
  }, {
    "tStartMs": 4984613,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "and taking the debt from the banks\nand doing those things."
    } ]
  }, {
    "tStartMs": 4986853,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "It was not, like,\nraising an insane amount of capital"
    } ]
  }, {
    "tStartMs": 4990173,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "and say, \"Okay, you go\nand experiment with somebody else.\""
    } ]
  }, {
    "tStartMs": 4992533,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "-Yeah, yeah, yeah.\n-Right?"
    } ]
  }, {
    "tStartMs": 4994253,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "So..."
    } ]
  }, {
    "tStartMs": 4995933,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "-I think, yeah, these are the examples.\n-No, no, crazy impressive."
    } ]
  }, {
    "tStartMs": 4998373,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "I like pushing people\nto see how they defend themselves."
    } ]
  }, {
    "tStartMs": 5000453,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Yeah. [chuckles]"
    } ]
  }, {
    "tStartMs": 5001573,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I'm trying to figure out how to push Amit."
    } ]
  }, {
    "tStartMs": 5003333,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "-Yeah.\n-Okay, so..."
    } ]
  }, {
    "tStartMs": 5006213,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "what is today for?"
    } ]
  }, {
    "tStartMs": 5008013,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "Today is for any young Indian boy or girl,\nunder the age of 25,"
    } ]
  }, {
    "tStartMs": 5012333,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "who wants to start\na consumer electronic brand."
    } ]
  }, {
    "tStartMs": 5016133,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "It could be cell phone,\nit could be TV, it could be speaker,"
    } ]
  }, {
    "tStartMs": 5019613,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "it could be earphone,\nit could be smartwatch."
    } ]
  }, {
    "tStartMs": 5022773,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "We want to, like, plot a road map\nof what they need to look at,"
    } ]
  }, {
    "tStartMs": 5027893,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "how to identify the opportunity,\nwhich vendor to go to,"
    } ]
  }, {
    "tStartMs": 5032293,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "how to test the product,\nand how to finally take it to market."
    } ]
  }, {
    "tStartMs": 5035573,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "We'll go into\ndo you sell on quick commerce,"
    } ]
  }, {
    "tStartMs": 5038453,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "do you sell on Amazon,\ndo you sell through physical distribution?"
    } ]
  }, {
    "tStartMs": 5042613,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "So the first thing we thought we might do\nis establish market size."
    } ]
  }, {
    "tStartMs": 5047613,
    "dDurationMs": 4880,
    "segs": [ {
      "utf8": "How big is the consumer electronic market,"
    } ]
  }, {
    "tStartMs": 5052573,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "A, in the world, B, in India?"
    } ]
  }, {
    "tStartMs": 5056333,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "How fast is it growing there,\nand how fast is it growing here?"
    } ]
  }, {
    "tStartMs": 5059053,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Should I start with smartphones?"
    } ]
  }, {
    "tStartMs": 5060213,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 5061533,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "Smartphones globally\nis about 1.2 billion units every year."
    } ]
  }, {
    "tStartMs": 5065333,
    "dDurationMs": 5960,
    "segs": [ {
      "utf8": "In India it's 120 to 140 million annually,\ndepending on what number you look at."
    } ]
  }, {
    "tStartMs": 5072293,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "So if you assume that the ASP is $300,\nthen 1.2 billion,"
    } ]
  }, {
    "tStartMs": 5077093,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "that's over $300 billion,\njust on the hardware side."
    } ]
  }, {
    "tStartMs": 5080493,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "ASP is..."
    } ]
  }, {
    "tStartMs": 5081893,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "-Average selling price.\n-Average selling price."
    } ]
  }, {
    "tStartMs": 5083373,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "Very different in India\ncompared to the rest of the world?"
    } ]
  }, {
    "tStartMs": 5085773,
    "dDurationMs": 4880,
    "segs": [ {
      "utf8": "Yeah. Every country is different\ndepending on the market dynamics."
    } ]
  }, {
    "tStartMs": 5090733,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "-Per capita as well.\n-Yeah."
    } ]
  }, {
    "tStartMs": 5092373,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "Where is the sweet spot?"
    } ]
  }, {
    "tStartMs": 5093653,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "If I want to start making\na cell phone today,"
    } ]
  }, {
    "tStartMs": 5097293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "where would I price it?"
    } ]
  }, {
    "tStartMs": 5100453,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Personally, I don't think\nthere is any more opportunity."
    } ]
  }, {
    "tStartMs": 5102213,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "Oh, man, I wouldn't recommend\nany of my friends"
    } ]
  }, {
    "tStartMs": 5104333,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "to go into this business right now."
    } ]
  }, {
    "tStartMs": 5106733,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "The market is very, very tough\nto compete in."
    } ]
  }, {
    "tStartMs": 5109813,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "But you need to understand\nthat what exactly,"
    } ]
  }, {
    "tStartMs": 5113093,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "if you want to make that,\nwhat exactly are you trying to solve?"
    } ]
  }, {
    "tStartMs": 5115533,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "Are you trying to, let's say,\nmake a luxury brand,"
    } ]
  }, {
    "tStartMs": 5118933,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "or are you going to make a mass brand?"
    } ]
  }, {
    "tStartMs": 5121693,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "Basis is that you need to figure out\nyour TAM."
    } ]
  }, {
    "tStartMs": 5126253,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "That what is the market\nI'm going to address."
    } ]
  }, {
    "tStartMs": 5129493,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "And basis is that you can define,\n\"Okay, this is that, you know,\""
    } ]
  }, {
    "tStartMs": 5131773,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "then you can find the sweet spot."
    } ]
  }, {
    "tStartMs": 5132853,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Because otherwise the category is like,"
    } ]
  }, {
    "tStartMs": 5136053,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "if you see mobile phones,\niPhone is $1,000."
    } ]
  }, {
    "tStartMs": 5141373,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "And then your, you know,"
    } ]
  }, {
    "tStartMs": 5143573,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "the average selling price,\nas he said, is right,"
    } ]
  }, {
    "tStartMs": 5145893,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "between, you know, $250 to $300 in India."
    } ]
  }, {
    "tStartMs": 5150533,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "So maybe let me break it\nfor India market perspective"
    } ]
  }, {
    "tStartMs": 5154093,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "so that at least viewers\ncould understand it well."
    } ]
  }, {
    "tStartMs": 5156773,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "In a category like truly wireless,\nfor an example,"
    } ]
  }, {
    "tStartMs": 5159173,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "the India market\nwould be like 60 million units."
    } ]
  }, {
    "tStartMs": 5161733,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "In a category like?"
    } ]
  }, {
    "tStartMs": 5162813,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "Audio devices, for an example, like this."
    } ]
  }, {
    "tStartMs": 5164653,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "This market\nwould be like 60 million devices,"
    } ]
  }, {
    "tStartMs": 5166853,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "which is six crores."
    } ]
  }, {
    "tStartMs": 5167933,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 5169813,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "-And 90% of this--\n-And value-wise?"
    } ]
  }, {
    "tStartMs": 5172693,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "Around a billion dollar market value."
    } ]
  }, {
    "tStartMs": 5176493,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "Can you just tell me\nfor India specifically?"
    } ]
  }, {
    "tStartMs": 5180253,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Yeah. Yeah."
    } ]
  }, {
    "tStartMs": 5181613,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "How much is smartphone, how much is TV,\nhow much is earphone, how much is watch?"
    } ]
  }, {
    "tStartMs": 5186093,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "So, like this..."
    } ]
  }, {
    "tStartMs": 5190253,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Phones would be\nabout $150 million, phones?"
    } ]
  }, {
    "tStartMs": 5192133,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "One-fifty million devices in India,\nam I right?"
    } ]
  }, {
    "tStartMs": 5194213,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "One-fifty million smartphones,"
    } ]
  }, {
    "tStartMs": 5195533,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "and let's say still there are like around\n50, 60 million feature phones."
    } ]
  }, {
    "tStartMs": 5198573,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Feature phones."
    } ]
  }, {
    "tStartMs": 5199653,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "So on a broad level,\nIndia has a penetration"
    } ]
  }, {
    "tStartMs": 5202053,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "of 600 million smartphone users\nin the country."
    } ]
  }, {
    "tStartMs": 5205493,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "That's the right base to look at it."
    } ]
  }, {
    "tStartMs": 5207853,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Sixty crore people use smartphones,\nis that right?"
    } ]
  }, {
    "tStartMs": 5211053,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "-More or less.\n-Yeah. More or less."
    } ]
  }, {
    "tStartMs": 5212653,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "I think you gotta look at the annual,\nlike, 120, 140 number."
    } ]
  }, {
    "tStartMs": 5215853,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "[Nikhil] They broadly say that 72 billion"
    } ]
  }, {
    "tStartMs": 5217653,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "is the consumer electronic market\nin India."
    } ]
  }, {
    "tStartMs": 5221413,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "-[Carl] How much?\n-Seventy-two billion."
    } ]
  }, {
    "tStartMs": 5224053,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Per year."
    } ]
  }, {
    "tStartMs": 5225853,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Total consumer electronics?"
    } ]
  }, {
    "tStartMs": 5229853,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "USD or INR?"
    } ]
  }, {
    "tStartMs": 5230933,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "No, billion dollar he is talking about."
    } ]
  }, {
    "tStartMs": 5232613,
    "dDurationMs": 5640,
    "segs": [ {
      "utf8": "In that they say cell phones,\nsmart plus feature is 50 billion."
    } ]
  }, {
    "tStartMs": 5239013,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "Very true. I think large market\nwould be smartphones only."
    } ]
  }, {
    "tStartMs": 5243173,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "-[Nikhil] Right?\n-[Carl] Yeah."
    } ]
  }, {
    "tStartMs": 5244813,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "So in all the consumer electronics\nin India,"
    } ]
  }, {
    "tStartMs": 5247333,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "because you make TVs and everything else,"
    } ]
  }, {
    "tStartMs": 5249213,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "and you make earphones\nand watch and all that,"
    } ]
  }, {
    "tStartMs": 5252093,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "where is the opportunity?"
    } ]
  }, {
    "tStartMs": 5254333,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "For me, say I am a 20-year-old kid"
    } ]
  }, {
    "tStartMs": 5257773,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "who has managed to raise some money\nfrom somewhere,"
    } ]
  }, {
    "tStartMs": 5259853,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "and I want to compete in this space."
    } ]
  }, {
    "tStartMs": 5261693,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Where is the opportunity?"
    } ]
  }, {
    "tStartMs": 5264613,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "Tell me anything,\ntell me wired earphone, tell me..."
    } ]
  }, {
    "tStartMs": 5267733,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "No, so first of all,\nI think anybody who wanna enter a space,"
    } ]
  }, {
    "tStartMs": 5272373,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "first of all, everybody should enter\nto a space which is growing"
    } ]
  }, {
    "tStartMs": 5275653,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "and has a larger time."
    } ]
  }, {
    "tStartMs": 5276773,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "There is no point to enter to a space"
    } ]
  }, {
    "tStartMs": 5278253,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "which doesn't grow\nor doesn't have a future."
    } ]
  }, {
    "tStartMs": 5280893,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "For an example,\nit's not large enough because--"
    } ]
  }, {
    "tStartMs": 5283053,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "You are saying first you make a box of--"
    } ]
  }, {
    "tStartMs": 5285053,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "I mean, if the segment is big and growing,\nthen it's a point to go"
    } ]
  }, {
    "tStartMs": 5288653,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "because if you're a 2% player also,\nyou will be a sizable company."
    } ]
  }, {
    "tStartMs": 5291573,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "Let's say if you go in a market\nwhich is 1,000 crore overall revenue,"
    } ]
  }, {
    "tStartMs": 5295133,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "you become 5% also,\nyou would be a 50 crore company."
    } ]
  }, {
    "tStartMs": 5297493,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "-It doesn't make sense.\n-Which one is growing?"
    } ]
  }, {
    "tStartMs": 5299773,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "The fastest."
    } ]
  }, {
    "tStartMs": 5301053,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "No, so, okay, in our space,"
    } ]
  }, {
    "tStartMs": 5302853,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "let me take you through top-down,\nyou might understand."
    } ]
  }, {
    "tStartMs": 5305613,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Let's say in this case,"
    } ]
  }, {
    "tStartMs": 5306693,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "this is a 60 million-odd devices\nwe sell in a year,"
    } ]
  }, {
    "tStartMs": 5309653,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "which is six crores."
    } ]
  }, {
    "tStartMs": 5311093,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "And interestingly,\n90% devices get sold below $25,"
    } ]
  }, {
    "tStartMs": 5315293,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "which is sub 2,000 rupees."
    } ]
  }, {
    "tStartMs": 5317013,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "You're talking about Bluetooth earphones?"
    } ]
  }, {
    "tStartMs": 5318653,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Bluetooth earphones."
    } ]
  }, {
    "tStartMs": 5320173,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "And that is 60% of the market revenue."
    } ]
  }, {
    "tStartMs": 5323213,
    "dDurationMs": 6360,
    "segs": [ {
      "utf8": "Which is what 5,000 crore is like,\nthis market."
    } ]
  }, {
    "tStartMs": 5330253,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "And $25 to $75, which is medium segment,\nentry-mid premium,"
    } ]
  }, {
    "tStartMs": 5335093,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "that is close to 7%..."
    } ]
  }, {
    "tStartMs": 5338493,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "and would be 15% of the market."
    } ]
  }, {
    "tStartMs": 5341373,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "And then it is all $150 plus,"
    } ]
  }, {
    "tStartMs": 5344893,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "majority Apple,\n1% market share, and then..."
    } ]
  }, {
    "tStartMs": 5349013,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "[Nikhil] So are you saying\nit's a good market?"
    } ]
  }, {
    "tStartMs": 5350573,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "If I want to start,\nsay I have raised one million dollars."
    } ]
  }, {
    "tStartMs": 5353573,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "Should I start a earphone, earpod company?"
    } ]
  }, {
    "tStartMs": 5355973,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "So I personally think technology works\nin a very different way."
    } ]
  }, {
    "tStartMs": 5358853,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "It's not like fashion,"
    } ]
  }, {
    "tStartMs": 5360013,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "where you just create a product\nand sell it at any price point."
    } ]
  }, {
    "tStartMs": 5365973,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "Technology you need an access to partners\nwe were talking about,"
    } ]
  }, {
    "tStartMs": 5369133,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "a lot of proprietary things."
    } ]
  }, {
    "tStartMs": 5371493,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "So I think it's a very tough space\nfor somebody to enter."
    } ]
  }, {
    "tStartMs": 5374053,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "Yes, somebody want to enter into sub $20,\nyes, they can."
    } ]
  }, {
    "tStartMs": 5377533,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "But that's the race to bottom."
    } ]
  }, {
    "tStartMs": 5378973,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "And 20 to 50, which is a sweet spot,\nlike a 1,000 or 1,500 crore market,"
    } ]
  }, {
    "tStartMs": 5383453,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "it's tough,\nand bigger brands are sitting there."
    } ]
  }, {
    "tStartMs": 5385813,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "And when you say partner,\neverybody's partner is China?"
    } ]
  }, {
    "tStartMs": 5388533,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "No, no, it's not about those partners."
    } ]
  }, {
    "tStartMs": 5390053,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "We have partners."
    } ]
  }, {
    "tStartMs": 5391533,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "So one is partners\nwho are giving us chipsets,"
    } ]
  }, {
    "tStartMs": 5395693,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "but then you need to have\nyour own app teams,"
    } ]
  }, {
    "tStartMs": 5398573,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "you need to have your own algorithms\nwe were talking about."
    } ]
  }, {
    "tStartMs": 5402053,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So those expertise is also needed."
    } ]
  }, {
    "tStartMs": 5403973,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "-Mainly supply chain.\n-Supply chain. Yeah."
    } ]
  }, {
    "tStartMs": 5406213,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "For us, we have US partners,\nChinese partners, Japanese, Korean."
    } ]
  }, {
    "tStartMs": 5411173,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Yes, it's very international."
    } ]
  }, {
    "tStartMs": 5412893,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "So how do I... Say I have an idea\nto start an earpod company,"
    } ]
  }, {
    "tStartMs": 5417693,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "how do I connect with these partners?"
    } ]
  }, {
    "tStartMs": 5421533,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "I'm a newbie, I have no track record."
    } ]
  }, {
    "tStartMs": 5423653,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "You have not worked in this industry?"
    } ]
  }, {
    "tStartMs": 5425173,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "-I've not worked in this industry.\n-Completely coming from outside?"
    } ]
  }, {
    "tStartMs": 5427853,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I personally think, Nikhil,"
    } ]
  }, {
    "tStartMs": 5429613,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "it's really tough until and unless\nyou're getting to a segment"
    } ]
  }, {
    "tStartMs": 5433853,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "which is fairly new\nand not being cracked by all of us."
    } ]
  }, {
    "tStartMs": 5436813,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "I mean, a niche space."
    } ]
  }, {
    "tStartMs": 5438653,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "But, see,\nyou guys started recently, right?"
    } ]
  }, {
    "tStartMs": 5440573,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "-You started--\n-I'll give you one example."
    } ]
  }, {
    "tStartMs": 5442293,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "So I did OnePlus,"
    } ]
  }, {
    "tStartMs": 5444333,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "so I'm relatively known\nin the industry, right?"
    } ]
  }, {
    "tStartMs": 5446133,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "In the electronics industry."
    } ]
  }, {
    "tStartMs": 5448893,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "And when we started this new company,\nNothing, we wanted to make phones."
    } ]
  }, {
    "tStartMs": 5453133,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Nobody wanted to make phones for us."
    } ]
  }, {
    "tStartMs": 5455133,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "They said,\n\"Hey, look at the past ten years."
    } ]
  }, {
    "tStartMs": 5457413,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "So many startups have come and failed,\nand why are you different?"
    } ]
  }, {
    "tStartMs": 5460653,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "You raise money. They also raise money."
    } ]
  }, {
    "tStartMs": 5462573,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "You have experience.\nThey also have experience."
    } ]
  }, {
    "tStartMs": 5465213,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "We're not gonna make a phone for you."
    } ]
  }, {
    "tStartMs": 5466613,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Like, go away.\""
    } ]
  }, {
    "tStartMs": 5468213,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "And then we're like,\n\"Okay, we can't make a phone."
    } ]
  }, {
    "tStartMs": 5471573,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Maybe we can make earbuds first\nto prove ourselves,"
    } ]
  }, {
    "tStartMs": 5473733,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "to prove the skills of our team.\""
    } ]
  }, {
    "tStartMs": 5475853,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "We go to the earbud factories,\nand they also tell us to go away."
    } ]
  }, {
    "tStartMs": 5480173,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "They're like, \"Hey, just go on Amazon.\nThere's 2,000, 3,000 earbuds brands."
    } ]
  }, {
    "tStartMs": 5485253,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Who are you? What's your differentiation?"
    } ]
  }, {
    "tStartMs": 5487253,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "What's your strategy?\nHow much money have you raised?"
    } ]
  }, {
    "tStartMs": 5490933,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Go away.\""
    } ]
  }, {
    "tStartMs": 5492693,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "We were shocked."
    } ]
  }, {
    "tStartMs": 5494413,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "We thought we had some reputation\nin the industry"
    } ]
  }, {
    "tStartMs": 5497733,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "that some of the factories\nwanna work with us."
    } ]
  }, {
    "tStartMs": 5500333,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "So what changed? How did you do it?"
    } ]
  }, {
    "tStartMs": 5502973,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "We went to the worst factory."
    } ]
  }, {
    "tStartMs": 5505693,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "Like, the factory,\nif they didn't take us on as a client,"
    } ]
  }, {
    "tStartMs": 5509693,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "they would go out of business immediately."
    } ]
  }, {
    "tStartMs": 5510973,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "In China?"
    } ]
  }, {
    "tStartMs": 5512053,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "In China,\nbecause they were on the blacklist"
    } ]
  }, {
    "tStartMs": 5513893,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "of a lot of other people\nfor quality issues."
    } ]
  }, {
    "tStartMs": 5515813,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "And how did you find this factory?"
    } ]
  }, {
    "tStartMs": 5519493,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "One of my co-founders, I think he..."
    } ]
  }, {
    "tStartMs": 5522933,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "yeah, he knew some of the salespeople\nin the supply chain"
    } ]
  }, {
    "tStartMs": 5524973,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "and found this factory."
    } ]
  }, {
    "tStartMs": 5526733,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "But this was a factory\nthat had been put on the blacklist"
    } ]
  }, {
    "tStartMs": 5532333,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "'cause of quality issues."
    } ]
  }, {
    "tStartMs": 5533853,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "But we had no other choice."
    } ]
  }, {
    "tStartMs": 5535173,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Nobody wanted to work for us."
    } ]
  }, {
    "tStartMs": 5536853,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "That's where we started."
    } ]
  }, {
    "tStartMs": 5537933,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "That's true for all of us."
    } ]
  }, {
    "tStartMs": 5539013,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "We had to start work with factories\nwhich were less known."
    } ]
  }, {
    "tStartMs": 5542613,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "People don't want to work"
    } ]
  }, {
    "tStartMs": 5543693,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "because bigger factories\ndon't want to touch you also."
    } ]
  }, {
    "tStartMs": 5545653,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "They are saying we are happy\nmaking Apple, Boses of the universe,"
    } ]
  }, {
    "tStartMs": 5549493,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "and we don't want to--"
    } ]
  }, {
    "tStartMs": 5551093,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "But how do, I as a 20-year-old,\nfind this factory?"
    } ]
  }, {
    "tStartMs": 5553613,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Like, you had somebody."
    } ]
  }, {
    "tStartMs": 5554773,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "I think you can't. Like, they won't--"
    } ]
  }, {
    "tStartMs": 5556973,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "What if I just go to China\nand look for them?"
    } ]
  }, {
    "tStartMs": 5559253,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "There is no reason for them to engage.\nLike..."
    } ]
  }, {
    "tStartMs": 5563573,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Nikhil, these are the large businesses,"
    } ]
  }, {
    "tStartMs": 5565133,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "for example,\nif you see the size in terms of value,"
    } ]
  }, {
    "tStartMs": 5568453,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "automobile and mobile phone\nwill be similar."
    } ]
  }, {
    "tStartMs": 5570453,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "-In terms of value.\n-Very right."
    } ]
  }, {
    "tStartMs": 5572693,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "So if I reach out to one of you guys,"
    } ]
  }, {
    "tStartMs": 5575133,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "if I happen to know you,\nand ask that you connect me to a factory,"
    } ]
  }, {
    "tStartMs": 5579613,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "is that the way to do it?"
    } ]
  }, {
    "tStartMs": 5581133,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "If we connect also to the factories,"
    } ]
  }, {
    "tStartMs": 5583493,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "factories has no motivation\nto work with you"
    } ]
  }, {
    "tStartMs": 5585733,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "because everybody works with MOQ,\ncertain processes."
    } ]
  }, {
    "tStartMs": 5590533,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "-[Carl] Yeah.\n-They find you working with..."
    } ]
  }, {
    "tStartMs": 5594093,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I would need to pitch who you are."
    } ]
  }, {
    "tStartMs": 5595853,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "I will go to this founder of the factory."
    } ]
  }, {
    "tStartMs": 5597653,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "\"Hey, I have a friend\nwho wants to talk to you."
    } ]
  }, {
    "tStartMs": 5600653,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "This is this person's background\nand credentials."
    } ]
  }, {
    "tStartMs": 5603373,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Can I make the intro or not?\""
    } ]
  }, {
    "tStartMs": 5605893,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "So..."
    } ]
  }, {
    "tStartMs": 5607213,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "So I have a recent example\ngoing on right now."
    } ]
  }, {
    "tStartMs": 5609493,
    "dDurationMs": 4960,
    "segs": [ {
      "utf8": "So right now we have this technology\nof making connected glasses."
    } ]
  }, {
    "tStartMs": 5614533,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Right."
    } ]
  }, {
    "tStartMs": 5615973,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "Because we feel that's the future,\nthat's where buyers are going to move."
    } ]
  }, {
    "tStartMs": 5619493,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "We are trying to find out\nwho are the right brands"
    } ]
  }, {
    "tStartMs": 5622773,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "who can do these glasses"
    } ]
  }, {
    "tStartMs": 5625133,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "and established brands\nin the glasses space,"
    } ]
  }, {
    "tStartMs": 5629413,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "right now who exist,\npitching it to them that, \"Hey, look--\""
    } ]
  }, {
    "tStartMs": 5632093,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Like Meta glasses?"
    } ]
  }, {
    "tStartMs": 5633333,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "-Exactly same.\n-[Nikhil] Right."
    } ]
  }, {
    "tStartMs": 5634533,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Exactly same."
    } ]
  }, {
    "tStartMs": 5635613,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "Actually, with Meta, along with Meta."
    } ]
  }, {
    "tStartMs": 5639853,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "When you say along with Meta--"
    } ]
  }, {
    "tStartMs": 5641253,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "Meta, the operating system,\nfor example, the whole AI is from Meta."
    } ]
  }, {
    "tStartMs": 5645893,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "So, for example, they have done\nthe same partnership with Luxottica,"
    } ]
  }, {
    "tStartMs": 5649973,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "-Ray-Ban, similar.\n-[Nikhil] Right. Right."
    } ]
  }, {
    "tStartMs": 5653973,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "Do you guys think\nthere is an opportunity there?"
    } ]
  }, {
    "tStartMs": 5656013,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "The form is changing,"
    } ]
  }, {
    "tStartMs": 5657213,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "and it moves from cell phone\nto something else?"
    } ]
  }, {
    "tStartMs": 5661293,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "No, I think, interestingly,\nour industry is evolving every decade."
    } ]
  }, {
    "tStartMs": 5665173,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "So, like, nobody thought that Nokia\ncould be disrupted, for an example."
    } ]
  }, {
    "tStartMs": 5669533,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "So any of our devices could be disrupted,\nand form factors are definitely changing."
    } ]
  }, {
    "tStartMs": 5674213,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "People are working aggressively\non glasses."
    } ]
  }, {
    "tStartMs": 5677533,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "So that is one form factor to look into."
    } ]
  }, {
    "tStartMs": 5679853,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "But like he said,\nit's a game of people who have..."
    } ]
  }, {
    "tStartMs": 5683133,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "For glasses,\nI think all mobility is working."
    } ]
  }, {
    "tStartMs": 5685613,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Entire mobile brands in the world\nare working towards that."
    } ]
  }, {
    "tStartMs": 5688293,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "So it becomes very difficult\nfor a young company to still compete."
    } ]
  }, {
    "tStartMs": 5692733,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "Glasses, you can do."
    } ]
  }, {
    "tStartMs": 5695053,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Glasses, you can do."
    } ]
  }, {
    "tStartMs": 5696573,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "[Amit] You got one..."
    } ]
  }, {
    "tStartMs": 5699213,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "one gap."
    } ]
  }, {
    "tStartMs": 5700613,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "No, there is. Because, see,\nlook at the glasses industry."
    } ]
  }, {
    "tStartMs": 5704573,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "Last year, Meta, with Luxottica,\nand these are public numbers,"
    } ]
  }, {
    "tStartMs": 5708973,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "they sold two million glasses,\ntwo million."
    } ]
  }, {
    "tStartMs": 5712733,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "And the number what is being projected\nin the next four years"
    } ]
  }, {
    "tStartMs": 5716253,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "is around 30 million."
    } ]
  }, {
    "tStartMs": 5717333,
    "dDurationMs": 6760,
    "segs": [ {
      "utf8": "That's a CAGR of, let's say,\nmore than 43, 45% on an annual basis."
    } ]
  }, {
    "tStartMs": 5724173,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Right?"
    } ]
  }, {
    "tStartMs": 5725253,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "And... since we have been working on that,\nso the tech is..."
    } ]
  }, {
    "tStartMs": 5730133,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "So earlier the glasses came\nwith only speaker here."
    } ]
  }, {
    "tStartMs": 5733533,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "-Yeah, yeah.\n-Right?"
    } ]
  }, {
    "tStartMs": 5734813,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "-Old. Yeah, yeah.\n-Yeah?"
    } ]
  }, {
    "tStartMs": 5737053,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Gen 2, there was a camera."
    } ]
  }, {
    "tStartMs": 5738613,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 5741573,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "And let's say Gen 3\nwith this whole AI engine coming in there."
    } ]
  }, {
    "tStartMs": 5747093,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "Gen 4, you have a heads-up display."
    } ]
  }, {
    "tStartMs": 5748933,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Correct."
    } ]
  }, {
    "tStartMs": 5750173,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Now once you have a heads-up display,"
    } ]
  }, {
    "tStartMs": 5752413,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "then whatever, for example,\nis going on my cell phone,"
    } ]
  }, {
    "tStartMs": 5754733,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "I have a display here."
    } ]
  }, {
    "tStartMs": 5756173,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "On the frame?"
    } ]
  }, {
    "tStartMs": 5757453,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "No, no, not on the frame."
    } ]
  }, {
    "tStartMs": 5758613,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "It is a heads-up display\nlike you have in your cars."
    } ]
  }, {
    "tStartMs": 5760093,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "You are projecting onto a wall."
    } ]
  }, {
    "tStartMs": 5761253,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "No, no, not on the wall."
    } ]
  }, {
    "tStartMs": 5763093,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "-Just like in a car speedometer.\n-Yeah, yeah."
    } ]
  }, {
    "tStartMs": 5765533,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "It is a heads-up display. You can see."
    } ]
  }, {
    "tStartMs": 5767493,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "So here I can see."
    } ]
  }, {
    "tStartMs": 5769373,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "So today, for example, if it is in,\nlet's say, black and white,"
    } ]
  }, {
    "tStartMs": 5774053,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "tomorrow it will be all coloured."
    } ]
  }, {
    "tStartMs": 5775733,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "It will evolve."
    } ]
  }, {
    "tStartMs": 5777573,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "And then, for example,\nif you are watching your Instagram Reels,"
    } ]
  }, {
    "tStartMs": 5780573,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "you are just flicking it."
    } ]
  }, {
    "tStartMs": 5782853,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Just sitting,\nand then you are not taking out your phone"
    } ]
  }, {
    "tStartMs": 5784533,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "because rest of..."
    } ]
  }, {
    "tStartMs": 5785653,
    "dDurationMs": 4920,
    "segs": [ {
      "utf8": "See, in your phone, you have a display,\nyou have speaker, mic, and a camera."
    } ]
  }, {
    "tStartMs": 5791813,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "All things are solved."
    } ]
  }, {
    "tStartMs": 5794133,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Then why do you need\nto take out your phone?"
    } ]
  }, {
    "tStartMs": 5796133,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Do you think that will be the future\nof form?"
    } ]
  }, {
    "tStartMs": 5798573,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Cell phone will move to glasses?"
    } ]
  }, {
    "tStartMs": 5800453,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "See, nobody can just firmly say that,\n\"Okay, this is...\""
    } ]
  }, {
    "tStartMs": 5803413,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Although, for example, Zuckerberg has said\nthat this is going to be."
    } ]
  }, {
    "tStartMs": 5806493,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "But he said the Oculus\nand all of those things"
    } ]
  }, {
    "tStartMs": 5809053,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "were the form as well for a long time,\nwhich didn't play out, right?"
    } ]
  }, {
    "tStartMs": 5811653,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[Rahul] You're correct."
    } ]
  }, {
    "tStartMs": 5813413,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "So, as I said, see, it is nothing right,\nnothing wrong."
    } ]
  }, {
    "tStartMs": 5816693,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "You have to go out in the market\nand test it out."
    } ]
  }, {
    "tStartMs": 5818533,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "-Hmm.\n-[Rahul] Right?"
    } ]
  }, {
    "tStartMs": 5820093,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "But looking at the tech right now,\nwhat exactly is it going to solve?"
    } ]
  }, {
    "tStartMs": 5824893,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "I think I've seen\nall the new glasses coming up."
    } ]
  }, {
    "tStartMs": 5827893,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "I seriously feel that this will be\nthe form factor to watch out for."
    } ]
  }, {
    "tStartMs": 5832253,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "-[Nikhil] Right.\n-[Rahul] Yes."
    } ]
  }, {
    "tStartMs": 5833933,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "So if somebody new watching this\nwants to get into the industry,"
    } ]
  }, {
    "tStartMs": 5837093,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "this is the industry."
    } ]
  }, {
    "tStartMs": 5839173,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "-Right.\n-I have a different approach."
    } ]
  }, {
    "tStartMs": 5842333,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "If somebody was young and watching this"
    } ]
  }, {
    "tStartMs": 5844373,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "and wanting to get\ninto consumer electronics,"
    } ]
  }, {
    "tStartMs": 5847333,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "I would urge them\nto first become a content creator."
    } ]
  }, {
    "tStartMs": 5850813,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Bang on!"
    } ]
  }, {
    "tStartMs": 5851893,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "-Marketing.\n-Because the barrier to entry is very low."
    } ]
  }, {
    "tStartMs": 5854933,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Everybody can do it."
    } ]
  }, {
    "tStartMs": 5856693,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And that is the arbitrage opportunity now."
    } ]
  }, {
    "tStartMs": 5858693,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "Like, the millennials\nand the older people,"
    } ]
  }, {
    "tStartMs": 5861693,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "they're gonna have a harder time to learn\nthe latest algorithms, latest trends."
    } ]
  }, {
    "tStartMs": 5865253,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "100%."
    } ]
  }, {
    "tStartMs": 5867653,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "If you do the content well, like MrBeast,\nnow you can do anything."
    } ]
  }, {
    "tStartMs": 5871333,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "You can make chocolates,\nyou can make a TV show on Amazon."
    } ]
  }, {
    "tStartMs": 5875133,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "When you have the traffic,\nyou have leverage to sell any product."
    } ]
  }, {
    "tStartMs": 5879773,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "Then when I do the intro to the factory,\nthey will, \"That's MrBeast, of course.\""
    } ]
  }, {
    "tStartMs": 5883773,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "He's just some random kid,\nit's impossible."
    } ]
  }, {
    "tStartMs": 5886173,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "But I feel there are very niche spaces\nwhich are coming up"
    } ]
  }, {
    "tStartMs": 5890653,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "which none of us are solving\nas bigger companies."
    } ]
  }, {
    "tStartMs": 5893973,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "When you look at our space,\nthis product..."
    } ]
  }, {
    "tStartMs": 5897773,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "hearing aids, is a decent space."
    } ]
  }, {
    "tStartMs": 5899653,
    "dDurationMs": 5480,
    "segs": [ {
      "utf8": "But right now it's like 150,000,\n1,50,000 rupees or $2,000,"
    } ]
  }, {
    "tStartMs": 5905213,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "there is a hearing aid, it looks ugly."
    } ]
  }, {
    "tStartMs": 5908653,
    "dDurationMs": 4760,
    "segs": [ {
      "utf8": "I see industry working in a space\nwhich is over-the-counter hearing aids,"
    } ]
  }, {
    "tStartMs": 5913493,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "way affordable, looking better."
    } ]
  }, {
    "tStartMs": 5916053,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "That is one market."
    } ]
  }, {
    "tStartMs": 5917893,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And when you look at our category,\nwearables,"
    } ]
  }, {
    "tStartMs": 5919893,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "I see now penetration has happened\nin wearables."
    } ]
  }, {
    "tStartMs": 5922493,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Like, as parents, we have used, Rahul."
    } ]
  }, {
    "tStartMs": 5924933,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "Now the problem is we have aging parents."
    } ]
  }, {
    "tStartMs": 5927333,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "We need a device for them\nwhich could monitor their health."
    } ]
  }, {
    "tStartMs": 5929613,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "And more importantly,\nwe live in urban cities, we have kids."
    } ]
  }, {
    "tStartMs": 5934893,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "And you won't believe, I get a message\nfrom five people every day,"
    } ]
  }, {
    "tStartMs": 5938253,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "\"Do you have a kid's watch?\""
    } ]
  }, {
    "tStartMs": 5939693,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Because none of us\nare looking at this space,"
    } ]
  }, {
    "tStartMs": 5941573,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "the space stands at zero."
    } ]
  }, {
    "tStartMs": 5943173,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "You're saying for kids\nand senior monitoring?"
    } ]
  }, {
    "tStartMs": 5945373,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "I mean, we have two spaces,\nbecause, see, first market--"
    } ]
  }, {
    "tStartMs": 5947973,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "But can't an Apple Watch do that?"
    } ]
  }, {
    "tStartMs": 5950613,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "Apple Watch does it,\nbut it's 50,000 rupees."
    } ]
  }, {
    "tStartMs": 5953653,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "Will India price point get solved\nwith 50,000 bucks?"
    } ]
  }, {
    "tStartMs": 5956813,
    "dDurationMs": 4760,
    "segs": [ {
      "utf8": "India would need a watch for a parent,\nmaybe at eight to ten thousand rupees."
    } ]
  }, {
    "tStartMs": 5961653,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Not a 50,000, 100%."
    } ]
  }, {
    "tStartMs": 5964213,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "So coming up to his point of hearing aids."
    } ]
  }, {
    "tStartMs": 5969013,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "Again, anybody watching,\nthere's a space to disrupt."
    } ]
  }, {
    "tStartMs": 5972573,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Because all the hearing aids, if you see,"
    } ]
  }, {
    "tStartMs": 5973813,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "are, like, one lakh rupees,\ntwo lakh rupees,"
    } ]
  }, {
    "tStartMs": 5976893,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "-close to three lakh rupees.\n-Two lakh rupees."
    } ]
  }, {
    "tStartMs": 5979173,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "I, you know,\nwent to buy for my dad to a doctor."
    } ]
  }, {
    "tStartMs": 5982853,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "It's 1.5 lakh rupees, hearing aid."
    } ]
  }, {
    "tStartMs": 5986133,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And I said, \"You have a better one?\""
    } ]
  }, {
    "tStartMs": 5987893,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "He said, \"Yeah, it's two lakh rupees.\""
    } ]
  }, {
    "tStartMs": 5989613,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "I said, \"What is the difference?\"\n\"Software difference.\""
    } ]
  }, {
    "tStartMs": 5992053,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "On phone."
    } ]
  }, {
    "tStartMs": 5993573,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "With this, we give you three more\nextra features which you can unlock."
    } ]
  }, {
    "tStartMs": 5996533,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "-It's very uncompetitive market.\n-Yeah."
    } ]
  }, {
    "tStartMs": 5998533,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "I said, \"Why?\""
    } ]
  }, {
    "tStartMs": 6000453,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "He said, \"No, no, with these features,\nyou'll be able to understand"
    } ]
  }, {
    "tStartMs": 6004213,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "if the voice is coming\nfrom behind or front, all these things.\""
    } ]
  }, {
    "tStartMs": 6007053,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "Then I went into\nwhy these hearing aids are expensive."
    } ]
  }, {
    "tStartMs": 6011733,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Because back then,"
    } ]
  }, {
    "tStartMs": 6013453,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "putting something in a small form factor\nwas expensive."
    } ]
  }, {
    "tStartMs": 6018173,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Was expensive at that time."
    } ]
  }, {
    "tStartMs": 6019733,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "But not today."
    } ]
  }, {
    "tStartMs": 6020813,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "I think, no,\nit's not about this also, Rahul."
    } ]
  }, {
    "tStartMs": 6023613,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "So cost would be cheaper for\nthe manufacturer who is selling it brand."
    } ]
  }, {
    "tStartMs": 6026373,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "But it's just about only one or two brands\ndoing that business,"
    } ]
  }, {
    "tStartMs": 6029613,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "selling at maybe 80%, 90% gross margin."
    } ]
  }, {
    "tStartMs": 6032013,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "-There is one company I'm just forgetting.\n-They have the majority market share."
    } ]
  }, {
    "tStartMs": 6034493,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "They have all the three big brands"
    } ]
  }, {
    "tStartMs": 6035653,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "-in the world.\n-Yeah, yeah, yeah."
    } ]
  }, {
    "tStartMs": 6037333,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "-Hearing aids?\n-Yeah."
    } ]
  }, {
    "tStartMs": 6038653,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "There is one company\nwho has bought out all others."
    } ]
  }, {
    "tStartMs": 6040533,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Three to four big brands in the world."
    } ]
  }, {
    "tStartMs": 6042053,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Is it a big market?"
    } ]
  }, {
    "tStartMs": 6043533,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "It's a narrow, not big."
    } ]
  }, {
    "tStartMs": 6045893,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "-But--\n-Is there another advice?"
    } ]
  }, {
    "tStartMs": 6048253,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Pick narrow markets"
    } ]
  }, {
    "tStartMs": 6049333,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "where the large incumbents\nare not going after?"
    } ]
  }, {
    "tStartMs": 6052533,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "-Yes, if you're passionate about it.\n-[Amit] Yeah."
    } ]
  }, {
    "tStartMs": 6055373,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Passion has to keep you going."
    } ]
  }, {
    "tStartMs": 6056853,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "Explain, like, why would I be passionate\nabout hearing aids?"
    } ]
  }, {
    "tStartMs": 6059253,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "That's what I mean."
    } ]
  }, {
    "tStartMs": 6060333,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "If you are not passionate\nabout a business you're starting,"
    } ]
  }, {
    "tStartMs": 6062853,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "like, businesses are tough."
    } ]
  }, {
    "tStartMs": 6064373,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "There are some good days\nand a lot of terrible days."
    } ]
  }, {
    "tStartMs": 6067213,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "So if you are not really in love\nwith what you are doing,"
    } ]
  }, {
    "tStartMs": 6069373,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "it's hard to persevere\nwhen it gets really difficult."
    } ]
  }, {
    "tStartMs": 6073213,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "But can I be passionate\nabout hearing aids?"
    } ]
  }, {
    "tStartMs": 6074773,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Some people are passionate about it."
    } ]
  }, {
    "tStartMs": 6076293,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Some people are, by the way.\nThey are trying to solve real problems."
    } ]
  }, {
    "tStartMs": 6078813,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "No, we are."
    } ]
  }, {
    "tStartMs": 6080533,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "If somebody wants to do it, you know,\ncrack the code, go out of it."
    } ]
  }, {
    "tStartMs": 6085933,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "So, for example, you are saying\nyou want to introduce someone and all."
    } ]
  }, {
    "tStartMs": 6089413,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "I mean, we can introduce to them\nall the chipset players,"
    } ]
  }, {
    "tStartMs": 6091813,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "you know, all whatever."
    } ]
  }, {
    "tStartMs": 6092933,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "Because nobody is there in that space\nthat's available for somebody to take on."
    } ]
  }, {
    "tStartMs": 6096293,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "And we are ready to fund them."
    } ]
  }, {
    "tStartMs": 6098093,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "100%."
    } ]
  }, {
    "tStartMs": 6099173,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Think I am not interviewing you guys."
    } ]
  }, {
    "tStartMs": 6102253,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "Think I am a 20-year-old boy\nsitting in a room."
    } ]
  }, {
    "tStartMs": 6105613,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "I have had the great opportunity\nof sitting with three of you."
    } ]
  }, {
    "tStartMs": 6108653,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "I have a million dollars."
    } ]
  }, {
    "tStartMs": 6110013,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "I want to build something\nin consumer electronics."
    } ]
  }, {
    "tStartMs": 6112413,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "I live in Bangalore, in India."
    } ]
  }, {
    "tStartMs": 6114973,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "So you three have a conversation,\nand I will try and learn along the way."
    } ]
  }, {
    "tStartMs": 6119213,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "And intervene once in a while."
    } ]
  }, {
    "tStartMs": 6120653,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "What else?"
    } ]
  }, {
    "tStartMs": 6121733,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "We have already given the cards,\nfor example."
    } ]
  }, {
    "tStartMs": 6123973,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "You know, the glasses, hearing aids."
    } ]
  }, {
    "tStartMs": 6127853,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "-[Nikhil] What else?\n-What not-- I'll be very clear."
    } ]
  }, {
    "tStartMs": 6129973,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "If somebody is trying to go\nto a commodity market, it's no-go."
    } ]
  }, {
    "tStartMs": 6134053,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "It's a race to bottom.\nThere is no winning there."
    } ]
  }, {
    "tStartMs": 6135733,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "What is a commodity?"
    } ]
  }, {
    "tStartMs": 6137253,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "I mean, let's say somebody says,"
    } ]
  }, {
    "tStartMs": 6138333,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "\"I want to do a earbud\nwhich is 1,500 bucks.\""
    } ]
  }, {
    "tStartMs": 6141693,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "No go."
    } ]
  }, {
    "tStartMs": 6142773,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "How will you win?"
    } ]
  }, {
    "tStartMs": 6143853,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "I mean, what's your right to win\nwhen there's overcrowded market?"
    } ]
  }, {
    "tStartMs": 6146973,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And when large players are there."
    } ]
  }, {
    "tStartMs": 6148733,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "I am a content creator.\nI have distribution."
    } ]
  }, {
    "tStartMs": 6150333,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Let's add that."
    } ]
  }, {
    "tStartMs": 6151413,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "I'll tell you, content creator\nalso has a shelf threshold of,"
    } ]
  }, {
    "tStartMs": 6155293,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "let's say,\nwhatever million followers they have."
    } ]
  }, {
    "tStartMs": 6157413,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "They could reach to 5,000 units,\n10,000 units, not beyond that."
    } ]
  }, {
    "tStartMs": 6161453,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "Did somebody, a content creator,\nrecently sell a watch, and he sold a lot?"
    } ]
  }, {
    "tStartMs": 6165733,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "-Yeah.\n-What was his name?"
    } ]
  }, {
    "tStartMs": 6167893,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Shlok, nah?"
    } ]
  }, {
    "tStartMs": 6169333,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Anarc. Layers."
    } ]
  }, {
    "tStartMs": 6170853,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "-Yeah.\n-Shlok."
    } ]
  }, {
    "tStartMs": 6172013,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "-Yeah, yeah, yeah.\n-Tech Burner."
    } ]
  }, {
    "tStartMs": 6174253,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "So they did it, but if you look into it--"
    } ]
  }, {
    "tStartMs": 6176653,
    "dDurationMs": 5520,
    "segs": [ {
      "utf8": "What if the kid is ten times\nor hundred times bigger than Tech Burner?"
    } ]
  }, {
    "tStartMs": 6183093,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "MrBeast has done that."
    } ]
  }, {
    "tStartMs": 6184173,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "But I'm just saying.\nTech is very different."
    } ]
  }, {
    "tStartMs": 6186213,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "Tech, they failed because the product\nwas not up to the mark."
    } ]
  }, {
    "tStartMs": 6190733,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "They were new in the town."
    } ]
  }, {
    "tStartMs": 6192253,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "See, it's not like selling T-shirt."
    } ]
  }, {
    "tStartMs": 6193453,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "You can just stitch it and sell it."
    } ]
  }, {
    "tStartMs": 6194973,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "And there is no tech to it."
    } ]
  }, {
    "tStartMs": 6196933,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "A same factory makes a 300-rupees T-shirt\nand a 30,000-rupees T-shirt also."
    } ]
  }, {
    "tStartMs": 6200733,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Tech is not like that."
    } ]
  }, {
    "tStartMs": 6201813,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "But if you're outsourcing the tech,\nthe production,"
    } ]
  }, {
    "tStartMs": 6204493,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "if you're going to a co-packer almost--"
    } ]
  }, {
    "tStartMs": 6206253,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "No, it's not like this business."
    } ]
  }, {
    "tStartMs": 6209173,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "So, like all of us,\nwe choose what components to get into."
    } ]
  }, {
    "tStartMs": 6213493,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "That will get into it.\nIt's a super customised business."
    } ]
  }, {
    "tStartMs": 6216653,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Some of the software layers\nare being customised"
    } ]
  }, {
    "tStartMs": 6218733,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "at our level in our teams."
    } ]
  }, {
    "tStartMs": 6220853,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Some are outsourced."
    } ]
  }, {
    "tStartMs": 6221933,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "-Am I right, Carl?\n-Yes."
    } ]
  }, {
    "tStartMs": 6223293,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "And then we design a product,\nand then it comes out."
    } ]
  }, {
    "tStartMs": 6226053,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "It's like a CPU."
    } ]
  }, {
    "tStartMs": 6227573,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "It's just not you buy from it."
    } ]
  }, {
    "tStartMs": 6229133,
    "dDurationMs": 4880,
    "segs": [ {
      "utf8": "You choose specific components,\nrun software on it, develop software."
    } ]
  }, {
    "tStartMs": 6234093,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "It's not that easy.\nThat's why companies are failing."
    } ]
  }, {
    "tStartMs": 6235893,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "So I had the same idea\nbefore trying this business."
    } ]
  }, {
    "tStartMs": 6240573,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "There's a bunch of factories.\nThey all know how to make it."
    } ]
  }, {
    "tStartMs": 6242413,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "We just go and order and then pay them."
    } ]
  }, {
    "tStartMs": 6244893,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "It shows up. Done."
    } ]
  }, {
    "tStartMs": 6247133,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "That can't be further away from the truth."
    } ]
  }, {
    "tStartMs": 6249973,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "Like, these factories, sure,\nthey have the common models"
    } ]
  }, {
    "tStartMs": 6252373,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "that you can buy off the shelf."
    } ]
  }, {
    "tStartMs": 6253573,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "-But everybody can buy those.\n-[Amit] Yeah."
    } ]
  }, {
    "tStartMs": 6255653,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "And they don't have the best engineers."
    } ]
  }, {
    "tStartMs": 6257173,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Like, the best engineers,\nthey're not gonna work for a factory."
    } ]
  }, {
    "tStartMs": 6259613,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "They're gonna work for Apple\nor Samsung or, like, a brand, right?"
    } ]
  }, {
    "tStartMs": 6262333,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "So they don't have good engineering."
    } ]
  }, {
    "tStartMs": 6264053,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "So what is happening in China,\nand what is happening at Apple?"
    } ]
  }, {
    "tStartMs": 6266213,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Explain the engineering process."
    } ]
  }, {
    "tStartMs": 6268413,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "We just were discussing\nwhen we went on a break."
    } ]
  }, {
    "tStartMs": 6271013,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "About the camera."
    } ]
  }, {
    "tStartMs": 6272093,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "-Yeah.\n-Yeah."
    } ]
  }, {
    "tStartMs": 6273173,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "Yeah, camera is a great example."
    } ]
  }, {
    "tStartMs": 6275733,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "Like, if you wanna create..."
    } ]
  }, {
    "tStartMs": 6279093,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "There are so many fields\nwithin these products, right?"
    } ]
  }, {
    "tStartMs": 6280733,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "There is a radio antenna,\nthere is industrial design,"
    } ]
  }, {
    "tStartMs": 6283213,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "there is camera, there is software."
    } ]
  }, {
    "tStartMs": 6284893,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "It's like so many different things."
    } ]
  }, {
    "tStartMs": 6286293,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "Everything requires a lot of investment\nand time and energy to do it well."
    } ]
  }, {
    "tStartMs": 6290533,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "So I think maybe taking a step back."
    } ]
  }, {
    "tStartMs": 6293573,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "One piece of advice\nis to really also respect"
    } ]
  }, {
    "tStartMs": 6296773,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "whatever new thing you're doing."
    } ]
  }, {
    "tStartMs": 6298653,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Like, \"Okay, now we are making earbuds."
    } ]
  }, {
    "tStartMs": 6300893,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Let's learn about how to make earbuds,\nhow everything works."
    } ]
  }, {
    "tStartMs": 6303973,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "Well, now we're doing camera tuning.\nLet's really learn about how that works.\""
    } ]
  }, {
    "tStartMs": 6307573,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "So we just have a very simplistic view\nand outsource it to other people."
    } ]
  }, {
    "tStartMs": 6311333,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "If we don't even know\nwhat the underlying principles are,"
    } ]
  }, {
    "tStartMs": 6314973,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "it's gonna be very bad."
    } ]
  }, {
    "tStartMs": 6316253,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "So just for camera,\nwe've been struggling with camera."
    } ]
  }, {
    "tStartMs": 6321133,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "This year, it got a lot better."
    } ]
  }, {
    "tStartMs": 6323973,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "It's not that we are not smart enough."
    } ]
  }, {
    "tStartMs": 6325773,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "But the camera\nis a very hardcore resource investment."
    } ]
  }, {
    "tStartMs": 6329693,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "The way it works is you make the phone\nrecognise the scene."
    } ]
  }, {
    "tStartMs": 6332813,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "The scene could be\ntwo people sitting here."
    } ]
  }, {
    "tStartMs": 6334733,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "It could be nighttime. It could be city."
    } ]
  }, {
    "tStartMs": 6337053,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "Fruits."
    } ]
  }, {
    "tStartMs": 6338373,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "Fruits. The more scenes you can define,\nthe better your pictures will be."
    } ]
  }, {
    "tStartMs": 6342093,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "The more you can define,\nthen each scene will have its own tuning."
    } ]
  }, {
    "tStartMs": 6346373,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "The team will tune it differently\ndepending on the scene"
    } ]
  }, {
    "tStartMs": 6348293,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "to make it as beautiful as possible\nfor this specific scene."
    } ]
  }, {
    "tStartMs": 6352053,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "So if I have a big team,\nI can define a lot of different scenes."
    } ]
  }, {
    "tStartMs": 6355653,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So then there's a very high likelihood"
    } ]
  }, {
    "tStartMs": 6358013,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "that the phone will tune it\nin a way that's nice."
    } ]
  }, {
    "tStartMs": 6360853,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "If I have a small team,\nI can only define a few scenes."
    } ]
  }, {
    "tStartMs": 6364013,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "So if I only have a few scenes,"
    } ]
  }, {
    "tStartMs": 6365173,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "then I'll miss a lot of the long-tail\npotential use cases for the camera."
    } ]
  }, {
    "tStartMs": 6369333,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "And customers are not gonna be happy."
    } ]
  }, {
    "tStartMs": 6370813,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "Yeah, I think identifying gaps,\nand as I said,"
    } ]
  }, {
    "tStartMs": 6375213,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "you know, in terms of passion,\nyou were saying."
    } ]
  }, {
    "tStartMs": 6377373,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "So still so many categories are there."
    } ]
  }, {
    "tStartMs": 6379973,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "Example."
    } ]
  }, {
    "tStartMs": 6381293,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Let's take example of Dyson."
    } ]
  }, {
    "tStartMs": 6382813,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Can you disrupt?"
    } ]
  }, {
    "tStartMs": 6383893,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Bang on."
    } ]
  }, {
    "tStartMs": 6385253,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "So if you look at India as a market,\nthere is no Dyson."
    } ]
  }, {
    "tStartMs": 6387733,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "It's just Dyson,\nwhich is like 40,000 bucks,"
    } ]
  }, {
    "tStartMs": 6390053,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "and there is Bajaj to buy."
    } ]
  }, {
    "tStartMs": 6391213,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "No. So there is a company\ncalled SharkNinja."
    } ]
  }, {
    "tStartMs": 6394293,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "The number one in USA."
    } ]
  }, {
    "tStartMs": 6396133,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "-[Amit] There.\n-Disrupted as in completely."
    } ]
  }, {
    "tStartMs": 6397773,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "By Dyson, do you mean vacuum cleaner,\nhair blower--"
    } ]
  }, {
    "tStartMs": 6400653,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Home. Home. Home."
    } ]
  }, {
    "tStartMs": 6402533,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "You see, if you look at it,\nthere is no young brand in home."
    } ]
  }, {
    "tStartMs": 6405093,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Look at the customer."
    } ]
  }, {
    "tStartMs": 6407093,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Our parents grew up buying Bajaj."
    } ]
  }, {
    "tStartMs": 6409533,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "We aspire to buy Dyson,\nbut Dyson is too expensive."
    } ]
  }, {
    "tStartMs": 6412373,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "So look at that 25 to 35 age group,\nwhat they would buy."
    } ]
  }, {
    "tStartMs": 6416253,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "So, for example,\nif I have to use an analogy,"
    } ]
  }, {
    "tStartMs": 6418853,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "-if Dyson is the Mercedes-Benz...\n-[Amit] Yeah. No, Toyota is there."
    } ]
  }, {
    "tStartMs": 6422253,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "Yeah, a Toyota, a Honda, or a Hyundai."
    } ]
  }, {
    "tStartMs": 6425733,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "We have Maruti."
    } ]
  }, {
    "tStartMs": 6427613,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "So Maruti is Bajaj?"
    } ]
  }, {
    "tStartMs": 6429493,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "I mean, those kind of companies, yeah."
    } ]
  }, {
    "tStartMs": 6432293,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So, you know, these are the segments."
    } ]
  }, {
    "tStartMs": 6434213,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "So you have to really identify those gaps\nand say, \"Yes. Is there a market?\""
    } ]
  }, {
    "tStartMs": 6439853,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "And I think, go for it."
    } ]
  }, {
    "tStartMs": 6441773,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "And if you have a passion and all,\nyou will figure out a way,"
    } ]
  }, {
    "tStartMs": 6444413,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "you know, find out the right people."
    } ]
  }, {
    "tStartMs": 6446733,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Maybe take a step-by-step approach."
    } ]
  }, {
    "tStartMs": 6448813,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "Instead of starting your own company,\nwork for somebody else,"
    } ]
  }, {
    "tStartMs": 6452373,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "-like me.\n-Learn it."
    } ]
  }, {
    "tStartMs": 6456013,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "If there are so many mistakes you can make\nin our industry,"
    } ]
  }, {
    "tStartMs": 6460893,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "if I did not do it, like, once before,"
    } ]
  }, {
    "tStartMs": 6463413,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "the chances of failure\nwould have been way higher."
    } ]
  }, {
    "tStartMs": 6466133,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "It's, like, eight to nine months\nof a cycle when you're committed."
    } ]
  }, {
    "tStartMs": 6469253,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "And when you're committed,"
    } ]
  }, {
    "tStartMs": 6470333,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "you are committed\nwith few million dollars."
    } ]
  }, {
    "tStartMs": 6472173,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "You cannot get out."
    } ]
  }, {
    "tStartMs": 6475013,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "Carl, you have said the easiest way\nto differentiate is design."
    } ]
  }, {
    "tStartMs": 6480333,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "In a bunch of interviews."
    } ]
  }, {
    "tStartMs": 6482253,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "Can't I look at the same devices,\nbut relook design altogether?"
    } ]
  }, {
    "tStartMs": 6487533,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "And do what design?"
    } ]
  }, {
    "tStartMs": 6489013,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Like, relook\nmy design philosophy altogether."
    } ]
  }, {
    "tStartMs": 6492213,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Why do earbuds have to look like this?"
    } ]
  }, {
    "tStartMs": 6494413,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "What if I change\nthe form factor completely?"
    } ]
  }, {
    "tStartMs": 6496773,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Then there is PMF risk."
    } ]
  }, {
    "tStartMs": 6498853,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "What is PMF risk?"
    } ]
  }, {
    "tStartMs": 6500213,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Product-market fit risk."
    } ]
  }, {
    "tStartMs": 6502813,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "So if you look at our products,\nthat product and this product,"
    } ]
  }, {
    "tStartMs": 6507053,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "design is different,\nbut actually there is very low PMF risk"
    } ]
  }, {
    "tStartMs": 6510133,
    "dDurationMs": 4480,
    "segs": [ {
      "utf8": "because these are products\nthat consumers already know how to use,"
    } ]
  }, {
    "tStartMs": 6514693,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "what to use it for."
    } ]
  }, {
    "tStartMs": 6516213,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "They already buy a lot of them\nevery single year."
    } ]
  }, {
    "tStartMs": 6518653,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "If you deviate too much\nfrom the current product definition,"
    } ]
  }, {
    "tStartMs": 6521853,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "then you have to take care of the risk."
    } ]
  }, {
    "tStartMs": 6525293,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "And then it's a question\nof whether the risk versus the reward"
    } ]
  }, {
    "tStartMs": 6529133,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "could potentially be worth it."
    } ]
  }, {
    "tStartMs": 6530453,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "But there's no way to test it?"
    } ]
  }, {
    "tStartMs": 6532813,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "You can test it, you can do a mock-up,"
    } ]
  }, {
    "tStartMs": 6535493,
    "dDurationMs": 4480,
    "segs": [ {
      "utf8": "you can even use AI to generate a picture\nand then go and speak to people."
    } ]
  }, {
    "tStartMs": 6540053,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "But I think besides mock-up,\nit is all about functionality, usage,"
    } ]
  }, {
    "tStartMs": 6544453,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "so that also plays a bigger role."
    } ]
  }, {
    "tStartMs": 6546013,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "So I think we don't want to change\npeople behaviours the way they are doing."
    } ]
  }, {
    "tStartMs": 6550293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Little changes--"
    } ]
  }, {
    "tStartMs": 6551373,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "It is a different business strategy."
    } ]
  }, {
    "tStartMs": 6553053,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "I think we're\nin the fast follower strategy"
    } ]
  }, {
    "tStartMs": 6556053,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "or late mover strategy."
    } ]
  }, {
    "tStartMs": 6557293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Explain."
    } ]
  }, {
    "tStartMs": 6559213,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "So we're coming into an industry\nthat already got created by other people,"
    } ]
  }, {
    "tStartMs": 6563853,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "and we're just trying to carve out\nour space within a big industry,"
    } ]
  }, {
    "tStartMs": 6567333,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "a billion-units-a-year industry\nthat was created by other people."
    } ]
  }, {
    "tStartMs": 6570813,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "So then we do not take the risk."
    } ]
  }, {
    "tStartMs": 6573613,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "We come into a very mature category,"
    } ]
  }, {
    "tStartMs": 6576173,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "and then we can differentiate\nthrough design."
    } ]
  }, {
    "tStartMs": 6578733,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "But if you're creating something new,\nlike, back in the day, drones were new,"
    } ]
  }, {
    "tStartMs": 6582533,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "or now electric vehicles are new,\nor robotics,"
    } ]
  }, {
    "tStartMs": 6586013,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "then you do not have to differentiate\non the product"
    } ]
  }, {
    "tStartMs": 6588373,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "because the technology is fresh enough\nas a differentiator."
    } ]
  }, {
    "tStartMs": 6591893,
    "dDurationMs": 5280,
    "segs": [ {
      "utf8": "But then you have the execution risk\non the technology and also the PMF risk"
    } ]
  }, {
    "tStartMs": 6597253,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "on whether consumers will wanna adopt\nthis product or not."
    } ]
  }, {
    "tStartMs": 6601773,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "I personally think late mover\nis easier for me."
    } ]
  }, {
    "tStartMs": 6606733,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "That requires a different way of thinking,\nmore survival-focused,"
    } ]
  }, {
    "tStartMs": 6610973,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "more capability-building,\nmore long-term thinking."
    } ]
  }, {
    "tStartMs": 6614133,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "Whereas the technology approach\nis more like, you have one shot."
    } ]
  }, {
    "tStartMs": 6618093,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "If it works, it works."
    } ]
  }, {
    "tStartMs": 6619173,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "If it does not work,\nyou gotta start over again."
    } ]
  }, {
    "tStartMs": 6624893,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "-So just asking Carl on...\n-[Nikhil] Yeah, yeah."
    } ]
  }, {
    "tStartMs": 6626933,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "So, Carl, on the phones, for example,"
    } ]
  }, {
    "tStartMs": 6629693,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "where do you think...\nsome disruption can happen?"
    } ]
  }, {
    "tStartMs": 6634533,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "I think the disruption can happen\non the OS side."
    } ]
  }, {
    "tStartMs": 6637533,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "I think the hardware side is very hard\nto differentiate on"
    } ]
  }, {
    "tStartMs": 6641653,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "because all these suppliers that we have,"
    } ]
  }, {
    "tStartMs": 6644933,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "they're all very concentrated,\nand they're very strong,"
    } ]
  }, {
    "tStartMs": 6647813,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "and they're investing\nin their product road map,"
    } ]
  }, {
    "tStartMs": 6650653,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "upgrading their batteries and processors\nincrementally every year."
    } ]
  }, {
    "tStartMs": 6654493,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Like, we cannot really differentiate."
    } ]
  }, {
    "tStartMs": 6657413,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "And as a supplier,\nyou wanna sell to everybody, right?"
    } ]
  }, {
    "tStartMs": 6660253,
    "dDurationMs": 4920,
    "segs": [ {
      "utf8": "But if the form factors are changing now,\nfoldable phones are coming in,"
    } ]
  }, {
    "tStartMs": 6665253,
    "dDurationMs": 4520,
    "segs": [ {
      "utf8": "don't you think if we can bring the cost\nby innovation of the foldable phones down,"
    } ]
  }, {
    "tStartMs": 6670533,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "it will have a mass adoption?"
    } ]
  }, {
    "tStartMs": 6671693,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "Because relatively,\nit's a game-changing thing"
    } ]
  }, {
    "tStartMs": 6674733,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "because from a single screen,\nyou're going to a bigger screen."
    } ]
  }, {
    "tStartMs": 6678053,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "-Yeah.\n-Or maybe a triple screen."
    } ]
  }, {
    "tStartMs": 6679453,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "That's also not up to us, right?"
    } ]
  }, {
    "tStartMs": 6681333,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "'Cause the screen manufacturer"
    } ]
  }, {
    "tStartMs": 6683333,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "is the real decision maker\nfor that product."
    } ]
  }, {
    "tStartMs": 6687213,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "It's not us."
    } ]
  }, {
    "tStartMs": 6688733,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Also, just to add onto it,\nthe screen manufacturer is also booked,"
    } ]
  }, {
    "tStartMs": 6691813,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "and he also wants to take advantage of it\nbecause he knows after three years,"
    } ]
  }, {
    "tStartMs": 6695013,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "there's gonna be the same price\nas a normal screen."
    } ]
  }, {
    "tStartMs": 6697573,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "So he will also not reduce the price."
    } ]
  }, {
    "tStartMs": 6699133,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "And you wanna go with the biggest vendor\ninstead of a startup like us."
    } ]
  }, {
    "tStartMs": 6702653,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "So I think for us,"
    } ]
  }, {
    "tStartMs": 6704013,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "our biggest opportunity to differentiate\nin our next phase"
    } ]
  }, {
    "tStartMs": 6707813,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "-is through the OS.\n-OS."
    } ]
  }, {
    "tStartMs": 6710893,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "I think the next differentiation\nfor all of us"
    } ]
  }, {
    "tStartMs": 6713573,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "would be through software only."
    } ]
  }, {
    "tStartMs": 6715893,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "But aren't you using one of two softwares\nwhich are in the market"
    } ]
  }, {
    "tStartMs": 6720213,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "and operating your devices on that?"
    } ]
  }, {
    "tStartMs": 6723173,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "[Amit] So we..."
    } ]
  }, {
    "tStartMs": 6725013,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "So phones is a different universe."
    } ]
  }, {
    "tStartMs": 6727213,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "They're Android or iOS."
    } ]
  }, {
    "tStartMs": 6729653,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "But in our case,\nwe work on open RTOS operating system,"
    } ]
  }, {
    "tStartMs": 6733733,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "where we build our operating system there."
    } ]
  }, {
    "tStartMs": 6737693,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "-Right.\n-And what I mean is,"
    } ]
  }, {
    "tStartMs": 6739733,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "more softwares would come in like,"
    } ]
  }, {
    "tStartMs": 6742173,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "\"Could I fine-tune my audio"
    } ]
  }, {
    "tStartMs": 6745613,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "based on my hearing capabilities\nof my ear?\""
    } ]
  }, {
    "tStartMs": 6747733,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "Like, Apple is doing it now.\nIt's pure software."
    } ]
  }, {
    "tStartMs": 6750853,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "\"Or could I have AI capabilities in this\nso that I could interact it?\""
    } ]
  }, {
    "tStartMs": 6754893,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "A lot of companies are working\non a friend kind of a concept."
    } ]
  }, {
    "tStartMs": 6757813,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "So it's all software,\nwhat I see is happening."
    } ]
  }, {
    "tStartMs": 6759533,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "And the same is gonna happen on the..."
    } ]
  }, {
    "tStartMs": 6762413,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Today we're based on Android,"
    } ]
  }, {
    "tStartMs": 6763853,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "but I see some disruption opportunities\nto become the next Android."
    } ]
  }, {
    "tStartMs": 6768573,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Like?"
    } ]
  }, {
    "tStartMs": 6770253,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "I think there's a couple of trends, right?"
    } ]
  }, {
    "tStartMs": 6774973,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "The one trend is..."
    } ]
  }, {
    "tStartMs": 6777773,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "if you look at the current big OSes,\niOS and Android,"
    } ]
  }, {
    "tStartMs": 6781453,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "they're very successful already."
    } ]
  }, {
    "tStartMs": 6783293,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Android has three billion-plus users."
    } ]
  }, {
    "tStartMs": 6785773,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "iOS has one billion-plus users."
    } ]
  }, {
    "tStartMs": 6788133,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "So they can't really\nchange the product that much."
    } ]
  }, {
    "tStartMs": 6790013,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "If you change the product,\na lot of people are gonna be confused."
    } ]
  }, {
    "tStartMs": 6793093,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "They have too many users."
    } ]
  }, {
    "tStartMs": 6794533,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "And it's very profitable."
    } ]
  }, {
    "tStartMs": 6795773,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "They're making a lot of money\non the software and the services."
    } ]
  }, {
    "tStartMs": 6798733,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "I don't know the number for India,\nbut in the US,"
    } ]
  }, {
    "tStartMs": 6801133,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "Apple makes $100 per year\non each iPhone user,"
    } ]
  }, {
    "tStartMs": 6803893,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "just on non-hardware stuff."
    } ]
  }, {
    "tStartMs": 6806293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "It's a very high margin."
    } ]
  }, {
    "tStartMs": 6809413,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "It's very profitable. Very big."
    } ]
  }, {
    "tStartMs": 6811933,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Now the disruption moment is with GenAI"
    } ]
  }, {
    "tStartMs": 6814453,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "-and large language models.\n-[Amit] Correct."
    } ]
  }, {
    "tStartMs": 6816373,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "If you look at the recent news\naround Apple,"
    } ]
  }, {
    "tStartMs": 6818373,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "they announced Apple Intelligence at WWDC."
    } ]
  }, {
    "tStartMs": 6822173,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "And still today, almost a year later,"
    } ]
  }, {
    "tStartMs": 6825653,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "-there's nothing...\n-Still the same."
    } ]
  }, {
    "tStartMs": 6827133,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "...nothing there to use."
    } ]
  }, {
    "tStartMs": 6828733,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Now they are reshuffling\ntheir management team."
    } ]
  }, {
    "tStartMs": 6830213,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "And this is like four years after ChatGPT."
    } ]
  }, {
    "tStartMs": 6834093,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "It took a long time to implement this."
    } ]
  }, {
    "tStartMs": 6838173,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "So I think, one,\nthey're too big and too successful."
    } ]
  }, {
    "tStartMs": 6842053,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "So then the question is, like,\nhow do you disrupt?"
    } ]
  }, {
    "tStartMs": 6844493,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Like, what is their biggest moat?"
    } ]
  }, {
    "tStartMs": 6847573,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "I think, at least for smartphones,"
    } ]
  }, {
    "tStartMs": 6849213,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "their biggest moat\nis their developer ecosystem, right?"
    } ]
  }, {
    "tStartMs": 6852213,
    "dDurationMs": 5840,
    "segs": [ {
      "utf8": "If today we launch our own OS\nbased on Android or a fork of Android,"
    } ]
  }, {
    "tStartMs": 6859133,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "we don't have any apps on the phone,\nno app store, no apps,"
    } ]
  }, {
    "tStartMs": 6862853,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "nobody is gonna buy the product."
    } ]
  }, {
    "tStartMs": 6864693,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Like, I wanna use my apps."
    } ]
  }, {
    "tStartMs": 6867453,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "But again, if you look at AI,"
    } ]
  }, {
    "tStartMs": 6868733,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "there's a disruption moment\nfor app development"
    } ]
  }, {
    "tStartMs": 6870693,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "because now with AI coding tools,"
    } ]
  }, {
    "tStartMs": 6873933,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "you just need to write what app you want,\nand then it shows up."
    } ]
  }, {
    "tStartMs": 6878293,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "In the future, you can just speak\nwhat app you want into the phone,"
    } ]
  }, {
    "tStartMs": 6880773,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "and that app shows up."
    } ]
  }, {
    "tStartMs": 6882013,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "So then that gives\na smaller company like us"
    } ]
  }, {
    "tStartMs": 6884533,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "the ability to compete with iOS,"
    } ]
  }, {
    "tStartMs": 6887333,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "which has, I don't know,\na million, two million apps already."
    } ]
  }, {
    "tStartMs": 6890293,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "But we can empower every normal person\nto also be an app developer."
    } ]
  }, {
    "tStartMs": 6894133,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "If you have an idea,\nyou just speak your idea into the product."
    } ]
  }, {
    "tStartMs": 6897573,
    "dDurationMs": 5920,
    "segs": [ {
      "utf8": "Therefore, we can also quickly develop\nour ecosystem of developers and apps."
    } ]
  }, {
    "tStartMs": 6903573,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "So I think that's the main opportunity\nthat I see,"
    } ]
  }, {
    "tStartMs": 6906493,
    "dDurationMs": 6640,
    "segs": [ {
      "utf8": "that a younger, more nimble company\ncan navigate a changing world way quicker."
    } ]
  }, {
    "tStartMs": 6913213,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "And the big moment that's enabling\nall of this is the advancements in AI."
    } ]
  }, {
    "tStartMs": 6918653,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "How else can AI present opportunities"
    } ]
  }, {
    "tStartMs": 6922733,
    "dDurationMs": 5280,
    "segs": [ {
      "utf8": "if I were to want to build something\nin consumer electronics as a 25-year-old?"
    } ]
  }, {
    "tStartMs": 6928093,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "It's kind of like the personal computer."
    } ]
  }, {
    "tStartMs": 6931893,
    "dDurationMs": 5840,
    "segs": [ {
      "utf8": "The example of it enables you\nto manifest your creativity into reality."
    } ]
  }, {
    "tStartMs": 6938493,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "The personal computer allows you to go\nto Photoshop, GarageBand, iMovie."
    } ]
  }, {
    "tStartMs": 6943893,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "Now, creating stuff is easier than ever."
    } ]
  }, {
    "tStartMs": 6946653,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Like, we talked about creating apps."
    } ]
  }, {
    "tStartMs": 6948773,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "You can create graphics,\ncreate advertising,"
    } ]
  }, {
    "tStartMs": 6950933,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "create content,\ncreate product design, code."
    } ]
  }, {
    "tStartMs": 6954853,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "It's really, in one way, lowering the bar\nto creativity being manifested."
    } ]
  }, {
    "tStartMs": 6960133,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "[Rahul] I think that is one segment\nwhich will..."
    } ]
  }, {
    "tStartMs": 6961613,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "Again, a great idea,\nyou know, for all the youngsters."
    } ]
  }, {
    "tStartMs": 6965533,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "For AI, in terms of training the models,\nyou know,"
    } ]
  }, {
    "tStartMs": 6969173,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "we all see that you will need\nthese many GPUs,"
    } ]
  }, {
    "tStartMs": 6972373,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "you know, hundreds of GPUs,\nthousands of GPUs,"
    } ]
  }, {
    "tStartMs": 6974613,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "to train all your models and all."
    } ]
  }, {
    "tStartMs": 6975733,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "I think all those things,\nyou know, will change."
    } ]
  }, {
    "tStartMs": 6980053,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "There will be a time\nwhere you will be able to train"
    } ]
  }, {
    "tStartMs": 6982293,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "the largest of the models\nusing one single server."
    } ]
  }, {
    "tStartMs": 6984893,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "You will not need a farm of servers."
    } ]
  }, {
    "tStartMs": 6987813,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "We have seen a trailer\nin form of DeepSeek already."
    } ]
  }, {
    "tStartMs": 6992493,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "And I think very soon we'll..."
    } ]
  }, {
    "tStartMs": 6996053,
    "dDurationMs": 4920,
    "segs": [ {
      "utf8": "What, you know, it implies\nis that how it is going to change."
    } ]
  }, {
    "tStartMs": 7001053,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "This means that the access to technology\nwill be massified."
    } ]
  }, {
    "tStartMs": 7006733,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Right now, it is with only a few people\nwho are working on these LLMs."
    } ]
  }, {
    "tStartMs": 7009933,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "For example, running 405 billion tokens,"
    } ]
  }, {
    "tStartMs": 7012573,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "or now the new model\nis 788 billion tokens,"
    } ]
  }, {
    "tStartMs": 7016613,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "which only big server farms can do."
    } ]
  }, {
    "tStartMs": 7019213,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "But, once there is a technology"
    } ]
  }, {
    "tStartMs": 7023053,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "wherein within a single server\nyou'll be able to--"
    } ]
  }, {
    "tStartMs": 7025213,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "You can run your models."
    } ]
  }, {
    "tStartMs": 7027893,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "I think, then all the youngsters,\nand they are way more creative,"
    } ]
  }, {
    "tStartMs": 7032973,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "they will be able to come up with,\nfor example, an operating system."
    } ]
  }, {
    "tStartMs": 7035573,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "They can just come up with an OS\nand then..."
    } ]
  }, {
    "tStartMs": 7039293,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "and figure it out."
    } ]
  }, {
    "tStartMs": 7040573,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "Maybe then find a MrBeast and say,\n\"Okay, hey, I have this.\""
    } ]
  }, {
    "tStartMs": 7044413,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "And then, so..."
    } ]
  }, {
    "tStartMs": 7046493,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "But, there will be numerous opportunities\ncoming out of that once it is massified."
    } ]
  }, {
    "tStartMs": 7050893,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "One trend that I see in the market"
    } ]
  }, {
    "tStartMs": 7053413,
    "dDurationMs": 5880,
    "segs": [ {
      "utf8": "is the youth of today does not want to buy\nfrom the corporations of yesterday."
    } ]
  }, {
    "tStartMs": 7059373,
    "dDurationMs": 5760,
    "segs": [ {
      "utf8": "I feel like things like Louis Vuitton,\nGucci are not cool today"
    } ]
  }, {
    "tStartMs": 7065213,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "like they might have been ten years ago."
    } ]
  }, {
    "tStartMs": 7067253,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "Everybody wants streetwear,\nthe new independent brand--"
    } ]
  }, {
    "tStartMs": 7071653,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Look at how you are dressed, for example."
    } ]
  }, {
    "tStartMs": 7074773,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Do you think there is a play there?"
    } ]
  }, {
    "tStartMs": 7076173,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "If I start a consumer electronic company"
    } ]
  }, {
    "tStartMs": 7080333,
    "dDurationMs": 6840,
    "segs": [ {
      "utf8": "where I will use the narrative\nof not a corporation?"
    } ]
  }, {
    "tStartMs": 7088173,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "[Carl] I think there is an opportunity,"
    } ]
  }, {
    "tStartMs": 7090013,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "but I think you would first need to start\nin a different category."
    } ]
  }, {
    "tStartMs": 7093693,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "Like, make a fashion brand,\nmake that successful."
    } ]
  }, {
    "tStartMs": 7096493,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "Then you have the credibility"
    } ]
  }, {
    "tStartMs": 7098013,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "to go to the consumer\nelectronics suppliers"
    } ]
  }, {
    "tStartMs": 7100973,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "to get them to want to work with you."
    } ]
  }, {
    "tStartMs": 7102933,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "'Cause they have seen so many..."
    } ]
  }, {
    "tStartMs": 7104813,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "These guys have seen so many failures\nand so many pitches."
    } ]
  }, {
    "tStartMs": 7107333,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "They are very pragmatic."
    } ]
  }, {
    "tStartMs": 7109773,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "That is an interesting idea."
    } ]
  }, {
    "tStartMs": 7111213,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "So, you are saying"
    } ]
  }, {
    "tStartMs": 7113293,
    "dDurationMs": 5440,
    "segs": [ {
      "utf8": "start an independent design-themed brand,"
    } ]
  }, {
    "tStartMs": 7118813,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "start elsewhere,\nsucceed and then transition into this?"
    } ]
  }, {
    "tStartMs": 7122013,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "You have to have volume."
    } ]
  }, {
    "tStartMs": 7123533,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "That is the core of the consumer\nelectronics industry."
    } ]
  }, {
    "tStartMs": 7126333,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "To be able to work with these suppliers"
    } ]
  }, {
    "tStartMs": 7128493,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "you need to show the numbers\nthat they can believe in."
    } ]
  }, {
    "tStartMs": 7131653,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So, look at our case."
    } ]
  }, {
    "tStartMs": 7133573,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "We did not come from electronics\nor consumer electronics background."
    } ]
  }, {
    "tStartMs": 7137253,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "So, in my wildest dream\nI could have never thought of"
    } ]
  }, {
    "tStartMs": 7141573,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "working in a space which is led by\nmobility brands or other brands."
    } ]
  }, {
    "tStartMs": 7145493,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "So, we started with mobile accessories."
    } ]
  }, {
    "tStartMs": 7147973,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "It's like...\nI still say it is a T-shirt business."
    } ]
  }, {
    "tStartMs": 7150213,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "It is just simple cases."
    } ]
  }, {
    "tStartMs": 7151853,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "You just print designs\nand designs are a character."
    } ]
  }, {
    "tStartMs": 7154973,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "And we started understanding the user,\nconsumer pattern,"
    } ]
  }, {
    "tStartMs": 7158253,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "and knowing and started building volumes."
    } ]
  }, {
    "tStartMs": 7160693,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Our partners saw a confidence in us, like,"
    } ]
  }, {
    "tStartMs": 7163373,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "\"They are doing good volumes.\nWe could test something with them.\""
    } ]
  }, {
    "tStartMs": 7166533,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "So, maybe our entry also\nwas not on day one here."
    } ]
  }, {
    "tStartMs": 7169093,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "We learnt consumer from a basic business."
    } ]
  }, {
    "tStartMs": 7173693,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "But, by the way,\nI have a very fundamental question"
    } ]
  }, {
    "tStartMs": 7176053,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "which I have realised as a founder."
    } ]
  }, {
    "tStartMs": 7179133,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "What is the segment of the market\nyou want to chase?"
    } ]
  }, {
    "tStartMs": 7182853,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Like, what customer you want to..."
    } ]
  }, {
    "tStartMs": 7185053,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "I am asking you that question."
    } ]
  }, {
    "tStartMs": 7186733,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I don't have data like you have."
    } ]
  }, {
    "tStartMs": 7188493,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "No, it is not about what I want."
    } ]
  }, {
    "tStartMs": 7192893,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "It is about what you want to build."
    } ]
  }, {
    "tStartMs": 7194373,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "I'll tell you for an example,\nthe game what he is doing."
    } ]
  }, {
    "tStartMs": 7196293,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "He is saying,\nI'll not fight the cheapest in the market,"
    } ]
  }, {
    "tStartMs": 7198453,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "like, he is not doing the Xiaomi play."
    } ]
  }, {
    "tStartMs": 7201293,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "But what he is doing,"
    } ]
  }, {
    "tStartMs": 7202453,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "he is in the mid segment,\nwhich is super painful,"
    } ]
  }, {
    "tStartMs": 7206333,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "which needs time."
    } ]
  }, {
    "tStartMs": 7207933,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "His gestation would be...\nSuccess will not be short term."
    } ]
  }, {
    "tStartMs": 7211533,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "He would have a patience of\nthree-to-four-year capital to build it."
    } ]
  }, {
    "tStartMs": 7215213,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "And then he--"
    } ]
  }, {
    "tStartMs": 7216653,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "There are chances he might see\nand might not see success."
    } ]
  }, {
    "tStartMs": 7219173,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "So, as founders or whosoever,\nyoung people want to start,"
    } ]
  }, {
    "tStartMs": 7223093,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "they need to be very clear\nwhat segment they are trying to build."
    } ]
  }, {
    "tStartMs": 7226453,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Because different segment--\nWhen you talk about design--"
    } ]
  }, {
    "tStartMs": 7228733,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "What, if I come to you with a blank slate,"
    } ]
  }, {
    "tStartMs": 7230733,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "what segment\nwould you recommend I build in?"
    } ]
  }, {
    "tStartMs": 7232493,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "No, if you ask me,\nI would say don't go for the mass."
    } ]
  }, {
    "tStartMs": 7235653,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "Mass is important,\nbut have some brand aspiration,"
    } ]
  }, {
    "tStartMs": 7238293,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "have your identity,\nhave your brand uniqueness."
    } ]
  }, {
    "tStartMs": 7241053,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "No point to fight for a commodity,\nthat's a race to bottom."
    } ]
  }, {
    "tStartMs": 7243893,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "You sell for $20,"
    } ]
  }, {
    "tStartMs": 7246173,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "somebody else will sell for 15, 12, 11."
    } ]
  }, {
    "tStartMs": 7249333,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Have your own community,"
    } ]
  }, {
    "tStartMs": 7250933,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "one narrow cohort of users\nwho you are selling,"
    } ]
  }, {
    "tStartMs": 7253373,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "and that community should be\nyour evangelist there."
    } ]
  }, {
    "tStartMs": 7257213,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "And that always happens at\nsomewhere little above, not to the basics."
    } ]
  }, {
    "tStartMs": 7261373,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "You are not solving basics\nof anyone right now."
    } ]
  }, {
    "tStartMs": 7263573,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "How does India build the supply chain?"
    } ]
  }, {
    "tStartMs": 7265533,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Great."
    } ]
  }, {
    "tStartMs": 7267813,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "So, it's a process."
    } ]
  }, {
    "tStartMs": 7270013,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "So, the process is that\nyou start with initially..."
    } ]
  }, {
    "tStartMs": 7273813,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "to start with EMS."
    } ]
  }, {
    "tStartMs": 7275093,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "EMS is?"
    } ]
  }, {
    "tStartMs": 7276333,
    "dDurationMs": 5280,
    "segs": [ {
      "utf8": "EMS is the electronic manufacturing\nservices that you start the EMS process."
    } ]
  }, {
    "tStartMs": 7282413,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "Then you start getting the design\nout there in country."
    } ]
  }, {
    "tStartMs": 7288133,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "Then after design, you start working on\nthe supply chain, the component ecosystem."
    } ]
  }, {
    "tStartMs": 7293493,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "Right? So, this is...\nThis all is a process one-by-one."
    } ]
  }, {
    "tStartMs": 7297773,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "If I am 25 and I want to start\na component company,"
    } ]
  }, {
    "tStartMs": 7302133,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "I've raised a little bit of money,\nput up a factory."
    } ]
  }, {
    "tStartMs": 7305893,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "How will I ever compete\nwith somebody in China"
    } ]
  }, {
    "tStartMs": 7308173,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "who's manufacturing millions of units?"
    } ]
  }, {
    "tStartMs": 7310213,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "So, you can do that."
    } ]
  }, {
    "tStartMs": 7312173,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "So, there is so much of material\nwhich goes inside."
    } ]
  }, {
    "tStartMs": 7315053,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "For example, a glue on a glue machine,\non SMT, it's a glue."
    } ]
  }, {
    "tStartMs": 7320933,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "That glue--"
    } ]
  }, {
    "tStartMs": 7322053,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "So, I just found out that that glue,"
    } ]
  }, {
    "tStartMs": 7323653,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "the particular glue\nis still coming from China."
    } ]
  }, {
    "tStartMs": 7325773,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "We can-- Why can't we make that here?"
    } ]
  }, {
    "tStartMs": 7328213,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "And I studied, I said why the chemical\ncompanies can make that glue out there."
    } ]
  }, {
    "tStartMs": 7331613,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "You can do that."
    } ]
  }, {
    "tStartMs": 7333493,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Probably there is--"
    } ]
  }, {
    "tStartMs": 7334573,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "Maybe somebody has to find out\nand get into that."
    } ]
  }, {
    "tStartMs": 7339773,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "I know someone, you know, who said, \"Okay,"
    } ]
  }, {
    "tStartMs": 7341813,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "after finishing my engineering,\nwhat should I do and all?\""
    } ]
  }, {
    "tStartMs": 7344733,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "And then went on search\nthat what India is importing a lot"
    } ]
  }, {
    "tStartMs": 7348333,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "and he found out\nall the coin's material..."
    } ]
  }, {
    "tStartMs": 7351973,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "Right? For the coins, currency coins,\nthe material, we still import."
    } ]
  }, {
    "tStartMs": 7355573,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "He started making that,\nhe started supplying that."
    } ]
  }, {
    "tStartMs": 7358093,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "So, you just..."
    } ]
  }, {
    "tStartMs": 7359253,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Is that an opportunity for me?"
    } ]
  }, {
    "tStartMs": 7360733,
    "dDurationMs": 4520,
    "segs": [ {
      "utf8": "I think US will, in the tariff world,\nnot buy from China like they once did."
    } ]
  }, {
    "tStartMs": 7365333,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Components is a huge opportunity."
    } ]
  }, {
    "tStartMs": 7367093,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "So, for example, now India is projecting\na market of 500 billion dollars by 2030."
    } ]
  }, {
    "tStartMs": 7371573,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "It's a huge market."
    } ]
  }, {
    "tStartMs": 7373533,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "60% of that is components."
    } ]
  }, {
    "tStartMs": 7375333,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "And we are also incentivised to use\nthe locally manufactured components."
    } ]
  }, {
    "tStartMs": 7379533,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "If manufacturing is coming here,"
    } ]
  }, {
    "tStartMs": 7380933,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "100% components will come here,\nlike batteries..."
    } ]
  }, {
    "tStartMs": 7383813,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "-That's an opportunity, too.\n-100%."
    } ]
  }, {
    "tStartMs": 7385733,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Like, I want to make money,\nI'm 25, in this industry."
    } ]
  }, {
    "tStartMs": 7388253,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "-Component is part of--\n-EMS is a..."
    } ]
  }, {
    "tStartMs": 7389813,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "I think next ten years is EMS. So..."
    } ]
  }, {
    "tStartMs": 7393253,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "And the component PLI scheme is coming."
    } ]
  }, {
    "tStartMs": 7394893,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "Maybe by the time this podcast is out,\nthe scheme will be announced."
    } ]
  }, {
    "tStartMs": 7397493,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "How do I go about starting that?"
    } ]
  }, {
    "tStartMs": 7399013,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "Let's say an EMS company,\nan EMS manufacturer."
    } ]
  }, {
    "tStartMs": 7402293,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "Great. So, take a mobile phone,\nget into each and every component."
    } ]
  }, {
    "tStartMs": 7406173,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "There are so many. There are--"
    } ]
  }, {
    "tStartMs": 7407853,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "So, in a mobile phone, there are,\nlet's say, 700-800 components."
    } ]
  }, {
    "tStartMs": 7411013,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Maybe in his phone, maybe it will be more."
    } ]
  }, {
    "tStartMs": 7412693,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "iPhone will be way more, right?"
    } ]
  }, {
    "tStartMs": 7414853,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Get into that."
    } ]
  }, {
    "tStartMs": 7415933,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "How do I find that out?\nLike, I want to know..."
    } ]
  }, {
    "tStartMs": 7419653,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "I'm assuming US, China\nare going to hate each other"
    } ]
  }, {
    "tStartMs": 7421653,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "for some time more."
    } ]
  }, {
    "tStartMs": 7423813,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Apple phones are made in the US."
    } ]
  }, {
    "tStartMs": 7425613,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "They can't buy that particular product\nthat they have been, from China anymore."
    } ]
  }, {
    "tStartMs": 7430533,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "How do I figure out what that component is\nand then how to build it?"
    } ]
  }, {
    "tStartMs": 7434333,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Just tear it down."
    } ]
  }, {
    "tStartMs": 7436293,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Nikhil, these days,\nit is actually simpler."
    } ]
  }, {
    "tStartMs": 7438213,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "You know, you go on ChatGPT."
    } ]
  }, {
    "tStartMs": 7440493,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "There are so many sites on the Internet"
    } ]
  }, {
    "tStartMs": 7442013,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "where you could just see\ntear down of every phone."
    } ]
  }, {
    "tStartMs": 7443813,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Tear down, you can find out\nwhat are the components"
    } ]
  }, {
    "tStartMs": 7445813,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "and then you find out, okay,\nhow many components are there in India."
    } ]
  }, {
    "tStartMs": 7448013,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "Go on the export list, import list\nthat what all are getting in the country."
    } ]
  }, {
    "tStartMs": 7452333,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Right? What is the volume? What is the--"
    } ]
  }, {
    "tStartMs": 7454413,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "These days, you can get access\nto all the customs data easily."
    } ]
  }, {
    "tStartMs": 7456773,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[Amit] Yeah."
    } ]
  }, {
    "tStartMs": 7457853,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "So, huge opportunity."
    } ]
  }, {
    "tStartMs": 7460693,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "You should also work at EMS to get some...\nindustry knowledge."
    } ]
  }, {
    "tStartMs": 7464533,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "-Experience. Yeah.\n-[Carl] Experience."
    } ]
  }, {
    "tStartMs": 7466493,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "There is somebody working with him\nfor a year."
    } ]
  }, {
    "tStartMs": 7468613,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "He would know everything\nwhere this opportunity lies."
    } ]
  }, {
    "tStartMs": 7472013,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "How big is the incentive\nfor someone like Carl?"
    } ]
  }, {
    "tStartMs": 7474053,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Say, you are selling Nothing phones\nin India."
    } ]
  }, {
    "tStartMs": 7476453,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "You source from me in Bangalore"
    } ]
  }, {
    "tStartMs": 7478613,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "versus a Chinese component manufacturer."
    } ]
  }, {
    "tStartMs": 7482173,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "Is the incentive enough\nto warrant the change in price?"
    } ]
  }, {
    "tStartMs": 7488093,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "So, right now, we have to pay\nduties on components"
    } ]
  }, {
    "tStartMs": 7491813,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "that are sourced\nfrom other countries like China."
    } ]
  }, {
    "tStartMs": 7494293,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "So the more we can source locally,"
    } ]
  }, {
    "tStartMs": 7495653,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "the more we can lower\nthe prices of our product"
    } ]
  }, {
    "tStartMs": 7498533,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "to then be more competitive on the market."
    } ]
  }, {
    "tStartMs": 7500613,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "So, we are very incentivised."
    } ]
  }, {
    "tStartMs": 7502533,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "And if we are able to tap into PLI,"
    } ]
  }, {
    "tStartMs": 7504733,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "and I think the PLI regulation"
    } ]
  }, {
    "tStartMs": 7506373,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "will also be more and more requiring\nof the brands to source locally."
    } ]
  }, {
    "tStartMs": 7512093,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "And they will raise the bar\nevery single year."
    } ]
  }, {
    "tStartMs": 7516333,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "We are very incentivised\nto source locally."
    } ]
  }, {
    "tStartMs": 7518813,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "As a business, we just need to make\nthe best decision for our shareholders."
    } ]
  }, {
    "tStartMs": 7522533,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "So, till now you have told me,\ngo to ChatGPT, figure out..."
    } ]
  }, {
    "tStartMs": 7526253,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "No, no, just..."
    } ]
  }, {
    "tStartMs": 7528013,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Just as I said, these days,\nthere are a lot of avenues"
    } ]
  }, {
    "tStartMs": 7531213,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "where you can go and find out\nmultiple sort of information."
    } ]
  }, {
    "tStartMs": 7534293,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Right. So, I figure out one component"
    } ]
  }, {
    "tStartMs": 7536253,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "which is going into\nUS cell phone manufacturer"
    } ]
  }, {
    "tStartMs": 7538973,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "which is coming from China."
    } ]
  }, {
    "tStartMs": 7541133,
    "dDurationMs": 4880,
    "segs": [ {
      "utf8": "And then I go about figuring if that\nraw material is available in India."
    } ]
  }, {
    "tStartMs": 7546093,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "I identify that there is."
    } ]
  }, {
    "tStartMs": 7548133,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "What do I do next\nto set up a factory which makes it?"
    } ]
  }, {
    "tStartMs": 7552293,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Okay, let's take an example."
    } ]
  }, {
    "tStartMs": 7555173,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Carl, can I use your phone?"
    } ]
  }, {
    "tStartMs": 7560533,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Let's say this is a USB socket."
    } ]
  }, {
    "tStartMs": 7562333,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[Nikhil] Yeah."
    } ]
  }, {
    "tStartMs": 7563413,
    "dDurationMs": 5840,
    "segs": [ {
      "utf8": "This USB socket is\nthe most abused component here"
    } ]
  }, {
    "tStartMs": 7569333,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "because, let's say a million times\nyou are going to..."
    } ]
  }, {
    "tStartMs": 7573213,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Right? So, this means to say that"
    } ]
  }, {
    "tStartMs": 7575373,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "this will require\na special sort of material."
    } ]
  }, {
    "tStartMs": 7577773,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Study that material."
    } ]
  }, {
    "tStartMs": 7579133,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Where that material is available?"
    } ]
  }, {
    "tStartMs": 7581333,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Who is manufacturing it?"
    } ]
  }, {
    "tStartMs": 7583053,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "At what cost?"
    } ]
  }, {
    "tStartMs": 7585133,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "And absolutely go to the root of that."
    } ]
  }, {
    "tStartMs": 7590213,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "And then see what are the..."
    } ]
  }, {
    "tStartMs": 7593333,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "If you can go and visit these factories"
    } ]
  }, {
    "tStartMs": 7596573,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "by tapping someone,\ngetting into a network--"
    } ]
  }, {
    "tStartMs": 7600453,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "These factories in China?"
    } ]
  }, {
    "tStartMs": 7602373,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "Wherever. Wherever. If possible."
    } ]
  }, {
    "tStartMs": 7605413,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "See, and then understand the standards."
    } ]
  }, {
    "tStartMs": 7608413,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "See, why this is not happening?"
    } ]
  }, {
    "tStartMs": 7609693,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Why I gave you a glue example?"
    } ]
  }, {
    "tStartMs": 7610933,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Because people said,\n\"No, India can't make that.\""
    } ]
  }, {
    "tStartMs": 7612653,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Why can't we make that?"
    } ]
  }, {
    "tStartMs": 7613733,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "We are fantastic in chemical--"
    } ]
  }, {
    "tStartMs": 7615453,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Our chemical industry,\nour pharmaceutical industry,"
    } ]
  }, {
    "tStartMs": 7617133,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "they are doing brilliantly well."
    } ]
  }, {
    "tStartMs": 7619453,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "Probably there is maybe,\nthere is not awareness of that,"
    } ]
  }, {
    "tStartMs": 7622173,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "or the volumes and everything,"
    } ]
  }, {
    "tStartMs": 7623853,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "but I think if we are going to go,"
    } ]
  }, {
    "tStartMs": 7625933,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "let's say from 100 billion\nto 500 billion dollars,"
    } ]
  }, {
    "tStartMs": 7629133,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "it's a massive opportunity."
    } ]
  }, {
    "tStartMs": 7630613,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Similarly here."
    } ]
  }, {
    "tStartMs": 7632413,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "What else can be done?"
    } ]
  }, {
    "tStartMs": 7633933,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "Like, see, the outcome of this is we want,"
    } ]
  }, {
    "tStartMs": 7637413,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "even if it's five kids who start..."
    } ]
  }, {
    "tStartMs": 7642213,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "solving for the supply chain problem\ndependency that we are talking about,"
    } ]
  }, {
    "tStartMs": 7647293,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "if that is the go-to action that happens\nbecause of the time we have spent today,"
    } ]
  }, {
    "tStartMs": 7651733,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "I think we can all say today was worth it."
    } ]
  }, {
    "tStartMs": 7654773,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Also, like, we spoke--"
    } ]
  }, {
    "tStartMs": 7657133,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "And I think we will need\n5,000 of those kids"
    } ]
  }, {
    "tStartMs": 7658933,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "because it's a huge universe."
    } ]
  }, {
    "tStartMs": 7662253,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "And we don't have it here."
    } ]
  }, {
    "tStartMs": 7663653,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "We have to bring it in."
    } ]
  }, {
    "tStartMs": 7665253,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "[Nikhil] Yeah."
    } ]
  }, {
    "tStartMs": 7666533,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "And, by the way, brands like us"
    } ]
  }, {
    "tStartMs": 7668493,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "are desperately looking for people\nto do it for us."
    } ]
  }, {
    "tStartMs": 7671613,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "I mean, it's our need also."
    } ]
  }, {
    "tStartMs": 7672853,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "What is the biggest need?\nSay two things that you want me--"
    } ]
  }, {
    "tStartMs": 7675413,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "Let's say for us, for an example,"
    } ]
  }, {
    "tStartMs": 7677453,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "in watches we do,\nthe largest component is the screen."
    } ]
  }, {
    "tStartMs": 7680053,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "The screen is like $5 or something."
    } ]
  }, {
    "tStartMs": 7682573,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "And if I import, there is a 15% duty,"
    } ]
  }, {
    "tStartMs": 7685933,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "which means every screen\nI am paying, what?"
    } ]
  }, {
    "tStartMs": 7688413,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "One and a half-- Close to $1."
    } ]
  }, {
    "tStartMs": 7691253,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "If you say, make it in India,\nit's a huge volume."
    } ]
  }, {
    "tStartMs": 7694333,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "It's maybe half a million,\none million screens a month."
    } ]
  }, {
    "tStartMs": 7696693,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "What is the margin in screen business?"
    } ]
  }, {
    "tStartMs": 7699173,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "I'm sure if we cost arbitrage,\nif you look at it,"
    } ]
  }, {
    "tStartMs": 7701773,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "it still makes 10% or 7%."
    } ]
  }, {
    "tStartMs": 7704853,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "It's just one SKU,\nyou have to keep producing."
    } ]
  }, {
    "tStartMs": 7707293,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Oh, you know the smartphone screens\nfrom China,"
    } ]
  }, {
    "tStartMs": 7711253,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "those companies are losing money\nto sell the screens."
    } ]
  }, {
    "tStartMs": 7714293,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "Because they have policies that subsidise\nthe creation of that industry."
    } ]
  }, {
    "tStartMs": 7718653,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "So, at least for the smartphone screens,\nit's very hard for..."
    } ]
  }, {
    "tStartMs": 7721773,
    "dDurationMs": 5680,
    "segs": [ {
      "utf8": "So you're saying our import duty has to be\nhigher than their subsidy, at the least?"
    } ]
  }, {
    "tStartMs": 7727533,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "At the least, if-- Yeah. Yeah."
    } ]
  }, {
    "tStartMs": 7730493,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "So, one is import duty,"
    } ]
  }, {
    "tStartMs": 7732133,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "and second, of course,\nthe PLI schemes coming on components"
    } ]
  }, {
    "tStartMs": 7735213,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "will incentivise\nto use more Make In India."
    } ]
  }, {
    "tStartMs": 7737693,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Any advice to the government,"
    } ]
  }, {
    "tStartMs": 7739053,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "because I'm sure\nsomebody will be watching."
    } ]
  }, {
    "tStartMs": 7740893,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "How should the PLI scheme be structured\nfor components?"
    } ]
  }, {
    "tStartMs": 7744213,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "It's already structured."
    } ]
  }, {
    "tStartMs": 7745293,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "It's just going to be announced\nin two-three days."
    } ]
  }, {
    "tStartMs": 7746773,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "-He would be a part of it.\n-[Rahul] So..."
    } ]
  }, {
    "tStartMs": 7749773,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "It's a good scheme."
    } ]
  }, {
    "tStartMs": 7751413,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "Yes, it's a good scheme."
    } ]
  }, {
    "tStartMs": 7753853,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "It's a good scheme."
    } ]
  }, {
    "tStartMs": 7755973,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "But see, the larger point here is..."
    } ]
  }, {
    "tStartMs": 7759493,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "that you have to ensure\nthat locally-made products"
    } ]
  }, {
    "tStartMs": 7763973,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "make more sense for anybody who wants to,"
    } ]
  }, {
    "tStartMs": 7766453,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "you know, who's selling,\nlet's say, in India."
    } ]
  }, {
    "tStartMs": 7768613,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "I'm not even talking about export."
    } ]
  }, {
    "tStartMs": 7770613,
    "dDurationMs": 5240,
    "segs": [ {
      "utf8": "If Carl wants to buy a,\nlet's say, a middle frame,"
    } ]
  }, {
    "tStartMs": 7775933,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "he should be able to source it locally\nand it should be cheaper for him,"
    } ]
  }, {
    "tStartMs": 7779933,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "not because he's forced\nbecause of a regulation."
    } ]
  }, {
    "tStartMs": 7783613,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "It should also make sense economically\nfor him to do that."
    } ]
  }, {
    "tStartMs": 7787173,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "And that, in today's world,\nbecause of scale,"
    } ]
  }, {
    "tStartMs": 7789413,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "it can only happen with custom duty\nor the tariff."
    } ]
  }, {
    "tStartMs": 7794773,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "So, tariff-- No--"
    } ]
  }, {
    "tStartMs": 7795853,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "-Depending on the component.\n-Yes."
    } ]
  }, {
    "tStartMs": 7797333,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "I think plastic\nshould be very easy, right?"
    } ]
  }, {
    "tStartMs": 7799933,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "-To replicate here.\n-Yes."
    } ]
  }, {
    "tStartMs": 7802293,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "Plastic, and second, as I said,\nthe government incentive schemes."
    } ]
  }, {
    "tStartMs": 7806813,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "Because, you know,\nif you see how China was built,"
    } ]
  }, {
    "tStartMs": 7808933,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "because of\nall the government schemes only."
    } ]
  }, {
    "tStartMs": 7811933,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "And why their exports went up"
    } ]
  }, {
    "tStartMs": 7813293,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "because their export schemes are,\nlike, massive."
    } ]
  }, {
    "tStartMs": 7815213,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "You three continue talking."
    } ]
  }, {
    "tStartMs": 7816733,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Like, I'm a 25-year-old."
    } ]
  }, {
    "tStartMs": 7818133,
    "dDurationMs": 4840,
    "segs": [ {
      "utf8": "I'm trying to learn from three stalwarts\nof our consumer electronic industry."
    } ]
  }, {
    "tStartMs": 7824213,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "I want to make money. End goal."
    } ]
  }, {
    "tStartMs": 7827893,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "The biggest moneymaker is, like..."
    } ]
  }, {
    "tStartMs": 7830653,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "The industries with fewer competitors,\nright? Like NVIDIA."
    } ]
  }, {
    "tStartMs": 7835213,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "If you look at the NVIDIA share price,\nit's insane."
    } ]
  }, {
    "tStartMs": 7837733,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Taking a huge example."
    } ]
  }, {
    "tStartMs": 7838813,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "But even for our industry, like,\nI think the chipset makers,"
    } ]
  }, {
    "tStartMs": 7842453,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "their margins are way higher\nthan the EMS factories, right?"
    } ]
  }, {
    "tStartMs": 7846293,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "NVIDIA, I don't know, is it 40--"
    } ]
  }, {
    "tStartMs": 7848773,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "Qualcomm is 40, 60--"
    } ]
  }, {
    "tStartMs": 7850053,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "They're 45%, I think,\nthey just declared, yeah."
    } ]
  }, {
    "tStartMs": 7852093,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "[Carl] 45% gross margin."
    } ]
  }, {
    "tStartMs": 7853373,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "But Foxconn is, I think, 10%. So..."
    } ]
  }, {
    "tStartMs": 7857533,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Like, eventually we also have to move\nupmarket, right,"
    } ]
  }, {
    "tStartMs": 7860093,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "into, like, more and more difficult,\nlower competition areas of the stack."
    } ]
  }, {
    "tStartMs": 7866053,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Yes, but, Carl, again,"
    } ]
  }, {
    "tStartMs": 7868773,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "Nikhil's point is that how do we inspire\nthe young generation out here"
    } ]
  }, {
    "tStartMs": 7873053,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "to start doing something?"
    } ]
  }, {
    "tStartMs": 7874453,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "You know, how do they spot opportunities?"
    } ]
  }, {
    "tStartMs": 7876093,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 7877173,
    "dDurationMs": 5240,
    "segs": [ {
      "utf8": "So, as I said, if you tear down the phone,\nwhat are the easiest five things,"
    } ]
  }, {
    "tStartMs": 7882493,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "ten things you can just pick up and say,\n\"Hey, this I can do."
    } ]
  }, {
    "tStartMs": 7885893,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "That is a little-- Is not that complex.\""
    } ]
  }, {
    "tStartMs": 7890373,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "By the way, you know, he's right."
    } ]
  }, {
    "tStartMs": 7893413,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "You know, so making these mechanics,"
    } ]
  }, {
    "tStartMs": 7897653,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "for example,\nprecision mechanics is not that easy."
    } ]
  }, {
    "tStartMs": 7901653,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "We still, you know, a lot of things\nare getting imported,"
    } ]
  }, {
    "tStartMs": 7903773,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "even on precision mechanics."
    } ]
  }, {
    "tStartMs": 7904933,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "-Yeah?\n-[Rahul] Yeah."
    } ]
  }, {
    "tStartMs": 7907413,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "But once there are\na lot of incentives and all,"
    } ]
  }, {
    "tStartMs": 7909333,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "we have ample people here\nwho can take a shot at that."
    } ]
  }, {
    "tStartMs": 7913853,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "I'm curious to hear, like,\nhow does the next Qualcomm..."
    } ]
  }, {
    "tStartMs": 7919173,
    "dDurationMs": 4600,
    "segs": [ {
      "utf8": "Like, if a kid is watching this,\nlike, say, 30 years later,"
    } ]
  }, {
    "tStartMs": 7923853,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "they've created Qualcomm,\nthe next Qualcomm."
    } ]
  }, {
    "tStartMs": 7925813,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Like, how does that path happen?"
    } ]
  }, {
    "tStartMs": 7928013,
    "dDurationMs": 5120,
    "segs": [ {
      "utf8": "So, you know, Carl, you just straight away\ntalking about a moonshot."
    } ]
  }, {
    "tStartMs": 7933213,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "But instead of a Qualcomm, one Qualcomm,"
    } ]
  }, {
    "tStartMs": 7937053,
    "dDurationMs": 4520,
    "segs": [ {
      "utf8": "I'm saying, can we make, for example,"
    } ]
  }, {
    "tStartMs": 7941653,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "if I have to take an example\nof automobile,"
    } ]
  }, {
    "tStartMs": 7944133,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "let's say, in terms of components,"
    } ]
  }, {
    "tStartMs": 7945333,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "can we make 300 or 500 Mindas here?"
    } ]
  }, {
    "tStartMs": 7950453,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Minda is a good example, you know."
    } ]
  }, {
    "tStartMs": 7952453,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "-Auto is all making money.\n-[Rahul] Yeah."
    } ]
  }, {
    "tStartMs": 7957733,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "-Makes sense.\n-Yeah."
    } ]
  }, {
    "tStartMs": 7958813,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "I think that's a very large opportunity,\nknocking on our door."
    } ]
  }, {
    "tStartMs": 7962373,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "How much money would I need to start\na factory around, say, the USB port?"
    } ]
  }, {
    "tStartMs": 7967013,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "I think it will be very less, right?"
    } ]
  }, {
    "tStartMs": 7969693,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[Amit] For USB port."
    } ]
  }, {
    "tStartMs": 7970773,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "It's not easy."
    } ]
  }, {
    "tStartMs": 7973093,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "-You would know it the best.\n-[Rahul] Yeah, it's a..."
    } ]
  }, {
    "tStartMs": 7977693,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "You know, Molly and all,"
    } ]
  }, {
    "tStartMs": 7978853,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "they are like specialised Europeans\nwho are working on this."
    } ]
  }, {
    "tStartMs": 7984333,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "But again, it was just an example."
    } ]
  }, {
    "tStartMs": 7987413,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "But once you go inside, Nikhil,\nas I said, you can find out..."
    } ]
  }, {
    "tStartMs": 7992653,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "For example, inside there is a..."
    } ]
  }, {
    "tStartMs": 7995693,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "You have battery.\nOn battery to dissipate the heat,"
    } ]
  }, {
    "tStartMs": 7999773,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "you need some mechanism\nto dissipate the heat."
    } ]
  }, {
    "tStartMs": 8002533,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "You need a graphene,\nsmall film of graphene,"
    } ]
  }, {
    "tStartMs": 8004653,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "which you can put,\nwhich can dissipate the heat."
    } ]
  }, {
    "tStartMs": 8006253,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "You can make it here."
    } ]
  }, {
    "tStartMs": 8008893,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "It will go in every phone."
    } ]
  }, {
    "tStartMs": 8011933,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "So, I am not saying straight away\nyou go and target,"
    } ]
  }, {
    "tStartMs": 8013493,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "okay, I am going to make the next\nSony camera or something like that."
    } ]
  }, {
    "tStartMs": 8016373,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "And the PLI scheme\nwill incentivise all of this?"
    } ]
  }, {
    "tStartMs": 8020413,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "So, as of now,\nthey have structured it for,"
    } ]
  }, {
    "tStartMs": 8022853,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "let's say,\ncomponents which are high in value,"
    } ]
  }, {
    "tStartMs": 8025773,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "let's say, which cover 70% to 75%\nof the mobile phone."
    } ]
  }, {
    "tStartMs": 8030573,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "These are all B2B businesses then."
    } ]
  }, {
    "tStartMs": 8032373,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "I mean, everybody has\na different inclination"
    } ]
  }, {
    "tStartMs": 8034813,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "towards what they want to build."
    } ]
  }, {
    "tStartMs": 8037333,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "No, anything is fine."
    } ]
  }, {
    "tStartMs": 8038813,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "I just want to build something\nin this space"
    } ]
  }, {
    "tStartMs": 8041053,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "where I can actually make money."
    } ]
  }, {
    "tStartMs": 8044133,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Is there financing available?"
    } ]
  }, {
    "tStartMs": 8045533,
    "dDurationMs": 6560,
    "segs": [ {
      "utf8": "Let's say, I figure out a certain product\nwhich is under PLI that I start building."
    } ]
  }, {
    "tStartMs": 8053533,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "But I don't have too much initial capital."
    } ]
  }, {
    "tStartMs": 8056133,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "How does one go around\ngetting that initial funding?"
    } ]
  }, {
    "tStartMs": 8059773,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "If I come up with a business plan"
    } ]
  }, {
    "tStartMs": 8061213,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "and come to somebody like Rahul,\nwill you give it?"
    } ]
  }, {
    "tStartMs": 8063333,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "Yes, if I see that your product works,"
    } ]
  }, {
    "tStartMs": 8068253,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "working as per the standards, and then..."
    } ]
  }, {
    "tStartMs": 8070933,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Would a bank give it?"
    } ]
  }, {
    "tStartMs": 8072493,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "I think yes.\nBut, of course, banks work on collaterals."
    } ]
  }, {
    "tStartMs": 8074893,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "I don't have collateral."
    } ]
  }, {
    "tStartMs": 8076013,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "There are a few banks who might,\nyou know..."
    } ]
  }, {
    "tStartMs": 8077693,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "Is there some startup scheme,\nsome government subsidy,"
    } ]
  }, {
    "tStartMs": 8081213,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "where I can get the initial capital?"
    } ]
  }, {
    "tStartMs": 8082413,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Yes, you can. There are multiple schemes."
    } ]
  }, {
    "tStartMs": 8084133,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Again, yeah. Very good point."
    } ]
  }, {
    "tStartMs": 8085613,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "There are so many schemes\nwhich people are not even aware of."
    } ]
  }, {
    "tStartMs": 8088413,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "For example, for MSME sector,"
    } ]
  }, {
    "tStartMs": 8091213,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "you know,\nfrom Invest India, from Startup India,"
    } ]
  }, {
    "tStartMs": 8094253,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "there are multiple schemes going on\nwhich people are not even aware of."
    } ]
  }, {
    "tStartMs": 8098053,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "I am not aware. How do I find out?"
    } ]
  }, {
    "tStartMs": 8100333,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "You will have to make this much effort."
    } ]
  }, {
    "tStartMs": 8102133,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Then you need to go after that"
    } ]
  }, {
    "tStartMs": 8103813,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "and find out\nhow many schemes are available"
    } ]
  }, {
    "tStartMs": 8105493,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "and then one by one..."
    } ]
  }, {
    "tStartMs": 8106933,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Which one applies to me."
    } ]
  }, {
    "tStartMs": 8108293,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "Yes. For example,\nthere is a PLI everybody knows,"
    } ]
  }, {
    "tStartMs": 8111293,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "but there is a DLI,\nwhich is design-led incentive"
    } ]
  }, {
    "tStartMs": 8114093,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "for the chipsets and all."
    } ]
  }, {
    "tStartMs": 8116373,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "You should know that."
    } ]
  }, {
    "tStartMs": 8118693,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "There is a grant for that."
    } ]
  }, {
    "tStartMs": 8120493,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "You need to show your designs."
    } ]
  }, {
    "tStartMs": 8121693,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "Government, you know, they will come,\ninspect and see what you are doing"
    } ]
  }, {
    "tStartMs": 8125373,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "and then you can do that."
    } ]
  }, {
    "tStartMs": 8127693,
    "dDurationMs": 5800,
    "segs": [ {
      "utf8": "For a right idea, you will knock on\n100 doors, one door will open."
    } ]
  }, {
    "tStartMs": 8134893,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "But you need-- You need to knock."
    } ]
  }, {
    "tStartMs": 8138733,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "You just can't say, okay..."
    } ]
  }, {
    "tStartMs": 8141053,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "As you also said,\neither a bank will come up"
    } ]
  }, {
    "tStartMs": 8143213,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "or a VC will come up\nor a government scheme will come up."
    } ]
  }, {
    "tStartMs": 8146453,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "Something will come up for a right idea."
    } ]
  }, {
    "tStartMs": 8148493,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "I was reading this thing."
    } ]
  }, {
    "tStartMs": 8149973,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Somebody had sent me an email\nsaying semiconductors,"
    } ]
  }, {
    "tStartMs": 8152653,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "something drastic is happening in India."
    } ]
  }, {
    "tStartMs": 8155173,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Is that a possibility?"
    } ]
  }, {
    "tStartMs": 8157773,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "\"Drastic\" means?"
    } ]
  }, {
    "tStartMs": 8159013,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "Like, so the backstory goes\nthat at one point,"
    } ]
  }, {
    "tStartMs": 8163453,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "India was really focused\non semiconductors."
    } ]
  }, {
    "tStartMs": 8165893,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "There was one particular factory\nwhich burned down."
    } ]
  }, {
    "tStartMs": 8168973,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "But in the last 20 years,"
    } ]
  }, {
    "tStartMs": 8170733,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "we have been left behind\nor 30 years we have been left behind,"
    } ]
  }, {
    "tStartMs": 8173213,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "and they are restarting the effort..."
    } ]
  }, {
    "tStartMs": 8176133,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "to manufacture\nmore semiconductors in India."
    } ]
  }, {
    "tStartMs": 8179093,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Is that possible?"
    } ]
  }, {
    "tStartMs": 8181413,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "With TSMC and all of that?"
    } ]
  }, {
    "tStartMs": 8183173,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "The whole world is relying on them, right?"
    } ]
  }, {
    "tStartMs": 8185093,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "You mean like start a new TSMC\nor get TSMC to..."
    } ]
  }, {
    "tStartMs": 8188253,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "Like both semiconductor design\nand manufacturing. Can I--"
    } ]
  }, {
    "tStartMs": 8191493,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "-So you can't create a TSMC...\n-[Nikhil] Can you compete?"
    } ]
  }, {
    "tStartMs": 8193813,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "I think it comes down to, like,\nthe depth of the thing, right?"
    } ]
  }, {
    "tStartMs": 8196973,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "Like how many millimetre..."
    } ]
  }, {
    "tStartMs": 8198613,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "So we are working in one of the companies\non semiconductors."
    } ]
  }, {
    "tStartMs": 8200853,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "And what you're referring is,\nthere was one fab in India,"
    } ]
  }, {
    "tStartMs": 8205293,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "only one fab which was in Mohali,\ngovernment owned, long back..."
    } ]
  }, {
    "tStartMs": 8208613,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[Nikhil] Yes."
    } ]
  }, {
    "tStartMs": 8209693,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Doing probably, you know,"
    } ]
  }, {
    "tStartMs": 8214173,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "100 nanometres or something like that."
    } ]
  }, {
    "tStartMs": 8215893,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Today TSMC is doing two nanometres."
    } ]
  }, {
    "tStartMs": 8218613,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "Two-three, correct."
    } ]
  }, {
    "tStartMs": 8219973,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "So, of course, I mean,\nyou can't catch up with two nanometre."
    } ]
  }, {
    "tStartMs": 8222733,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "Even, see, China started their\nsemiconductor programme 20 years back."
    } ]
  }, {
    "tStartMs": 8226413,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "They are still not able\nto compete on that."
    } ]
  }, {
    "tStartMs": 8228293,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "But it is very, very important."
    } ]
  }, {
    "tStartMs": 8230773,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "All four of us, like, 15 years back or so,"
    } ]
  }, {
    "tStartMs": 8235653,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "have you ever thought that\nsemiconductor will be more valuable"
    } ]
  }, {
    "tStartMs": 8239493,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "or important than oil?"
    } ]
  }, {
    "tStartMs": 8240853,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Not even a thought came across to my mind."
    } ]
  }, {
    "tStartMs": 8243973,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Back then."
    } ]
  }, {
    "tStartMs": 8245173,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "But if you see today, it is."
    } ]
  }, {
    "tStartMs": 8247853,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "And I am assuming the same thing.\nI am assuming US, China continue to fight."
    } ]
  }, {
    "tStartMs": 8252293,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "And Taiwan becomes..."
    } ]
  }, {
    "tStartMs": 8255973,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "I don't know,\nmaybe our friend in that fight"
    } ]
  }, {
    "tStartMs": 8257813,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "or maybe not our friend."
    } ]
  }, {
    "tStartMs": 8259333,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "If our supply chain gets disrupted"
    } ]
  }, {
    "tStartMs": 8261653,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "where we can't get those\n2mm semiconductors,"
    } ]
  }, {
    "tStartMs": 8264693,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "what does India do then?"
    } ]
  }, {
    "tStartMs": 8266413,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "It is a tough question because,\nyou know, it is divided in multiple parts."
    } ]
  }, {
    "tStartMs": 8270333,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "So it is not only about two nanometres."
    } ]
  }, {
    "tStartMs": 8271653,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Two nanometre is only one segment.\nThen you have--"
    } ]
  }, {
    "tStartMs": 8273933,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "So, government is saying, you start with,"
    } ]
  }, {
    "tStartMs": 8275813,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "let's say 35 nanometres right now,\nis good enough."
    } ]
  }, {
    "tStartMs": 8279053,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "Because you have to start coming slowly\none by one. Right?"
    } ]
  }, {
    "tStartMs": 8282933,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "So even that, you know,\nif we can start at 35,"
    } ]
  }, {
    "tStartMs": 8288373,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "because those are larger components,\nwhich can go into you know, other things."
    } ]
  }, {
    "tStartMs": 8293773,
    "dDurationMs": 6240,
    "segs": [ {
      "utf8": "You know, refrigerators, TVs,\nvacuums, cars and all."
    } ]
  }, {
    "tStartMs": 8300093,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "And then slowly, slowly you start coming\nin for the ITs and the mobile phones."
    } ]
  }, {
    "tStartMs": 8305333,
    "dDurationMs": 5160,
    "segs": [ {
      "utf8": "But at least we start attacking the,\nyou know, the 35, 40 nanometres,"
    } ]
  }, {
    "tStartMs": 8310573,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "25 nanometres, start attacking that."
    } ]
  }, {
    "tStartMs": 8313813,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "So that is the opportunity."
    } ]
  }, {
    "tStartMs": 8314973,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "I mean, straight away, you know,\nyou can't leapfrog."
    } ]
  }, {
    "tStartMs": 8317533,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "As I said, China has put\nbillions and billions of dollars"
    } ]
  }, {
    "tStartMs": 8320493,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "and still they are not able\nto achieve that."
    } ]
  }, {
    "tStartMs": 8322053,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "And there are--\nAgain, it's a country play."
    } ]
  }, {
    "tStartMs": 8325453,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "A company can't build something like this."
    } ]
  }, {
    "tStartMs": 8328533,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "Country, you know, has to come into it."
    } ]
  }, {
    "tStartMs": 8331253,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "For example, to do a,"
    } ]
  }, {
    "tStartMs": 8334413,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "let's say,\nanything less than 10 nanometres,"
    } ]
  }, {
    "tStartMs": 8336333,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "you need to have lithography."
    } ]
  }, {
    "tStartMs": 8337693,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "What is that?"
    } ]
  }, {
    "tStartMs": 8338853,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "It's a machine. It's a technology."
    } ]
  }, {
    "tStartMs": 8341213,
    "dDurationMs": 6640,
    "segs": [ {
      "utf8": "That technology is right now\nwith Holland, Netherlands."
    } ]
  }, {
    "tStartMs": 8347933,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "There is a company...\nThis company name is..."
    } ]
  }, {
    "tStartMs": 8352173,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "-ASML.\n-ASML."
    } ]
  }, {
    "tStartMs": 8353293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "No competitors."
    } ]
  }, {
    "tStartMs": 8354373,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "So, ASML has those machines."
    } ]
  }, {
    "tStartMs": 8355853,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "You need to have access to that."
    } ]
  }, {
    "tStartMs": 8358693,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "In those machines, the software\nactually is coming from the United States."
    } ]
  }, {
    "tStartMs": 8361573,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "So it's a-- It's all a--"
    } ]
  }, {
    "tStartMs": 8363573,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "Because it's a game where you need to\nwork on this technology"
    } ]
  }, {
    "tStartMs": 8367293,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "and need to stabilise the technology."
    } ]
  }, {
    "tStartMs": 8368733,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "So the government has to come\nand play into that."
    } ]
  }, {
    "tStartMs": 8371013,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "So, it's way more deeper\nthan what we feel. Because, you know--"
    } ]
  }, {
    "tStartMs": 8375813,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "But, you know,\nsemiconductor is a vast range."
    } ]
  }, {
    "tStartMs": 8378773,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "It's not only that, only doing a TSMC,"
    } ]
  }, {
    "tStartMs": 8381093,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "because when we talk about semiconductors,\nyou know, we always talk about TSMC."
    } ]
  }, {
    "tStartMs": 8386293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Memory."
    } ]
  }, {
    "tStartMs": 8387373,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Why can't India have its own memory?"
    } ]
  }, {
    "tStartMs": 8389533,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Can we design our own?"
    } ]
  }, {
    "tStartMs": 8392053,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "Let's, for example, in your IT,"
    } ]
  }, {
    "tStartMs": 8393973,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "there is Gen 4, there is Gen 5,\nnow there is Gen 6."
    } ]
  }, {
    "tStartMs": 8398453,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Why can't India come up with,"
    } ]
  }, {
    "tStartMs": 8399853,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "I'm talking about, let's say,\nGen 8 or Gen 9?"
    } ]
  }, {
    "tStartMs": 8402653,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "End of the day, you have to have that."
    } ]
  }, {
    "tStartMs": 8405973,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "So these are all opportunities--"
    } ]
  }, {
    "tStartMs": 8407973,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "I'll ask you a question\non top of your question only."
    } ]
  }, {
    "tStartMs": 8409893,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Why is it not happening?"
    } ]
  }, {
    "tStartMs": 8411493,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "Because in India,\nwe were good in services."
    } ]
  }, {
    "tStartMs": 8414213,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "So we were--\nOur services sector was doing good."
    } ]
  }, {
    "tStartMs": 8416493,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So people said, okay,\nlet's build on the services business."
    } ]
  }, {
    "tStartMs": 8419613,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "So if you see all these Gen 4, 5,"
    } ]
  }, {
    "tStartMs": 8422493,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "half of their manpower\nwill be sitting in Bangalore and Hyderabad"
    } ]
  }, {
    "tStartMs": 8425733,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "and designing for the other bigger brands"
    } ]
  }, {
    "tStartMs": 8428453,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "who are somewhere in US\nor other countries."
    } ]
  }, {
    "tStartMs": 8433853,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "But not for us."
    } ]
  }, {
    "tStartMs": 8435453,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Because A, we were not having\nthose government programmes earlier."
    } ]
  }, {
    "tStartMs": 8438653,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "They were not, right--"
    } ]
  }, {
    "tStartMs": 8441253,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Not focused on creating\nsomething like that."
    } ]
  }, {
    "tStartMs": 8444493,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So, where the buck was going was,"
    } ]
  }, {
    "tStartMs": 8446853,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "okay, services is an easy business,\nlet's go there."
    } ]
  }, {
    "tStartMs": 8450733,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Half of the people working on those\ntechnologies will be from India."
    } ]
  }, {
    "tStartMs": 8454853,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "He was talking about Qualcomm or MTK,\ntheir biggest R\u0026D centres are in India."
    } ]
  }, {
    "tStartMs": 8459293,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "-Mm?\n-Yes."
    } ]
  }, {
    "tStartMs": 8462213,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "So the focus--"
    } ]
  }, {
    "tStartMs": 8463813,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "But now we have, you know,\nwith the current government,"
    } ]
  }, {
    "tStartMs": 8466733,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "all the new schemes coming in,"
    } ]
  }, {
    "tStartMs": 8470133,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "people are becoming more aware of that."
    } ]
  }, {
    "tStartMs": 8473573,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "See, today we are discussing\nabout semiconductors."
    } ]
  }, {
    "tStartMs": 8476453,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "Otherwise, if it was a consumer brand\nor electronics and that,"
    } ]
  }, {
    "tStartMs": 8479773,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "why will we be discussing\nabout semiconductors?"
    } ]
  }, {
    "tStartMs": 8482133,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "Because now, all of us,\nbecause of the policies and everything,"
    } ]
  }, {
    "tStartMs": 8484893,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "and whatever happened,\nwe are more aware of that."
    } ]
  }, {
    "tStartMs": 8488813,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "You are doing a bunch of\nvery new things, right?"
    } ]
  }, {
    "tStartMs": 8491773,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Like with television, operating software."
    } ]
  }, {
    "tStartMs": 8494773,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "There is one company\nthat we are both part of."
    } ]
  }, {
    "tStartMs": 8498533,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "-Around television, as well.\n-Yeah."
    } ]
  }, {
    "tStartMs": 8500053,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "What's happening in that world?\nWould you like to tell us?"
    } ]
  }, {
    "tStartMs": 8502533,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "No, that's more on the aggregation,"
    } ]
  }, {
    "tStartMs": 8505013,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "because the way we consume content\nis completely changing."
    } ]
  }, {
    "tStartMs": 8508613,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "Can you tell us your thesis around that?"
    } ]
  }, {
    "tStartMs": 8511253,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "Thesis is that, you know,\nyou buy a product,"
    } ]
  }, {
    "tStartMs": 8513853,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "and then you start getting multiple apps,"
    } ]
  }, {
    "tStartMs": 8516933,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "and then you start paying different apps."
    } ]
  }, {
    "tStartMs": 8522933,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "Then your user experience is then,"
    } ]
  }, {
    "tStartMs": 8525653,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "that whatever recommendation\none is showing something else,"
    } ]
  }, {
    "tStartMs": 8528213,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "the other is showing us\nsome different recommendation,"
    } ]
  }, {
    "tStartMs": 8530773,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "third is showing something else."
    } ]
  }, {
    "tStartMs": 8532373,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "Why can't I have an experience\nwherein I switch on my TV,"
    } ]
  }, {
    "tStartMs": 8537013,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "and then I don't have to go in any app?"
    } ]
  }, {
    "tStartMs": 8539293,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "There is one user interface,\nand all the apps are stitched into that."
    } ]
  }, {
    "tStartMs": 8543933,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "You just type in your,\nlet's say, username."
    } ]
  }, {
    "tStartMs": 8548013,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Let's say nikhil@gmail.com,"
    } ]
  }, {
    "tStartMs": 8551093,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "and then everything from your Netflix\nto your Zee to your Sony,"
    } ]
  }, {
    "tStartMs": 8556653,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "as per your choice and recommendation,\neverything starts coming on one screen."
    } ]
  }, {
    "tStartMs": 8559933,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "You're not going in an app."
    } ]
  }, {
    "tStartMs": 8563133,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "That's one area-- Because again,\nit's an evolving space."
    } ]
  }, {
    "tStartMs": 8567933,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "And then you bundle it\nalong with the hardware piece,"
    } ]
  }, {
    "tStartMs": 8570213,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "wherein you move on a SaaS model."
    } ]
  }, {
    "tStartMs": 8573293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "How do you..."
    } ]
  }, {
    "tStartMs": 8575453,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "I'm pretty interested\nin this business model,"
    } ]
  }, {
    "tStartMs": 8576933,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "because as a content platform,\nyou don't want to be unbundled, right?"
    } ]
  }, {
    "tStartMs": 8580893,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "You want your own app,\nyour own user experience."
    } ]
  }, {
    "tStartMs": 8583293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yes."
    } ]
  }, {
    "tStartMs": 8584373,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "How do you get their stuff?"
    } ]
  }, {
    "tStartMs": 8586133,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "Like, it's not in their incentive\nto unbundle their content."
    } ]
  }, {
    "tStartMs": 8590253,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Like, you're saying,\nhow do you get access to that content?"
    } ]
  }, {
    "tStartMs": 8592733,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yeah, for instance, Netflix."
    } ]
  }, {
    "tStartMs": 8593813,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "If I'm Netflix, and you say,\nyou just want to take the content..."
    } ]
  }, {
    "tStartMs": 8596493,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Apart from Netflix,\nyou take some other example,"
    } ]
  }, {
    "tStartMs": 8598453,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "because that's\na different animal altogether."
    } ]
  }, {
    "tStartMs": 8600293,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "-Hotstar.\n-Let's say Hotstar, yeah."
    } ]
  }, {
    "tStartMs": 8602813,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "So, I have my own app,\nI have my own users,"
    } ]
  }, {
    "tStartMs": 8605693,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "I don't want to give you my content,"
    } ]
  }, {
    "tStartMs": 8607053,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "because then I lose\nmy competitive advantage."
    } ]
  }, {
    "tStartMs": 8610173,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Then my content becomes a commodity\non your platform."
    } ]
  }, {
    "tStartMs": 8613333,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "So, I mean, the platform,\nthe content, the platforms,"
    } ]
  }, {
    "tStartMs": 8616773,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "they will try and hedge\nagainst this, right?"
    } ]
  }, {
    "tStartMs": 8620613,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "So, if there are like, say, 25 apps,"
    } ]
  }, {
    "tStartMs": 8622693,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "which are the most widely used apps\nout there,"
    } ]
  }, {
    "tStartMs": 8626013,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "and out of 25, 90% of the apps,"
    } ]
  }, {
    "tStartMs": 8629373,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "you're able to get inside the app"
    } ]
  }, {
    "tStartMs": 8632573,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "and get the permission for recommendation\nand everything."
    } ]
  }, {
    "tStartMs": 8637493,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "And then, you know,\nput it on your screen for the user."
    } ]
  }, {
    "tStartMs": 8641293,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "I think it's acceptable."
    } ]
  }, {
    "tStartMs": 8643773,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "-So, for them, it's like incremental.\n-Yes."
    } ]
  }, {
    "tStartMs": 8646333,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "If I don't work with you,\nI won't make this money."
    } ]
  }, {
    "tStartMs": 8648533,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Might as well make the money."
    } ]
  }, {
    "tStartMs": 8649653,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "-Because they also need distribution.\n-Yeah."
    } ]
  }, {
    "tStartMs": 8653013,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "So, then you have a few big ones\nthat are harder to negotiate with."
    } ]
  }, {
    "tStartMs": 8656733,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "They will come with scale."
    } ]
  }, {
    "tStartMs": 8658453,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So, once you achieve scale,\nthey will say, \"All right.\""
    } ]
  }, {
    "tStartMs": 8660813,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "-\"We also want this.\"\n-I get it."
    } ]
  }, {
    "tStartMs": 8662893,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "It's a bit like\ncell phone and app store, right?"
    } ]
  }, {
    "tStartMs": 8665773,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 8667893,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "So, when there's a new OS\non the cell phone,"
    } ]
  }, {
    "tStartMs": 8670933,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "the big app makers\nare not going to adopt, right?"
    } ]
  }, {
    "tStartMs": 8674053,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "They're going to wait for the distribution\nto come first."
    } ]
  }, {
    "tStartMs": 8677413,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "So, I think it's about that adoption."
    } ]
  }, {
    "tStartMs": 8679293,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 8680693,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "But when you bundle,\nI think it gets cheaper."
    } ]
  }, {
    "tStartMs": 8682773,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 8685093,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Why don't you guys speak\nlike I'm not in the room"
    } ]
  }, {
    "tStartMs": 8687053,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "and there are no cameras?"
    } ]
  }, {
    "tStartMs": 8689373,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Yeah, isn't... We're trying to."
    } ]
  }, {
    "tStartMs": 8691173,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "[laughter]"
    } ]
  }, {
    "tStartMs": 8692253,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "Carl, what opportunity exists\nin the consumer market besides phones?"
    } ]
  }, {
    "tStartMs": 8696773,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "What do I want to have exist?"
    } ]
  }, {
    "tStartMs": 8698453,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "No. I mean,\nwhat are the opportunities which--"
    } ]
  }, {
    "tStartMs": 8700853,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "Oh, what opportunities exist?"
    } ]
  }, {
    "tStartMs": 8702133,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Not for the large players."
    } ]
  }, {
    "tStartMs": 8704493,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "I'm only thinking about, like,\nvery big categories all the time."
    } ]
  }, {
    "tStartMs": 8708733,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "I'm thinking about, like,\nEVs and robotics stuff."
    } ]
  }, {
    "tStartMs": 8714173,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "But I agree, like, if you're young,"
    } ]
  }, {
    "tStartMs": 8715893,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "you have to start with something\nmore simple."
    } ]
  }, {
    "tStartMs": 8719453,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "[Nikhil] What is China like?"
    } ]
  }, {
    "tStartMs": 8720613,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "What else do you think we can learn\nas a country from them?"
    } ]
  }, {
    "tStartMs": 8725533,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "I don't spend a lot of time\nthinking about policy."
    } ]
  }, {
    "tStartMs": 8727813,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "But I do think the PLI is set up..."
    } ]
  }, {
    "tStartMs": 8729813,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "You probably know more\nabout PLI than me, but..."
    } ]
  }, {
    "tStartMs": 8734333,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "We are very keen to be a part\nof the next generation PLI scheme."
    } ]
  }, {
    "tStartMs": 8741413,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "I think if India wants to develop\nits own smartphone ecosystem,"
    } ]
  }, {
    "tStartMs": 8745453,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "starting from the factory,\nEMS side is very good."
    } ]
  }, {
    "tStartMs": 8748253,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "That's already happening."
    } ]
  }, {
    "tStartMs": 8750013,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "Incentivising foreign and domestic players\nto build here."
    } ]
  }, {
    "tStartMs": 8754053,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "It's already happening."
    } ]
  }, {
    "tStartMs": 8755933,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "I think to reach the next stage,"
    } ]
  }, {
    "tStartMs": 8757613,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "it can't just be\nmanufacturing and exports."
    } ]
  }, {
    "tStartMs": 8761533,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Because ultimately,\nthat's not the highest value add."
    } ]
  }, {
    "tStartMs": 8764453,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "The next stage will be to design\nand engineer here as well."
    } ]
  }, {
    "tStartMs": 8767813,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "So, what is the next stage policy"
    } ]
  }, {
    "tStartMs": 8770093,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "after the goal of PLI\nhas been accomplished?"
    } ]
  }, {
    "tStartMs": 8773933,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "What is the next stage plan? I'm not sure."
    } ]
  }, {
    "tStartMs": 8775933,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "I'm just starting to spend more time\nand learn more about this."
    } ]
  }, {
    "tStartMs": 8779973,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "So, I think, to your question that,\nwhat can we do?"
    } ]
  }, {
    "tStartMs": 8783293,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "If you see what they have done\nin last 25 years,"
    } ]
  }, {
    "tStartMs": 8786653,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "in terms of\nall the government policies, so..."
    } ]
  }, {
    "tStartMs": 8791253,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "We are discussing about incentivising,\nthat is one."
    } ]
  }, {
    "tStartMs": 8793893,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "That is one incentive."
    } ]
  }, {
    "tStartMs": 8795653,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "But rest of the other enablers,"
    } ]
  }, {
    "tStartMs": 8797173,
    "dDurationMs": 5240,
    "segs": [ {
      "utf8": "for example, the whole supply chain\nin terms of materials and everything,"
    } ]
  }, {
    "tStartMs": 8802493,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "they have worked\na lot deeper on that segment."
    } ]
  }, {
    "tStartMs": 8805693,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "In terms of logistics,"
    } ]
  }, {
    "tStartMs": 8808133,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "they have created logistics parks\nto enable that."
    } ]
  }, {
    "tStartMs": 8811773,
    "dDurationMs": 4720,
    "segs": [ {
      "utf8": "Today, if we are talking about,\nfor example, now we have,"
    } ]
  }, {
    "tStartMs": 8816573,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "let's say, iPhones going and exporting\nand doing all this sort of things."
    } ]
  }, {
    "tStartMs": 8821693,
    "dDurationMs": 5880,
    "segs": [ {
      "utf8": "The way we are expanding,\nyou will need two full, bigger, you know,"
    } ]
  }, {
    "tStartMs": 8827653,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "large aircrafts every week\nto ferry the product from here to Chicago."
    } ]
  }, {
    "tStartMs": 8833893,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "We need to have that."
    } ]
  }, {
    "tStartMs": 8835893,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "We need to, you know, build bigger ports,"
    } ]
  }, {
    "tStartMs": 8839173,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "wherein you can reduce the time."
    } ]
  }, {
    "tStartMs": 8841213,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "Because they have taken all that measures,\nnot only in one segment,"
    } ]
  }, {
    "tStartMs": 8844373,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "because we talk only about this,"
    } ]
  }, {
    "tStartMs": 8845693,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "but every segment,\nthey have done with all those policies."
    } ]
  }, {
    "tStartMs": 8850613,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "I think consumer electronics\nis a very expensive"
    } ]
  }, {
    "tStartMs": 8855653,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "and difficult thing\nfor somebody without experience."
    } ]
  }, {
    "tStartMs": 8858453,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "-All of a sudden going--\n-Experience is key, I believe."
    } ]
  }, {
    "tStartMs": 8861133,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Without that you can't do."
    } ]
  }, {
    "tStartMs": 8863173,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "In fact, you can't do also,\nI personally think."
    } ]
  }, {
    "tStartMs": 8865333,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "[Nikhil] You're making dessert?"
    } ]
  }, {
    "tStartMs": 8867253,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "-Yeah--\n-[Amit] Doing is expensive only."
    } ]
  }, {
    "tStartMs": 8869413,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "I mean, you will 100% make mistakes."
    } ]
  }, {
    "tStartMs": 8872133,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "I think we found a couple of themes,\nyou know, where people could start."
    } ]
  }, {
    "tStartMs": 8875733,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "Something more focused,\nsomething more niche,"
    } ]
  }, {
    "tStartMs": 8878373,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "lower risk, lower capex."
    } ]
  }, {
    "tStartMs": 8880853,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "Start from there, evolve from there."
    } ]
  }, {
    "tStartMs": 8882693,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "It could be on the consumer side,\nwith clothing or accessories."
    } ]
  }, {
    "tStartMs": 8887373,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "It could be on the supply chain side"
    } ]
  }, {
    "tStartMs": 8889133,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "with parts of the stack\nthat are easier to make."
    } ]
  }, {
    "tStartMs": 8894133,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "And then just evolve from there."
    } ]
  }, {
    "tStartMs": 8895973,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "It could be on the distribution side"
    } ]
  }, {
    "tStartMs": 8897853,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "with content creation\nas a means of distributing information."
    } ]
  }, {
    "tStartMs": 8902613,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "But, Rahul, what is your thought?"
    } ]
  }, {
    "tStartMs": 8904573,
    "dDurationMs": 6720,
    "segs": [ {
      "utf8": "We have seen all brands across the globe\ncoming to India in consumer electronics."
    } ]
  }, {
    "tStartMs": 8911373,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "Hardly there are brands who have gone out."
    } ]
  }, {
    "tStartMs": 8913173,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "-To have gone?\n-To have gone outside India."
    } ]
  }, {
    "tStartMs": 8916013,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "-Indian brands?\n-Yeah, Indian brands."
    } ]
  }, {
    "tStartMs": 8918653,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Forget Southeast Asian countries\nfor a while."
    } ]
  }, {
    "tStartMs": 8921733,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "But none of the brands have gone outside\nour home turf and played a game there."
    } ]
  }, {
    "tStartMs": 8926653,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "Do you think world needs\nsome new age brands?"
    } ]
  }, {
    "tStartMs": 8930893,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "I have solid thesis for that."
    } ]
  }, {
    "tStartMs": 8934373,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "So, I personally think\nIndia as a country..."
    } ]
  }, {
    "tStartMs": 8937733,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "I mean we all work with scarcity mindset."
    } ]
  }, {
    "tStartMs": 8939813,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "So, what has happened that,"
    } ]
  }, {
    "tStartMs": 8941253,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "what a US or an European entrepreneur"
    } ]
  }, {
    "tStartMs": 8943653,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "would try to solve a problem\nby throwing a dollar."
    } ]
  }, {
    "tStartMs": 8947413,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "A dollar is 90 rupees for us."
    } ]
  }, {
    "tStartMs": 8949653,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "So, what I'm trying to say,\nfor us every penny counts."
    } ]
  }, {
    "tStartMs": 8952533,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "And for something\nwhat they are producing for $100,"
    } ]
  }, {
    "tStartMs": 8956053,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "a similar great quality product,"
    } ]
  }, {
    "tStartMs": 8957973,
    "dDurationMs": 6520,
    "segs": [ {
      "utf8": "Indian entrepreneur could build for,\nlet's say 30-40% cheaper than them."
    } ]
  }, {
    "tStartMs": 8965333,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "We have captive consumption."
    } ]
  }, {
    "tStartMs": 8968933,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Entrepreneurs now are very smart,"
    } ]
  }, {
    "tStartMs": 8970533,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "they are very evolved,\ntravelled, done across."
    } ]
  }, {
    "tStartMs": 8974093,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "Why can't we take that arbitrage\nand take these brands to the globe?"
    } ]
  }, {
    "tStartMs": 8978733,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "I mean, we are good at marketing\nby the way, Indian entrepreneur."
    } ]
  }, {
    "tStartMs": 8981293,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Software, we are good at."
    } ]
  }, {
    "tStartMs": 8983253,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Hardware, we can learn from our peers."
    } ]
  }, {
    "tStartMs": 8986573,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Why can't Indian brands--"
    } ]
  }, {
    "tStartMs": 8987973,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "Why can't we build brands\nwho are based out of India"
    } ]
  }, {
    "tStartMs": 8992373,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "and move to global scale?"
    } ]
  }, {
    "tStartMs": 8995133,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "There are no brands existing everywhere,\nthere are old traditional brands."
    } ]
  }, {
    "tStartMs": 8999133,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "-It's starting now, right?\n-Yeah."
    } ]
  }, {
    "tStartMs": 9001293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "With you guys."
    } ]
  }, {
    "tStartMs": 9002373,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "[Amit] So,\nthat's what we are trying to do."
    } ]
  }, {
    "tStartMs": 9004813,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "We believe that\nit is a right platform for us."
    } ]
  }, {
    "tStartMs": 9008093,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "We have gained decent experience"
    } ]
  }, {
    "tStartMs": 9010853,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "and international markets\nwe could do justice."
    } ]
  }, {
    "tStartMs": 9014253,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "But I'm generally talking."
    } ]
  }, {
    "tStartMs": 9016133,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "We need more brands. One brand can't do."
    } ]
  }, {
    "tStartMs": 9018373,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "I mean, I have seen we all buying\ninternational brands."
    } ]
  }, {
    "tStartMs": 9021173,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Are you talking about-- You want me\nto answer in consumer electronics?"
    } ]
  }, {
    "tStartMs": 9023853,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "I am talking about consumer electronics,\nspecifically, yeah."
    } ]
  }, {
    "tStartMs": 9026533,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "In consumer electronics,"
    } ]
  }, {
    "tStartMs": 9028053,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "you can go into those markets\nwhere your products are relevant."
    } ]
  }, {
    "tStartMs": 9033493,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "-Bang on.\n-[Rahul] Okay?"
    } ]
  }, {
    "tStartMs": 9035053,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "So, for example, in Indian demographics,\nwhatever products you are making,"
    } ]
  }, {
    "tStartMs": 9038773,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "you are going to take the same product\nbecause you have scale and you go there."
    } ]
  }, {
    "tStartMs": 9042533,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "So, that's what I am saying. So, when..."
    } ]
  }, {
    "tStartMs": 9045733,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "I mean, I want to cater to a market\nwhich is, let's say, mid."
    } ]
  }, {
    "tStartMs": 9050293,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Because I don't want a cheapest product."
    } ]
  }, {
    "tStartMs": 9052253,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "-Which is fine. So--\n-[Amit] Indian demographic."
    } ]
  }, {
    "tStartMs": 9054533,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "So, those products you have taken into\nthose similar categories and similar..."
    } ]
  }, {
    "tStartMs": 9060053,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "-you know, geographies.\n-[Amit] Yeah."
    } ]
  }, {
    "tStartMs": 9061773,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "-That you can do.\n-[Amit] Yeah."
    } ]
  }, {
    "tStartMs": 9063933,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "Southeast Asia, all other, you know,\nso, for example, all the SAARC countries,"
    } ]
  }, {
    "tStartMs": 9068133,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "then this side, Russia, Eastern Europe."
    } ]
  }, {
    "tStartMs": 9070893,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "These are fantastic markets."
    } ]
  }, {
    "tStartMs": 9072333,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "-[Amit] Yeah.\n-Right?"
    } ]
  }, {
    "tStartMs": 9074133,
    "dDurationMs": 5400,
    "segs": [ {
      "utf8": "Then second, if you are saying\nthat you want to hit the upper deck."
    } ]
  }, {
    "tStartMs": 9079613,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "I am just staying middle."
    } ]
  }, {
    "tStartMs": 9081173,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "See, upper, I am very clear."
    } ]
  }, {
    "tStartMs": 9082973,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "Let Sony, Samsung play the game\nwhat they are playing, or Apple."
    } ]
  }, {
    "tStartMs": 9086373,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "We don't want to touch them."
    } ]
  }, {
    "tStartMs": 9087613,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "The consumers are very loyal.\nThey have an ecosystem."
    } ]
  }, {
    "tStartMs": 9090013,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "They have advantages\nof whatever they could, so..."
    } ]
  }, {
    "tStartMs": 9093253,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "You already have a scale in India."
    } ]
  }, {
    "tStartMs": 9096573,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "And then when you are going outside,\nyou know, you go with that."
    } ]
  }, {
    "tStartMs": 9100253,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "Same scale and cater to that."
    } ]
  }, {
    "tStartMs": 9102573,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Create one or two more brands."
    } ]
  }, {
    "tStartMs": 9106733,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "And use--\nLeverage the scale what you have."
    } ]
  }, {
    "tStartMs": 9111573,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "And, you know,\nyou can attack the markets--"
    } ]
  }, {
    "tStartMs": 9113293,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "No, that's what I am saying, we can do it."
    } ]
  }, {
    "tStartMs": 9115053,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "-India need those brands.\n-Yes."
    } ]
  }, {
    "tStartMs": 9117613,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "We are just no more\nabout basic necessity brand,"
    } ]
  }, {
    "tStartMs": 9120453,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "where we are just solving for features."
    } ]
  }, {
    "tStartMs": 9123693,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "And you'll be surprised, I'll tell you,\nRahul, where I'm coming from,"
    } ]
  }, {
    "tStartMs": 9125933,
    "dDurationMs": 3560,
    "segs": [ {
      "utf8": "When we-- We just launched in Dubai\nin Virgin stores."
    } ]
  }, {
    "tStartMs": 9130173,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "Traditionally, Indian brands would have\ngone and launched a $20 product."
    } ]
  }, {
    "tStartMs": 9133213,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "We launched ourselves\nat $75 to $100 pricing."
    } ]
  }, {
    "tStartMs": 9136453,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "And we're getting a great response."
    } ]
  }, {
    "tStartMs": 9138213,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "I mean, look at the kind of response\npeople are giving"
    } ]
  }, {
    "tStartMs": 9140453,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "for a decent-price-point products."
    } ]
  }, {
    "tStartMs": 9142973,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "-Again, innovation is one.\n-100%."
    } ]
  }, {
    "tStartMs": 9145293,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "Innovation is needed.\nYou can't enter a commodity space."
    } ]
  }, {
    "tStartMs": 9148373,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Innovation and then you can have--"
    } ]
  }, {
    "tStartMs": 9150133,
    "dDurationMs": 6160,
    "segs": [ {
      "utf8": "Create different brands for,\nyou know, different needs."
    } ]
  }, {
    "tStartMs": 9156373,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "One brand can't serve all, that's true."
    } ]
  }, {
    "tStartMs": 9158213,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "[Rahul] Look at..."
    } ]
  }, {
    "tStartMs": 9159533,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "Here you have OPPO, then you have OnePlus,\nthen you have Realme."
    } ]
  }, {
    "tStartMs": 9163213,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Under one umbrella only."
    } ]
  }, {
    "tStartMs": 9164333,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "-We have two brands.\n-[Rahul] Yeah."
    } ]
  }, {
    "tStartMs": 9166653,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "He has to come up with CMF because..."
    } ]
  }, {
    "tStartMs": 9168453,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "-We need the scale.\n-Yeah."
    } ]
  }, {
    "tStartMs": 9170373,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "The scale, 100% is needed."
    } ]
  }, {
    "tStartMs": 9171973,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "I think you can build mid-market\nwith the scale."
    } ]
  }, {
    "tStartMs": 9175133,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "-Yeah.\n-Otherwise, nobody gonna support you."
    } ]
  }, {
    "tStartMs": 9178053,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 9179133,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "But I think it's--"
    } ]
  }, {
    "tStartMs": 9181133,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "The Indian economy\nhas got into a point in time"
    } ]
  }, {
    "tStartMs": 9183373,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "where there's entrepreneurs\nwith a skill-set to go global."
    } ]
  }, {
    "tStartMs": 9186133,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "And it's already the language advantage,\nthe language and culture advantage."
    } ]
  }, {
    "tStartMs": 9190333,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "-It's easier to do marketing.\n-[Amit] Yeah."
    } ]
  }, {
    "tStartMs": 9192093,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Right? It's easier to do US or Europe."
    } ]
  }, {
    "tStartMs": 9196493,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "But on the product definition side,"
    } ]
  }, {
    "tStartMs": 9198053,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "it's easier to go to\nmore similar markets first."
    } ]
  }, {
    "tStartMs": 9201653,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "There will be more risk going into..."
    } ]
  }, {
    "tStartMs": 9203493,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "You need product market fit,\nwhich I am aligned."
    } ]
  }, {
    "tStartMs": 9205613,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "You go to-- Like, we also are going\nto similar markets,"
    } ]
  }, {
    "tStartMs": 9208173,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "which are easy acceptance."
    } ]
  }, {
    "tStartMs": 9209573,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "And then try to go in territory--\nI respect all territories."
    } ]
  }, {
    "tStartMs": 9212973,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "So, I mean, let's say US,\nthese are all tough markets."
    } ]
  }, {
    "tStartMs": 9215453,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "It's easy to go and break there."
    } ]
  }, {
    "tStartMs": 9217053,
    "dDurationMs": 4440,
    "segs": [ {
      "utf8": "So, I would like to go small there,\ndo little trials, fail, and then take on."
    } ]
  }, {
    "tStartMs": 9222693,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Yeah. So, they are, as I said,\ngoing to SAARC countries,"
    } ]
  }, {
    "tStartMs": 9225213,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "going to, you know,\nRussia, Eastern Europe,"
    } ]
  }, {
    "tStartMs": 9229333,
    "dDurationMs": 3760,
    "segs": [ {
      "utf8": "which are all, you know, great markets\nfor you to do your trials and all."
    } ]
  }, {
    "tStartMs": 9233173,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "And then also tweak."
    } ]
  }, {
    "tStartMs": 9235013,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "We should start, like, a hub."
    } ]
  }, {
    "tStartMs": 9238493,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "Like, start a place\nwhere we fund young entrepreneurs"
    } ]
  }, {
    "tStartMs": 9241613,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "to build some of the stuff we spoke about."
    } ]
  }, {
    "tStartMs": 9244173,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "100%"
    } ]
  }, {
    "tStartMs": 9246653,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "Right? Like, get some land,\ngive them the resources."
    } ]
  }, {
    "tStartMs": 9251573,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "You guys all have the know-how."
    } ]
  }, {
    "tStartMs": 9254893,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "Like, start one place where people can--"
    } ]
  }, {
    "tStartMs": 9257533,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "Like, an incubator of sorts,\nwith real estate."
    } ]
  }, {
    "tStartMs": 9260533,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "And it's easier to do. On..."
    } ]
  }, {
    "tStartMs": 9264533,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "And it could be anything."
    } ]
  }, {
    "tStartMs": 9266093,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "You know, you can--"
    } ]
  }, {
    "tStartMs": 9267573,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "If somebody comes up with an idea\nwith a diaper,"
    } ]
  }, {
    "tStartMs": 9271093,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "which will have some connectivity,"
    } ]
  }, {
    "tStartMs": 9273053,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "which tells that it is wet or not\nor whatever."
    } ]
  }, {
    "tStartMs": 9276533,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "Same tech you could be using,\nlet's say, in the ring."
    } ]
  }, {
    "tStartMs": 9279093,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "I just found out a tech\nwhere my daughter--"
    } ]
  }, {
    "tStartMs": 9283133,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "My wife wanted to monitor\nmy daughter about fever."
    } ]
  }, {
    "tStartMs": 9286453,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "And you can't measure\nevery time for a kid."
    } ]
  }, {
    "tStartMs": 9288173,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "So, there was a socks she could wear\nwhen she was six months or a year."
    } ]
  }, {
    "tStartMs": 9292413,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "It could track the sleep,\nthe temperature and everything. So..."
    } ]
  }, {
    "tStartMs": 9297653,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "These are micro-niche markets,\nbut yeah, innovations are there."
    } ]
  }, {
    "tStartMs": 9300613,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "What's the deal with these rings\nthat you are wearing?"
    } ]
  }, {
    "tStartMs": 9302973,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Why are they growing so much?\nWhy is everybody buying them?"
    } ]
  }, {
    "tStartMs": 9305893,
    "dDurationMs": 5760,
    "segs": [ {
      "utf8": "So, I think market moves\nin different form factors."
    } ]
  }, {
    "tStartMs": 9312493,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "And market need newness."
    } ]
  }, {
    "tStartMs": 9316933,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "This form factor, like watches,\nare maybe mass-adoption phase,"
    } ]
  }, {
    "tStartMs": 9320813,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "whatever phase you want to call."
    } ]
  }, {
    "tStartMs": 9323693,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "Rings are a new category, early adopters."
    } ]
  }, {
    "tStartMs": 9327533,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "And people are getting\nmore health conscious, also."
    } ]
  }, {
    "tStartMs": 9330973,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "So, they are pairing it\nwith their watches, by the way."
    } ]
  }, {
    "tStartMs": 9334013,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "They are not a replacement for a watch."
    } ]
  }, {
    "tStartMs": 9335733,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "Is that an opportunity,\nhealth-related consumer electronics?"
    } ]
  }, {
    "tStartMs": 9340253,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "You guys seeing any trends there?"
    } ]
  }, {
    "tStartMs": 9341893,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "So, I wear a WHOOP on my feet."
    } ]
  }, {
    "tStartMs": 9346373,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "So, what I have realised,\nI am into, I mean..."
    } ]
  }, {
    "tStartMs": 9350573,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "I am little bit into this space,\nso I understand it."
    } ]
  }, {
    "tStartMs": 9353773,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "So, consumer is saying it's good to have."
    } ]
  }, {
    "tStartMs": 9357373,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "Meaning, I want a fitness device,\nbut I will not track fitness."
    } ]
  }, {
    "tStartMs": 9360813,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "I mean, you would see a guy\nwearing a WHOOP-- I was talking--"
    } ]
  }, {
    "tStartMs": 9364133,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "and eating a McDonald's burger\nand a cola and a 100 kilos."
    } ]
  }, {
    "tStartMs": 9369693,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "So, it's just visual cues to tell people"
    } ]
  }, {
    "tStartMs": 9373093,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "that I belong to this universe\nwhere I know."
    } ]
  }, {
    "tStartMs": 9376493,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "I want to know what I am,\nbut they are not cautious."
    } ]
  }, {
    "tStartMs": 9379573,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "I think they are little bit aware of it,\nbut not that--"
    } ]
  }, {
    "tStartMs": 9383733,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "India is a market, internationally, yes."
    } ]
  }, {
    "tStartMs": 9385533,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "People are more and more health conscious."
    } ]
  }, {
    "tStartMs": 9388613,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Preventive healthcare is..."
    } ]
  }, {
    "tStartMs": 9390213,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "-You know that patch which measures--\n-CGM."
    } ]
  }, {
    "tStartMs": 9393493,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "-Insulin spikes.\n-Yeah."
    } ]
  }, {
    "tStartMs": 9395453,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "I have always been thinking\nthat at some point"
    } ]
  }, {
    "tStartMs": 9397733,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "an Apple Watch can start doing that."
    } ]
  }, {
    "tStartMs": 9399253,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "Do you think that's an opportunity,\nif your watch has a CGM monitor in it?"
    } ]
  }, {
    "tStartMs": 9403613,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "So, if you look at use cases,\nso I think these devices--"
    } ]
  }, {
    "tStartMs": 9407653,
    "dDurationMs": 4920,
    "segs": [ {
      "utf8": "Okay, diabetic is a very big used case,\nthis problem."
    } ]
  }, {
    "tStartMs": 9412653,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "And this doesn't work, by the way.\nNobody uses it."
    } ]
  }, {
    "tStartMs": 9415933,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "For us, we have used for wellness,\nbut diabetic patient also doesn't use it."
    } ]
  }, {
    "tStartMs": 9419613,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "It is 5,000 bucks, it's too expensive."
    } ]
  }, {
    "tStartMs": 9421333,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "And nobody wants to break it every time."
    } ]
  }, {
    "tStartMs": 9424253,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "So, we feel wearable gonna divert\ntowards health side,"
    } ]
  }, {
    "tStartMs": 9426733,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "like we were talking about."
    } ]
  }, {
    "tStartMs": 9428093,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Health is a segment."
    } ]
  }, {
    "tStartMs": 9429533,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Thirty-five plus,\nyou start getting those problems."
    } ]
  }, {
    "tStartMs": 9431773,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Apple is 100% working on it."
    } ]
  }, {
    "tStartMs": 9434053,
    "dDurationMs": 6200,
    "segs": [ {
      "utf8": "But Apple will only come when it becomes\nreally solid, mainstream, proven,"
    } ]
  }, {
    "tStartMs": 9440333,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "because it's health."
    } ]
  }, {
    "tStartMs": 9441733,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "Is there no opportunity unique to India?"
    } ]
  }, {
    "tStartMs": 9444133,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "What do we want in health\nthat other people don't want?"
    } ]
  }, {
    "tStartMs": 9446853,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "No, I think, no."
    } ]
  }, {
    "tStartMs": 9448253,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "This is a good space\nif somebody is working on it."
    } ]
  }, {
    "tStartMs": 9450973,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Honestly,\nI would like to invest in a space"
    } ]
  }, {
    "tStartMs": 9452573,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "where people are working on CGM."
    } ]
  }, {
    "tStartMs": 9454253,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "So, Apple is working."
    } ]
  }, {
    "tStartMs": 9455453,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "Samsung has a huge R\u0026D centre\nin Bangalore,"
    } ]
  }, {
    "tStartMs": 9457773,
    "dDurationMs": 5240,
    "segs": [ {
      "utf8": "where they are working on\nblood pressure and CGM on device,"
    } ]
  }, {
    "tStartMs": 9463093,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "where it's non-invasive."
    } ]
  }, {
    "tStartMs": 9464493,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "So, I think in two-three years time\nwe will see it there."
    } ]
  }, {
    "tStartMs": 9467973,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "I believe in health.\nHealth has PMF in consumer electronics."
    } ]
  }, {
    "tStartMs": 9472093,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "And another field that has PMF\nis children's education."
    } ]
  }, {
    "tStartMs": 9476253,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "Parents are always willing to invest\nin the future of their kids."
    } ]
  }, {
    "tStartMs": 9480653,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "What would that look like?"
    } ]
  }, {
    "tStartMs": 9482373,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "We have a common friend\nwho is building this company"
    } ]
  }, {
    "tStartMs": 9484813,
    "dDurationMs": 4760,
    "segs": [ {
      "utf8": "called SuperLearn, where--"
    } ]
  }, {
    "tStartMs": 9490373,
    "dDurationMs": 5440,
    "segs": [ {
      "utf8": "He is trying to build a tablet\nwhich costs $150,"
    } ]
  }, {
    "tStartMs": 9495893,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "where you can't, like,\nreally browse the net"
    } ]
  }, {
    "tStartMs": 9498933,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "and go to YouTube and Netflix,"
    } ]
  }, {
    "tStartMs": 9501773,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "but replace your school bag\nwith that device."
    } ]
  }, {
    "tStartMs": 9504213,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "You mean learning like that? Do you think\nsomething like that could work?"
    } ]
  }, {
    "tStartMs": 9506733,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "That could work."
    } ]
  }, {
    "tStartMs": 9507813,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "It could also be, like,\nsome form of smartwatch for kids,"
    } ]
  }, {
    "tStartMs": 9511333,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "for learning, maybe with an AI companion."
    } ]
  }, {
    "tStartMs": 9513653,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "It could also just be a teddy bear."
    } ]
  }, {
    "tStartMs": 9515853,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "That's there, no? The toy is there."
    } ]
  }, {
    "tStartMs": 9517853,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Miko-- Miko is doing good."
    } ]
  }, {
    "tStartMs": 9520893,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "I just know that it's a space\nwhere people want to spend money"
    } ]
  }, {
    "tStartMs": 9524613,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "and are not price sensitive."
    } ]
  }, {
    "tStartMs": 9526733,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "So, you-- Wherever you are spending,"
    } ]
  }, {
    "tStartMs": 9528813,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "you will spend for your parents,\nyou will spend for your kids."
    } ]
  }, {
    "tStartMs": 9530813,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "And your health."
    } ]
  }, {
    "tStartMs": 9532773,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "And health."
    } ]
  }, {
    "tStartMs": 9533973,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "What do you guys think of Elon Musk\nin Neuralink?"
    } ]
  }, {
    "tStartMs": 9536173,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "I like the thesis."
    } ]
  }, {
    "tStartMs": 9537813,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "It's trying to make the communication\nmore efficient."
    } ]
  }, {
    "tStartMs": 9542773,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "Efficiency is always beneficial\nto humanity."
    } ]
  }, {
    "tStartMs": 9546813,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "But maybe there are other ways\nto get to higher efficiency."
    } ]
  }, {
    "tStartMs": 9549293,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "I don't know how long it will take\nfor that to really work for mass market."
    } ]
  }, {
    "tStartMs": 9554573,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "Do you think people will be willing\nto do that?"
    } ]
  }, {
    "tStartMs": 9556853,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "Like, put something in your body,\nnot on your body?"
    } ]
  }, {
    "tStartMs": 9560773,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "If the benefits are there, I think so."
    } ]
  }, {
    "tStartMs": 9562693,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "But currently...\nI don't think the benefits are there."
    } ]
  }, {
    "tStartMs": 9566653,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Just dovetailing into his question."
    } ]
  }, {
    "tStartMs": 9569133,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Wherein, these days,\npeople are talking more about organic."
    } ]
  }, {
    "tStartMs": 9572293,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "They don't want to take\nunnecessary medicines and..."
    } ]
  }, {
    "tStartMs": 9577333,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "I mean, for somebody who is disabled,"
    } ]
  }, {
    "tStartMs": 9579973,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "then they get a lot of benefit\nfrom using that product today."
    } ]
  }, {
    "tStartMs": 9583373,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "But at what point\ndoes it become beneficial"
    } ]
  }, {
    "tStartMs": 9585493,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "for a normal person to use that? And why?"
    } ]
  }, {
    "tStartMs": 9588413,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "I think there is still some time to go."
    } ]
  }, {
    "tStartMs": 9591893,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Wouldn't you suddenly become\nso much smarter"
    } ]
  }, {
    "tStartMs": 9593853,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "if you have something in your head\nwhich is telling you everything?"
    } ]
  }, {
    "tStartMs": 9597973,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "You can almost have that already now\nif you have earbuds with ChatGPT."
    } ]
  }, {
    "tStartMs": 9602013,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "You can speak to ChatGPT voice."
    } ]
  }, {
    "tStartMs": 9603773,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "-With the AI glass also coming.\n-[Carl] Yeah."
    } ]
  }, {
    "tStartMs": 9605573,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "You are sitting in front of this.\nThis is the setup. This is happening--"
    } ]
  }, {
    "tStartMs": 9607973,
    "dDurationMs": 4480,
    "segs": [ {
      "utf8": "That's way easier to adopt\nthan operating something into your body."
    } ]
  }, {
    "tStartMs": 9612533,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "What happens to the world? Like..."
    } ]
  }, {
    "tStartMs": 9614573,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "If intelligence is on call,"
    } ]
  }, {
    "tStartMs": 9617213,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "traditional intelligence is on call\nor information is on call,"
    } ]
  }, {
    "tStartMs": 9622293,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "we still have to differentiate."
    } ]
  }, {
    "tStartMs": 9624293,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "How do we do that?"
    } ]
  }, {
    "tStartMs": 9626093,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "I think most people are going to..."
    } ]
  }, {
    "tStartMs": 9628453,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "I think 80% of the population\nwill just chill"
    } ]
  }, {
    "tStartMs": 9630813,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "and receive income from the government."
    } ]
  }, {
    "tStartMs": 9633293,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "And a small group of people\nwill leverage the new technologies"
    } ]
  }, {
    "tStartMs": 9636093,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "to push society and humanity forward."
    } ]
  }, {
    "tStartMs": 9638733,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Like universal basic income."
    } ]
  }, {
    "tStartMs": 9640293,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Yeah. I think that will happen for sure."
    } ]
  }, {
    "tStartMs": 9642493,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "Yeah?"
    } ]
  }, {
    "tStartMs": 9643813,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "I think you can't replace, you know,\nemotional quotient out of that."
    } ]
  }, {
    "tStartMs": 9647253,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "You know, that's what makes\nall of us unique."
    } ]
  }, {
    "tStartMs": 9650493,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "All of us--"
    } ]
  }, {
    "tStartMs": 9651573,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "You give us the same piece of information\nto all four of us,"
    } ]
  }, {
    "tStartMs": 9654333,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "all four of us will behave differently"
    } ]
  }, {
    "tStartMs": 9656773,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "and will have different actions."
    } ]
  }, {
    "tStartMs": 9658693,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "I think that is something which..."
    } ]
  }, {
    "tStartMs": 9662813,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "you can't take away."
    } ]
  }, {
    "tStartMs": 9666453,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Do you think?"
    } ]
  }, {
    "tStartMs": 9668213,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "A little bit agree on this."
    } ]
  }, {
    "tStartMs": 9670973,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Basic, I think 80% of the jobs\nwill be done,"
    } ]
  }, {
    "tStartMs": 9673413,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "for 20% you would still need human..."
    } ]
  }, {
    "tStartMs": 9677093,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "The productivity will increase so much."
    } ]
  }, {
    "tStartMs": 9679373,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "But I think he is also right\nthat we all will become more lazy."
    } ]
  }, {
    "tStartMs": 9682173,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "Like, kids today\ndon't need to use their brain."
    } ]
  }, {
    "tStartMs": 9684133,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "They will be doing everything on..."
    } ]
  }, {
    "tStartMs": 9686853,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "You need to be very self-motivated,"
    } ]
  }, {
    "tStartMs": 9688653,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "but those people\ncan really leverage the technology"
    } ]
  }, {
    "tStartMs": 9690773,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "to create so much more productivity."
    } ]
  }, {
    "tStartMs": 9693093,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "I wonder if a kid will think tomorrow"
    } ]
  }, {
    "tStartMs": 9694933,
    "dDurationMs": 3600,
    "segs": [ {
      "utf8": "if I can just regurgitate a book\nfrom my device at any point,"
    } ]
  }, {
    "tStartMs": 9698613,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "then why read the book?"
    } ]
  }, {
    "tStartMs": 9700373,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "That's how I was thinking\nwhen I was in school."
    } ]
  }, {
    "tStartMs": 9702373,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "-Like, I can just Google the information.\n-[Amit] Yeah."
    } ]
  }, {
    "tStartMs": 9704213,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Why should I memorise this?"
    } ]
  }, {
    "tStartMs": 9705653,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "Okay. Last part."
    } ]
  }, {
    "tStartMs": 9708293,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "I want each of you guys to give one advice"
    } ]
  }, {
    "tStartMs": 9711653,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "to me, the 25-year-old,\nhaving watched this today."
    } ]
  }, {
    "tStartMs": 9716973,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Tomorrow morning I want to wake up\nand figure out what to build."
    } ]
  }, {
    "tStartMs": 9719493,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "One piece of advice."
    } ]
  }, {
    "tStartMs": 9721653,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "Would you like to go first?"
    } ]
  }, {
    "tStartMs": 9726213,
    "dDurationMs": 5640,
    "segs": [ {
      "utf8": "I think if somebody needs to\nplan something in this space"
    } ]
  }, {
    "tStartMs": 9731933,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "or whatever space, I think,"
    } ]
  }, {
    "tStartMs": 9734573,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "definitely a thorough research is needed."
    } ]
  }, {
    "tStartMs": 9737533,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "I mean, why you're going in, and--"
    } ]
  }, {
    "tStartMs": 9739933,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "I think you need to have that fuel\nor patience also to build it."
    } ]
  }, {
    "tStartMs": 9742533,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "That passion we are talking about"
    } ]
  }, {
    "tStartMs": 9745333,
    "dDurationMs": 4520,
    "segs": [ {
      "utf8": "and do pick up a narrow niche\ninstead of going too broad."
    } ]
  }, {
    "tStartMs": 9750413,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "I mean, pick up a smaller subset\nof whatever problem you want to solve."
    } ]
  }, {
    "tStartMs": 9754773,
    "dDurationMs": 1680,
    "segs": [ {
      "utf8": "Go double down and then move on."
    } ]
  }, {
    "tStartMs": 9757373,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "Definitely there are going to be\nfailures, learnings--"
    } ]
  }, {
    "tStartMs": 9759653,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "But I would term them as learnings\nand you keep pivoting with that."
    } ]
  }, {
    "tStartMs": 9763693,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "So that would be one thing."
    } ]
  }, {
    "tStartMs": 9765853,
    "dDurationMs": 3280,
    "segs": [ {
      "utf8": "I would say be really sure\nthat you want to do something."
    } ]
  }, {
    "tStartMs": 9770133,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "It's not always fun."
    } ]
  }, {
    "tStartMs": 9772893,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "I think most people\nshould not be entrepreneurs."
    } ]
  }, {
    "tStartMs": 9775253,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "Most people have a much higher\nquality of life doing other things,"
    } ]
  }, {
    "tStartMs": 9779413,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "specialising in a tech field\nor working for somebody else."
    } ]
  }, {
    "tStartMs": 9784693,
    "dDurationMs": 1920,
    "segs": [ {
      "utf8": "Very inspiring advice"
    } ]
  }, {
    "tStartMs": 9786693,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "to wannabe entrepreneurs, Carl,\nI must say."
    } ]
  }, {
    "tStartMs": 9790453,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "It's better to say it now, right,\nrather than finding out down the line?"
    } ]
  }, {
    "tStartMs": 9794453,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "[Rahul] He is scaring us."
    } ]
  }, {
    "tStartMs": 9795893,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Just be really sure."
    } ]
  }, {
    "tStartMs": 9796973,
    "dDurationMs": 4920,
    "segs": [ {
      "utf8": "I think, like, it needs to come from\na deep passion around something"
    } ]
  }, {
    "tStartMs": 9801973,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "because it's going to be hard."
    } ]
  }, {
    "tStartMs": 9803453,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "There will be euphoric days,\nbut there will also be terrible days."
    } ]
  }, {
    "tStartMs": 9807733,
    "dDurationMs": 2880,
    "segs": [ {
      "utf8": "Like, lack of sleep for weeks. Like--"
    } ]
  }, {
    "tStartMs": 9810693,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "I mean, we've all\nbeen through that probably."
    } ]
  }, {
    "tStartMs": 9813973,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "Why are you going to keep pushing forward\nwhen you face those difficulties?"
    } ]
  }, {
    "tStartMs": 9817453,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "I think you've got to be sure\nthat this is what you really want to do,"
    } ]
  }, {
    "tStartMs": 9821333,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "that you're passionate about it."
    } ]
  }, {
    "tStartMs": 9823773,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "I believe in the potential\nof every individual person."
    } ]
  }, {
    "tStartMs": 9826253,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "Like, if you really want to\naccomplish something, you can."
    } ]
  }, {
    "tStartMs": 9829453,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "But there's a cost associated with it."
    } ]
  }, {
    "tStartMs": 9833253,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "And I think for most people,\nthe cost is not worth it."
    } ]
  }, {
    "tStartMs": 9838133,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Rahul?"
    } ]
  }, {
    "tStartMs": 9840173,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "My only advice will be\nshow me your five friends."
    } ]
  }, {
    "tStartMs": 9846213,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Because..."
    } ]
  }, {
    "tStartMs": 9850493,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "if you have to build a successful company,\nthen you have to keep a good company."
    } ]
  }, {
    "tStartMs": 9855773,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "So, if you have--\nAnd you will become like that."
    } ]
  }, {
    "tStartMs": 9859853,
    "dDurationMs": 4960,
    "segs": [ {
      "utf8": "So, if you have a good company\nof people, who are like-minded,"
    } ]
  }, {
    "tStartMs": 9867133,
    "dDurationMs": 3800,
    "segs": [ {
      "utf8": "then even if you have, you know,\nthere's certain qualities"
    } ]
  }, {
    "tStartMs": 9871013,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "and things which you don't possess,\nyou can, you know..."
    } ]
  }, {
    "tStartMs": 9875213,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "A, rely, learn, and do,"
    } ]
  }, {
    "tStartMs": 9879133,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "and, you know, come up with..."
    } ]
  }, {
    "tStartMs": 9882533,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "come out of various difficulties."
    } ]
  }, {
    "tStartMs": 9884133,
    "dDurationMs": 5520,
    "segs": [ {
      "utf8": "So, basically you will become, like,\nwhatever your company is."
    } ]
  }, {
    "tStartMs": 9889733,
    "dDurationMs": 1960,
    "segs": [ {
      "utf8": "So, if your company is, like,"
    } ]
  }, {
    "tStartMs": 9891773,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "there are guys who are doing other things,"
    } ]
  }, {
    "tStartMs": 9896093,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "you will eventually, you will go that way."
    } ]
  }, {
    "tStartMs": 9900173,
    "dDurationMs": 4040,
    "segs": [ {
      "utf8": "But if you have\nfive people reading biology,"
    } ]
  }, {
    "tStartMs": 9906813,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "you will certainly go down that path."
    } ]
  }, {
    "tStartMs": 9908493,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "Even if you are not--\nYou don't want to learn,"
    } ]
  }, {
    "tStartMs": 9911173,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "you say, \"No, I am not a bio person,\nI am a physics person.\""
    } ]
  }, {
    "tStartMs": 9914213,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "But, at least, you are doing physics."
    } ]
  }, {
    "tStartMs": 9917173,
    "dDurationMs": 2320,
    "segs": [ {
      "utf8": "You are not just doing anything else."
    } ]
  }, {
    "tStartMs": 9920373,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "So, just keep a cohort of those people..."
    } ]
  }, {
    "tStartMs": 9926853,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "and I think you will--"
    } ]
  }, {
    "tStartMs": 9929093,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "A lot of things will get resolved."
    } ]
  }, {
    "tStartMs": 9930733,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Fair."
    } ]
  }, {
    "tStartMs": 9932213,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "My fleeting thought,"
    } ]
  }, {
    "tStartMs": 9934333,
    "dDurationMs": 3200,
    "segs": [ {
      "utf8": "I am quite excited\nabout this component incubator."
    } ]
  }, {
    "tStartMs": 9938213,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "I would say let's each of us\nput in a little bit of money,"
    } ]
  }, {
    "tStartMs": 9942253,
    "dDurationMs": 2040,
    "segs": [ {
      "utf8": "not care too much about the upside,"
    } ]
  }, {
    "tStartMs": 9945013,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "and try and get not too many."
    } ]
  }, {
    "tStartMs": 9947093,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "I think we should find four kids,"
    } ]
  }, {
    "tStartMs": 9949053,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "support them in building\na component company"
    } ]
  }, {
    "tStartMs": 9951693,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "with time, money and all of that."
    } ]
  }, {
    "tStartMs": 9954373,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "And maybe other people can learn\nfrom what we have done and replicate."
    } ]
  }, {
    "tStartMs": 9958413,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "And I hope we are successful."
    } ]
  }, {
    "tStartMs": 9960533,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "But, thank you to each one of you"
    } ]
  }, {
    "tStartMs": 9962853,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "for flying into my home and doing this."
    } ]
  }, {
    "tStartMs": 9966693,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "Very kind and I will reach out to you"
    } ]
  }, {
    "tStartMs": 9969533,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "for different kinds of advice\nat different points of time,"
    } ]
  }, {
    "tStartMs": 9973893,
    "dDurationMs": 2960,
    "segs": [ {
      "utf8": "and also to help all the young\nwannabe entrepreneurs in India."
    } ]
  }, {
    "tStartMs": 9976933,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "But, thank you."
    } ]
  }, {
    "tStartMs": 9978413,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "No, no. Thank you so much.\nThanks for the great food."
    } ]
  }, {
    "tStartMs": 9981093,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "-[Amit] Good food.\n-[Rahul] Loved it."
    } ]
  }, {
    "tStartMs": 9982293,
    "dDurationMs": 1040,
    "segs": [ {
      "utf8": "Thank you guys."
    } ]
  }, {
    "tStartMs": 9986653,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "Like a high protein..."
    } ]
  }, {
    "tStartMs": 9988213,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "It's protein powder,\nyoghurt, and dark chocolate."
    } ]
  }, {
    "tStartMs": 9991093,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "-Very nice.\n-Yeah. It's all, like, really clean food."
    } ]
  }, {
    "tStartMs": 9995293,
    "dDurationMs": 1640,
    "segs": [ {
      "utf8": "Did you guys have fun? Was that okay?"
    } ]
  }, {
    "tStartMs": 9997013,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "-[Amit] Yeah, yeah.\n-It was superb."
    } ]
  } ]
}
